    { "type": "image_picker", "id": "left_image",   "label": "Image statique (médiathèque — prioritaire)" },
    { "type": "text",         "id": "left_img_alt", "label": "Texte alternatif image (SEO + accessibilité)", "default": "Image éditoriale" },
    { "type": "select", "id": "left_asset", "label": "Image assets (si médiathèque vide)", "default": "hp-editorial-2.jpg",
      "options": [
        { "value": "hp-editorial-2.jpg", "label": "Editorial 2" }, { "value": "hp-editorial.jpg", "label": "Editorial 1" },
        { "value": "hp-cta.jpg", "label": "CTA Banner" }, { "value": "hp-hero-1.jpg", "label": "Hero 1" },
        { "value": "hp-hero-2.jpg", "label": "Hero 2" }, { "value": "hp-hero-3.jpg", "label": "Hero 3" }
      ] },
    { "type": "header", "content": "Carousel gauche — comportement" },
    { "type": "checkbox", "id": "autoplay_enabled", "label": "Autoplay",     "default": false },
    { "type": "range",    "id": "autoplay_delay",   "label": "Délai (ms)",   "min": 2000, "max": 9000, "step": 500, "default": 4000 },
    { "type": "checkbox", "id": "show_arrows",      "label": "Flèches",      "default": true },
    { "type": "checkbox", "id": "show_dots",        "label": "Dots",         "default": true },
