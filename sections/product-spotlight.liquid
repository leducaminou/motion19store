    { "type": "collection", "id": "collection",  "label": "Collection à afficher" },
    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "bg_color",           "label": "Fond section",   "default": "#ffffff" },
    { "type": "color", "id": "text_color",         "label": "Couleur texte",  "default": "#0a0a0a" },
