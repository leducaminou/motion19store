    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bas mobile",    "min": 0, "max": 120, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_top_desktop",   "label": "Padding haut desktop",  "min": 0, "max": 120, "step": 4, "default": 52, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop","label": "Padding bas desktop",   "min": 0, "max": 120, "step": 4, "default": 52, "unit": "px" },
    { "type": "range", "id": "margin_top",    "label": "Marge haut", "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px" },
    { "type": "range", "id": "margin_bottom", "label": "Marge bas",  "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px" },
    { "type": "header", "content": "Visibilité" },
    { "type": "checkbox", "id": "hide_on_mobile",  "label": "Masquer mobile",  "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Masquer desktop", "default": false },
    { "type": "header", "content": "Avancé" },
    { "type": "text", "id": "custom_css", "label": "CSS personnalisé" }
  ],
  "blocks": [
