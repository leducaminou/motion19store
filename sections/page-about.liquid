  assign hero_overlay      = section.settings.hero_overlay
  assign hero_height_d     = section.settings.hero_height_d
  assign hero_height_m     = section.settings.hero_height_m
  assign hero_sz_d         = section.settings.hero_sz_d
  assign hero_sz_m         = section.settings.hero_sz_m
  assign hero_fw           = section.settings.hero_fw
  assign hero_title_col    = section.settings.hero_title_col

  assign show_mission      = section.settings.show_mission
  assign mission_label     = section.settings.mission_label
  assign mission_title     = section.settings.mission_title
  assign mission_body      = section.settings.mission_body
  assign mission_bg        = section.settings.mission_bg
  assign mission_pt_d      = section.settings.mission_pt_d
  assign mission_pb_d      = section.settings.mission_pb_d
  assign mission_pt_m      = section.settings.mission_pt_m
  assign mission_pb_m      = section.settings.mission_pb_m

  assign show_products     = section.settings.show_products
  assign products_title    = section.settings.products_title
  assign products_bg       = section.settings.products_bg
  assign products_pt_d     = section.settings.products_pt_d
  assign products_pb_d     = section.settings.products_pb_d
  assign products_pt_m     = section.settings.products_pt_m
  assign products_pb_m     = section.settings.products_pb_m

  assign show_why          = section.settings.show_why
  assign why_title         = section.settings.why_title
  assign why_bg            = section.settings.why_bg
  assign why_pt_d          = section.settings.why_pt_d
  assign why_pb_d          = section.settings.why_pb_d
  assign why_pt_m          = section.settings.why_pt_m
  assign why_pb_m          = section.settings.why_pb_m

  assign show_cta          = section.settings.show_cta
  assign cta_eyebrow       = section.settings.cta_eyebrow
  assign cta_title         = section.settings.cta_title
  assign cta_body          = section.settings.cta_body
  assign cta_btn_text      = section.settings.cta_btn_text
  assign cta_btn_url       = section.settings.cta_btn_url
  assign cta_btn2_text     = section.settings.cta_btn2_text
  assign cta_btn2_url      = section.settings.cta_btn2_url
  assign cta_bg            = section.settings.cta_bg
  assign show_contact_info = section.settings.show_contact_info
  assign cta_address       = section.settings.cta_address
  assign cta_phone         = section.settings.cta_phone
  assign cta_email         = section.settings.cta_email
  assign cta_pt_d          = section.settings.cta_pt_d
  assign cta_pb_d          = section.settings.cta_pb_d
  assign cta_pt_m          = section.settings.cta_pt_m
  assign cta_pb_m          = section.settings.cta_pb_m
-%}

<div class="pga section-page-about" id="section-{{ section.id }}">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Motion19",
    "url": "{{ shop.url }}",
    "logo": "{{ settings.logo | image_url: width: 200 }}",
    "description": "{{ page.description | escape }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1203 Bvd de la Liberté, Akwa",
      "addressLocality": "Douala",
      "addressCountry": "CM"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+237-656-99-99-89",
      "contactType": "customer service"
    }
  }
  </script>

  <!-- ── Hero ── -->
  <div
    class="pg__hero"
    style="--pg-hero-h: {{ hero_height_d }}px; --pg-hero-h-m: {{ hero_height_m }}px; --pg-hero-fw: {{ hero_fw }}; --pg-hero-sz-d: {{ hero_sz_d }}px; --pg-hero-sz-m: {{ hero_sz_m }}px; --pg-hero-title-col: {{ hero_title_col }};"
  >
    {%- if hero_bg != blank -%}
      <div class="pg__hero-bg">
        <img
          src="{{ hero_bg | image_url: width: 1600 }}"
          alt="{{ hero_heading | escape }}"
          width="{{ hero_bg.width }}"
          height="{{ hero_bg.height }}"
          loading="eager"
          fetchpriority="high"
        >
      </div>
      <div class="pg__hero-overlay" style="opacity: {{ hero_overlay | divided_by: 100.0 }};"></div>
    {%- endif -%}
    <div class="pg__hero-content" style="max-width: var(--container-width); padding-inline: var(--container-padding); margin-inline: auto;">
      {%- if show_breadcrumb -%}
        <nav class="pg__breadcrumb" aria-label="Fil d'Ariane">
          <a href="{{ shop.url }}">Accueil</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{{ hero_heading }}</span>
        </nav>
      {%- endif -%}
      <h1 class="pg__hero-title">{{ hero_heading }}</h1>
      {%- if hero_subheading != blank -%}
        <p class="pg__hero-subtitle">{{ hero_subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  <!-- ── Mission ── -->
  {%- if show_mission -%}
    <div
      class="pga__mission"
      style="background: {{ mission_bg }}; --pga-mission-pt-d: {{ mission_pt_d }}px; --pga-mission-pb-d: {{ mission_pb_d }}px; --pga-mission-pt-m: {{ mission_pt_m }}px; --pga-mission-pb-m: {{ mission_pb_m }}px;"
    >
      <div class="pga__mission-inner" style="max-width: var(--container-width); padding-inline: var(--container-padding); margin-inline: auto;">
        <div class="pga__mission-text">
          <p class="pga__section-label">{{ mission_label }}</p>
          <div class="pga__accent-line"></div>
          <h2 class="pga__section-title">{{ mission_title }}</h2>
          <div class="pga__section-body">{{ mission_body }}</div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- ── Ce que nous proposons ── -->
  {%- if show_products -%}
    <div
      class="pga__products"
      style="background: {{ products_bg }}; --pga-products-pt-d: {{ products_pt_d }}px; --pga-products-pb-d: {{ products_pb_d }}px; --pga-products-pt-m: {{ products_pt_m }}px; --pga-products-pb-m: {{ products_pb_m }}px;"
    >
      <div class="pga__products-inner">
        <div class="pga__products-head">
          <h2 class="pga__products-title">{{ products_title }}</h2>
        </div>
        <div class="pga__prod-grid">
          {%- for i in (1..6) -%}
            {%- liquid
              assign prod_icon  = 'prod' | append: i | append: '_icon'
              assign prod_label = 'prod' | append: i | append: '_label'
              assign prod_url   = 'prod' | append: i | append: '_url'
              assign icon_val   = section.settings[prod_icon]
              assign label_val  = section.settings[prod_label]
              assign url_val    = section.settings[prod_url]
            -%}
            {%- if label_val != blank -%}
              <a class="pga__prod-card" href="{{ url_val | default: shop.url }}">
                {%- if icon_val != blank -%}
                  <span class="pga__prod-icon" aria-hidden="true">{{ icon_val }}</span>
                {%- endif -%}
                <span class="pga__prod-label">{{ label_val }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- ── Pourquoi nous choisir ── -->
  {%- if show_why -%}
    <div
      class="pga__why"
      style="background: {{ why_bg }}; --pga-why-pt-d: {{ why_pt_d }}px; --pga-why-pb-d: {{ why_pb_d }}px; --pga-why-pt-m: {{ why_pt_m }}px; --pga-why-pb-m: {{ why_pb_m }}px;"
    >
      <div class="pga__why-inner">
        <div class="pga__why-head">
          <p class="pga__section-label">Nos engagements</p>
          <div class="pga__accent-line"></div>
          <h2 class="pga__section-title">{{ why_title }}</h2>
        </div>
        <ul class="pga__checklist">
          {%- for i in (1..4) -%}
            {%- liquid
              assign why_title_key = 'why' | append: i | append: '_title'
              assign why_desc_key  = 'why' | append: i | append: '_desc'
              assign why_title_val = section.settings[why_title_key]
              assign why_desc_val  = section.settings[why_desc_key]
            -%}
            {%- if why_title_val != blank -%}
              <li class="pga__checklist-item">
                <span class="pga__check-icon" aria-hidden="true"></span>
                <div class="pga__checklist-text">
                  <p class="pga__checklist-title">{{ why_title_val }}</p>
                  {%- if why_desc_val != blank -%}
                    <p class="pga__checklist-desc">{{ why_desc_val }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}

  <!-- ── CTA Engagement ── -->
  {%- if show_cta -%}
    <div
      class="pga__cta"
      style="--pga-cta-bg: {{ cta_bg }}; --pga-cta-pt-d: {{ cta_pt_d }}px; --pga-cta-pb-d: {{ cta_pb_d }}px; --pga-cta-pt-m: {{ cta_pt_m }}px; --pga-cta-pb-m: {{ cta_pb_m }}px;"
    >
      <div class="pga__cta-inner">
        {%- if cta_eyebrow != blank -%}
          <p class="pga__cta-eyebrow">{{ cta_eyebrow }}</p>
        {%- endif -%}
        <h2 class="pga__cta-title">{{ cta_title }}</h2>
        {%- if cta_body != blank -%}
          <p class="pga__cta-body">{{ cta_body }}</p>
        {%- endif -%}
        <div class="pga__cta-actions">
          {%- if cta_btn_text != blank -%}
            <a href="{{ cta_btn_url | default: shop.url }}" class="btn btn--primary">{{ cta_btn_text }}</a>
          {%- endif -%}
          {%- if cta_btn2_text != blank -%}
            <a href="{{ cta_btn2_url | default: shop.url | append: '/pages/contact' }}" class="btn btn--outline-white">{{ cta_btn2_text }}</a>
          {%- endif -%}
        </div>
        {%- if show_contact_info -%}
          <div class="pga__contact-info">
            {%- if cta_address != blank -%}
              <span class="pga__contact-info-item">{{ cta_address }}</span>
            {%- endif -%}
            {%- if cta_phone != blank -%}
              <span class="pga__contact-info-item">{{ cta_phone }}</span>
            {%- endif -%}
            {%- if cta_email != blank -%}
              <span class="pga__contact-info-item">{{ cta_email }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</div>

