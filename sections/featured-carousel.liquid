{{ 'card.css' | asset_url | stylesheet_tag }}
{%- comment -%} Featured Carousel — Motion19 — OS 2.0 v3 {%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign bg_color      = section.settings.bg_color           | default: '#f7f7f8'
  assign card_bg       = section.settings.card_bg            | default: '#ffffff'
  assign text_color    = section.settings.text_color         | default: '#0a0a0a'
  assign title_color   = section.settings.title_color        | default: '#0a0a0a'
  assign eyebrow_col   = section.settings.eyebrow_color      | default: '#0787ea'
  assign dot_active    = section.settings.dot_active_color   | default: '#0a0a0a'
  assign dot_inactive  = section.settings.dot_inactive_color | default: 'rgba(10,10,10,0.18)'
  assign arrow_color   = section.settings.arrow_color        | default: '#0a0a0a'

  assign autoplay      = section.settings.autoplay_enabled
  assign ap_delay      = section.settings.autoplay_delay     | default: 4000
  assign show_arr      = section.settings.show_arrows
  assign show_nav      = section.settings.show_dots
  assign nav_pos       = section.settings.nav_position       | default: 'bottom'
  assign arr_size      = section.settings.arrow_size         | default: 36
  assign dot_size      = section.settings.dot_size           | default: 6

  assign pt_m          = section.settings.padding_top_mobile    | default: 40
  assign pb_m          = section.settings.padding_bottom_mobile | default: 36
  assign pt_d          = section.settings.padding_top_desktop   | default: 52
  assign pb_d          = section.settings.padding_bottom_desktop | default: 36
  assign mt            = section.settings.margin_top            | default: 0
  assign mb            = section.settings.margin_bottom         | default: 0
  assign gap_cards     = section.settings.cards_gap             | default: 14
  assign max_width     = section.settings.section_max_width     | default: 1400
  assign header_align  = section.settings.header_align          | default: 'left'

  assign sep_enabled   = section.settings.separator_enabled     | default: false
  assign sep_text      = section.settings.separator_text
  assign sep_style     = section.settings.separator_style       | default: 'line'

  assign coll_handle   = section.settings.collection    | default: ''
  assign max_products  = section.settings.max_products  | default: 12
  assign show_badge    = section.settings.show_badge
  assign badge_text    = section.settings.badge_text    | default: 'Meilleur vente'
  assign show_atc      = section.settings.show_atc

  if coll_handle != blank and collections[coll_handle] != blank
    assign products_list = collections[coll_handle].products
  else
    assign products_list = collections.all.products
  endif
-%}

<section
  id="fc-{{ sid }}"
  class="fc"
  aria-labelledby="fc-title-{{ sid }}"
  style="
    --fc-bg:          {{ bg_color }};
    --fc-card-bg:     {{ card_bg }};
    --fc-text:        {{ text_color }};
    --fc-title:       {{ title_color }};
    --fc-eyebrow:     {{ eyebrow_col }};
    --fc-dot-active:  {{ dot_active }};
    --fc-dot-inactive:{{ dot_inactive }};
    --fc-arrow-color: {{ arrow_color }};
    --fc-pt-m:        {{ pt_m }}px;
    --fc-pb-m:        {{ pb_m }}px;
    --fc-pt-d:        {{ pt_d }}px;
    --fc-pb-d:        {{ pb_d }}px;
    --fc-mt:          {{ mt }}px;
    --fc-mb:          {{ mb }}px;
    --fc-gap:         {{ gap_cards }}px;
    --fc-max-w:       {{ max_width }}px;
    --fc-arrow-size:  {{ arr_size }}px;
    --fc-dot-size:    {{ dot_size }}px;
  "
>
  <div class="fc__inner">
    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="fc__header fc__header--{{ header_align }}">
      <div class="fc__header-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="fc__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="fc__title" id="fc-title-{{ sid }}">
          {{- section.settings.title | default: 'Nos coups de cœur' -}}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="fc__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_tabs -%}
        <div class="fc__tabs" role="tablist" aria-label="Filtrer les produits">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <button
                class="fc__tab{% if forloop.first %} fc__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-tab="{{ block.id }}"
                data-badge="{{ block.settings.badge | default: block.settings.label }}"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                {{ block.shopify_attributes }}
              >{{ block.settings.label }}</button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if sep_enabled -%}
      <div class="fc__sep fc__sep--{{ sep_style }}" aria-hidden="true">
        {%- if sep_text != blank -%}<span class="fc__sep-text">{{ sep_text }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Carousel viewport (full-width flush) ── {%- endcomment -%}
    <div class="fc__viewport-wrap">
      <div class="fc__viewport" id="fc-viewport-{{ sid }}">
        <ul class="fc__track" id="fc-track-{{ sid }}" role="list" aria-label="Produits">
          {%- for product in products_list limit: max_products -%}
            {%- assign img1 = product.featured_image -%}
            {%- assign img2 = product.images[1] -%}
            <li class="fc__item">
              <article class="m19-card" aria-label="{{ product.title | escape }}">
                <a class="m19-card__media m19-card__media--square" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                  {%- if img1 != blank -%}
                    <img
                      class="m19-card__img m19-card__img--primary"
                      src="{{ img1 | image_url: width: 600 }}"
                      srcset="{{ img1 | image_url: width: 400 }} 400w, {{ img1 | image_url: width: 600 }} 600w, {{ img1 | image_url: width: 800 }} 800w"
                      sizes="(max-width:768px) calc((100vw - 48px) / 1.5), (max-width:1280px) calc((100vw - 76px) / 3.5), calc((100vw - 106px) / 5.5)"
                      alt="{{ img1.alt | default: product.title | escape }}"
                      loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
                      width="{{ img1.width }}"
                      height="{{ img1.height }}"
                    >
                    {%- if img2 != blank -%}
                      <img
                        class="m19-card__img m19-card__img--hover"
                        src="{{ img2 | image_url: width: 600 }}"
                        alt="{{ img2.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="{{ img2.width }}"
                        height="{{ img2.height }}"
                        aria-hidden="true"
                      >
                    {%- endif -%}
                  {%- else -%}
                    <div class="m19-card__media-fallback" aria-hidden="true"></div>
                  {%- endif -%}

                  {%- if show_badge -%}
                    <span class="m19-card__badge fc__badge" aria-hidden="true">{{ badge_text }}</span>
                  {%- endif -%}

                  {%- if show_atc -%}
                    <button
                      class="m19-card__action"
                      type="button"
                      data-variant-id="{{ product.variants.first.id }}"
                      aria-label="Ajouter {{ product.title | escape }} au panier"
                    >
                      <svg class="m19-card__action-icon m19-card__action-icon--bag" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                      </svg>
                      <svg class="m19-card__action-icon m19-card__action-icon--check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </a>

                <div class="m19-card__body">
                  <a class="m19-card__name" href="{{ product.url }}">{{ product.title | truncate: 40 }}</a>
                  <div class="m19-card__pricing">
                    {%- if product.compare_at_price > product.price -%}
                      <s class="m19-card__price--compare">{{ product.compare_at_price | money }}</s>
                    {%- endif -%}
                    <span class="m19-card__price">{{ product.price | money }}</span>
                  </div>
                </div>
              </article>
            </li>
          {%- else -%}
            <li class="fc__empty">Aucun produit disponible.</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ── Footer: dots LEFT, arrows RIGHT ── {%- endcomment -%}
    {%- if show_nav or show_arr -%}
      <div class="fc__footer">
        <div class="fc__footer-left">
          {%- if show_nav -%}
            <div class="fc__dots" id="fc-dots-{{ sid }}" role="tablist" aria-label="Position carousel"></div>
          {%- endif -%}
        </div>
        <div class="fc__footer-right">
          {%- if show_arr -%}
            <div class="fc__arrows">
              <button class="fc__arrow" id="fc-prev-{{ sid }}" aria-label="Produits précédents" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="fc__arrow" id="fc-next-{{ sid }}" aria-label="Produits suivants" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
/* ═══════════════════════════════════════════════════
   Featured Carousel — fc
   Responsive: ≤768px → 1.5 cards | 769-1280px → 3.5 cards | ≥1281px → 5.5 cards
   ═══════════════════════════════════════════════════ */
.fc {
  --fc-pad:    16px;
  --fc-ease:   cubic-bezier(0.4, 0, 0.2, 1);
  /* Default card width: mobile 1.5 cards visible */
  --fc-card-w: calc((100vw - (2 * var(--fc-pad)) - var(--fc-gap)) / 1.5);

  background:    var(--fc-bg, #f7f7f8);
  color:         var(--fc-text, #0a0a0a);
  margin-top:    var(--fc-mt, 0);
  margin-bottom: var(--fc-mb, 0);
}

/* ── 769px → 1280px : 3.5 cards ── */
@media (min-width: 769px) {
  .fc {
    --fc-pad: 24px;
    --fc-card-w: calc((100vw - (2 * var(--fc-pad)) - (2.5 * var(--fc-gap))) / 3.5);
  }
}

/* ── ≥1281px : 5.5 cards ── */
@media (min-width: 1281px) {
  .fc {
    --fc-pad: 40px;
    --fc-card-w: calc((100vw - (2 * var(--fc-pad)) - (4.5 * var(--fc-gap))) / 5.5);
  }
}

/* ── Inner container — matches new-products max-width ── */
.fc__inner {
  max-width: var(--fc-max-w, 1400px);
  margin: 0 auto;
  padding-top: var(--fc-pt-m, 40px);
  padding-bottom: var(--fc-pb-m, 36px);
}
@media (min-width: 769px) {
  .fc__inner {
    padding-top: var(--fc-pt-d, 52px);
    padding-bottom: var(--fc-pb-d, 36px);
  }
}

/* ── Header ── */
.fc__header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
  padding: 0 var(--fc-pad) 24px;
}
.fc__header--center { align-items: center; text-align: center; }
.fc__header--right  { align-items: flex-end; text-align: right; }

@media (min-width: 769px) {
  .fc__header {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
  }
  .fc__header--center { flex-direction: column; align-items: center; }
  .fc__header--right  { flex-direction: column; align-items: flex-end; }
}

.fc__header-text { display: flex; flex-direction: column; gap: 4px; }

.fc__eyebrow {
  font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--fc-eyebrow, #0787ea);
}
.fc__title {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 800; letter-spacing: -0.03em;
  color: var(--fc-title, #0a0a0a); margin: 0;
}
.fc__subtitle {
  font-size: 0.875rem; color: color-mix(in srgb, var(--fc-text, #0a0a0a) 60%, transparent);
  margin: 0; max-width: 52ch; line-height: 1.55;
}
.fc__desc {
  font-size: 0.875rem; color: color-mix(in srgb, var(--fc-text, #0a0a0a) 55%, transparent);
  margin: 0; max-width: 60ch; line-height: 1.6; margin-top: 4px;
}

/* Tabs */
.fc__tabs { display: flex; gap: 6px; flex-wrap: wrap; }
.fc__tab {
  padding: 6px 16px;
  font-size: 0.8rem; font-weight: 600; letter-spacing: 0.03em;
  border-radius: 0.75rem; border: 1.5px solid var(--fc-text, #0a0a0a);
  background: transparent; color: var(--fc-text, #0a0a0a);
  cursor: pointer;
  transition: background 180ms var(--fc-ease), color 180ms var(--fc-ease);
}
.fc__tab--active { background: var(--fc-text, #0a0a0a); color: var(--fc-bg, #f7f7f8); }

/* Separator */
.fc__sep {
  margin: 0 var(--fc-pad) 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  color: color-mix(in srgb, var(--fc-text, #0a0a0a) 35%, transparent);
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.fc__sep--line::before,
.fc__sep--line::after {
  content: '';
  flex: 1;
  height: 1px;
  background: currentColor;
}
.fc__sep--dashed::before,
.fc__sep--dashed::after {
  content: '';
  flex: 1;
  height: 1px;
  border-top: 1px dashed currentColor;
}
.fc__sep--dots::before { display: none; }
.fc__sep--dots { justify-content: center; }

/* ── Viewport wrap — clip only on X so card shadows are fully visible on Y ── */
.fc__viewport-wrap {
  overflow-x: clip;
  overflow-y: visible;
}

/* ── Viewport ── */
.fc__viewport {
  padding-left: var(--fc-pad);
  overflow-x: visible;
  overflow-y: visible;
  cursor: grab;
  user-select: none;
  -webkit-user-select: none;
}
.fc__viewport:active { cursor: grabbing; }

/* ── Track ── */
.fc__track {
  display: flex;
  gap: var(--fc-gap, 14px);
  padding-top: 20px;
  padding-bottom: 28px;
  padding-right: var(--fc-pad);
  margin: 0;
  padding-left: 0;
  list-style: none;
}

/* ── Items — identical height/proportions ── */
.fc__item {
  flex: 0 0 var(--fc-card-w);
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.fc__item .m19-card {
  flex: 1;
  height: 100%;
  background: var(--fc-card-bg, #fff);
}

/* Badge */
.fc__item .fc__badge {
  background: #fff;
  color: #0a0a0a;
  border: 1px solid rgba(10, 10, 10, 0.75);
  border-radius: 0.75rem;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: none;
  padding: 3px 7px;
  line-height: 1;
  top: 10px;
  left: 10px;
  box-shadow: none;
}

.fc__empty { padding: 24px; font-size: 0.875rem; color: #aaa; }

/* ── Footer — dots LEFT, arrows RIGHT ── */
.fc__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px var(--fc-pad) 0;
  gap: 16px;
}

/* Mobile ≤767px : masquer dots, centrer flèches */
@media (max-width: 767px) {
  .fc__footer        { justify-content: center; }
  .fc__footer-left   { display: none; }
  .fc__footer-right  { margin: 0 auto; }
}

.fc__footer-left  { display: flex; align-items: center; }
.fc__footer-right { display: flex; align-items: center; }

/* ── Arrows — minimal, no bg, no border, no shadow ── */
.fc__arrows { display: flex; gap: 4px; }
.fc__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--fc-arrow-size, 36px);
  height: var(--fc-arrow-size, 36px);
  border-radius: 0.75rem;
  border: none;
  background: none;
  color: var(--fc-arrow-color, #0a0a0a);
  cursor: pointer;
  transition: background 180ms var(--fc-ease), color 180ms var(--fc-ease);
  padding: 0;
}
.fc__arrow:hover {
  background: rgba(10, 10, 10, 0.07);
}
.fc__arrow:disabled { opacity: 0.28; cursor: default; pointer-events: none; }
.fc__arrow:focus-visible { outline: 2px solid #0787ea; outline-offset: 2px; }

/* ── Dots ── */
.fc__dots { display: flex; align-items: center; gap: 8px; }

.fc__dot {
  width: var(--fc-dot-size, 6px);
  height: var(--fc-dot-size, 6px);
  padding: 0;
  border: none;
  border-radius: 50%;
  background: var(--fc-dot-inactive, rgba(10,10,10,0.18));
  cursor: pointer;
  transition: width 280ms var(--fc-ease), border-radius 280ms var(--fc-ease), background 280ms var(--fc-ease), transform 280ms ease, opacity 280ms ease;
}
.fc__dot--active {
  width: calc(var(--fc-dot-size, 6px) * 3.5);
  border-radius: 3px;
  background: var(--fc-dot-active, #0a0a0a);
}
.fc__dot--small  { transform: scale(0.6); opacity: 0.5; }
.fc__dot--hidden { display: none; }
.fc__dot:focus-visible { outline: 2px solid #0787ea; outline-offset: 2px; }
</style>

<script>
(function () {
  'use strict';
  var sid     = '{{ sid }}';
  var autoplay = {{ autoplay | json }};
  var apDelay  = {{ ap_delay }};

  function init() {
    var section  = document.getElementById('fc-' + sid);
    if (!section || !window.EmblaCarousel) return;

    var viewport = document.getElementById('fc-viewport-' + sid);
    if (!viewport) return;

    var dotsWrap = document.getElementById('fc-dots-' + sid);
    var btnPrev  = document.getElementById('fc-prev-' + sid);
    var btnNext  = document.getElementById('fc-next-' + sid);
    var tabs     = Array.from(section.querySelectorAll('.fc__tab'));
    var dots     = [];

    var plugins = [];
    if (autoplay && window.EmblaCarouselAutoScroll) {
      plugins.push(window.EmblaCarouselAutoScroll({
        direction: 'forward',
        speed: 1.5,
        startDelay: apDelay,
        playOnInit: true,
        stopOnMouseEnter: true,
        stopOnInteraction: true,
        stopOnFocusIn: true
      }));
    }

    var embla = window.EmblaCarousel(viewport, {
      loop:           true,
      align:          'start',
      slidesToScroll: 1,
      dragFree:       false,
      containScroll:  false
    }, plugins);

    /* ── Dots ── */
    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      dots = [];
      embla.scrollSnapList().forEach(function (_, i) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'fc__dot';
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-label', 'Page ' + (i + 1));
        btn.addEventListener('click', function () { embla.scrollTo(i); });
        dotsWrap.appendChild(btn);
        dots.push(btn);
      });
      updateDots();
    }

    function updateDots() {
      var maxV = 5;
      var idx  = embla.selectedScrollSnap();
      dots.forEach(function (d, i) {
        var active = i === idx;
        d.className = 'fc__dot' + (active ? ' fc__dot--active' : '');
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      if (dots.length > maxV) {
        var half  = Math.floor(maxV / 2);
        var start = Math.max(0, idx - half);
        var end   = Math.min(dots.length, start + maxV);
        if (end - start < maxV) start = Math.max(0, end - maxV);
        dots.forEach(function (d, i) {
          if (i < start || i >= end) {
            if (i === start - 1 || i === end) d.classList.add('fc__dot--small');
            else d.classList.add('fc__dot--hidden');
          }
        });
      }
    }

    embla.on('select', updateDots);
    embla.on('reInit', buildDots);
    buildDots();

    /* ── Arrows ── */
    if (btnPrev) btnPrev.addEventListener('click', function () { embla.scrollPrev(); });
    if (btnNext) btnNext.addEventListener('click', function () { embla.scrollNext(); });

    /* ── ATC ── */
    section.addEventListener('click', function (e) {
      var btn = e.target.closest('.m19-card__action');
      if (!btn || btn.disabled) return;
      e.preventDefault();
      e.stopPropagation();
      var id = btn.dataset.variantId;
      if (!id) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.status) { btn.disabled = false; return; }
          btn.classList.add('is-added');
          var counter = document.querySelector('[data-cart-count]');
          if (counter) fetch('/cart.js').then(function (r) { return r.json(); }).then(function (c) { counter.textContent = c.item_count; });
          setTimeout(function () { btn.classList.remove('is-added'); btn.disabled = false; }, 2200);
        })
        .catch(function () { btn.disabled = false; });
    });

    /* ── Tabs ── */
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) {
          t.classList.remove('fc__tab--active');
          t.setAttribute('aria-selected', 'false');
          t.setAttribute('tabindex', '-1');
        });
        tab.classList.add('fc__tab--active');
        tab.setAttribute('aria-selected', 'true');
        tab.setAttribute('tabindex', '0');
        var label = tab.dataset.badge || '{{ badge_text }}';
        section.querySelectorAll('.fc__badge').forEach(function (b) { b.textContent = label; });
        embla.scrollTo(0);
      });
    });

    /* Reveal cards */
    function showAllCards() {
      viewport.querySelectorAll('.m19-card').forEach(function (c) { c.classList.add('is-visible'); });
    }
    showAllCards();
    embla.on('init',   showAllCards);
    embla.on('reInit', showAllCards);
    embla.on('select', showAllCards);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sid) init();
  });
})();
</script>

