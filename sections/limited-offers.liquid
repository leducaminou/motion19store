    { "type": "color", "id": "arrow_color",        "label": "Icône flèches", "default": "#ffffff" },
    { "type": "color", "id": "dot_active_color",   "label": "Dot actif",     "default": "#ffffff" },
    { "type": "color", "id": "dot_inactive_color", "label": "Dot inactif",   "default": "#2d2d2d" },

