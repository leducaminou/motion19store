    { "type": "range", "id": "eyebrow_font_size",  "label": "Taille eyebrow (px)",    "min": 8,  "max": 18, "step": 1, "default": 11, "unit": "px" },
    { "type": "range", "id": "subtitle_font_size", "label": "Taille sous-titre (px)", "min": 10, "max": 24, "step": 1, "default": 14, "unit": "px" },

