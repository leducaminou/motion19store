{{ 'card.css' | asset_url | stylesheet_tag }}
{%- comment -%} Limited Offers — Motion19 — OS 2.0 (Swiper, dark mode, full customisable) {%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign bg_color       = section.settings.bg_color            | default: '#0d0d0d'
  assign card_bg        = section.settings.card_bg             | default: '#1a1a1a'
  assign text_color     = section.settings.text_color          | default: '#e8e8e8'
  assign title_color    = section.settings.title_color         | default: '#ffffff'
  if section.settings.eyebrow_color == blank
    assign eyebrow_col = 'var(--color-primary)'
  else
    assign eyebrow_col = section.settings.eyebrow_color
  endif
  assign subtitle_col   = section.settings.subtitle_color      | default: '#808080'
  assign dot_active     = section.settings.dot_active_color    | default: '#ffffff'
  assign dot_inactive   = section.settings.dot_inactive_color  | default: '#2d2d2d'
  assign arrow_color    = section.settings.arrow_color         | default: '#ffffff'

  assign title_size     = section.settings.title_font_size     | default: 32
  assign title_weight   = section.settings.title_font_weight   | default: '800'
  assign eyebrow_size   = section.settings.eyebrow_font_size   | default: 11
  assign subtitle_size  = section.settings.subtitle_font_size  | default: 14

  assign img_ratio      = section.settings.image_ratio         | default: '4 / 5'
  assign img_fit        = section.settings.image_fit           | default: 'contain'
  assign card_radius    = section.settings.card_border_radius  | default: 8
  assign card_border_c  = section.settings.card_border_color   | default: '#2d2d2d'
  assign card_name_col  = section.settings.card_name_color     | default: '#f0f0f0'
  assign card_price_col = section.settings.card_price_color    | default: '#ffffff'

  assign discount_bg    = section.settings.discount_badge_bg   | default: '#e63946'
  assign discount_txt   = section.settings.discount_badge_text | default: '#ffffff'

  assign show_badge   = section.settings.show_discount_badge
  assign show_compare = section.settings.show_compare_price

  assign autoplay       = section.settings.autoplay_enabled
  assign ap_delay       = section.settings.autoplay_delay      | default: 4000
  assign carousel_spd   = section.settings.carousel_speed      | default: 500
  assign loop_enabled   = section.settings.loop_enabled
  assign show_arr       = section.settings.show_arrows
  assign show_nav       = section.settings.show_dots
  assign arr_size       = section.settings.arrow_size          | default: 36
  assign arr_radius     = section.settings.arrow_border_radius | default: 6
  assign dot_size       = section.settings.dot_size            | default: 6
  assign dot_gap_val    = section.settings.dot_gap             | default: 8

  assign pt_m           = section.settings.padding_top_mobile     | default: 48
  assign pb_m           = section.settings.padding_bottom_mobile  | default: 44
  assign pt_d           = section.settings.padding_top_desktop    | default: 64
  assign pb_d           = section.settings.padding_bottom_desktop | default: 52
  assign mt             = section.settings.margin_top             | default: 0
  assign mb             = section.settings.margin_bottom          | default: 0
  assign gap_cards      = section.settings.cards_gap              | default: 14
  assign max_width      = section.settings.section_max_width      | default: 1400
  assign header_align   = section.settings.header_align           | default: 'left'

  assign coll_handle    = section.settings.collection    | default: ''
  assign max_products   = section.settings.max_products  | default: 12
  assign show_atc       = section.settings.show_atc

  assign show_cta  = section.settings.show_view_all
  assign cta_label = section.settings.view_all_label | default: 'Voir tout'
  assign cta_url   = section.settings.view_all_url

  if coll_handle != blank and collections[coll_handle] != blank
    assign products_list = collections[coll_handle].products
  else
    assign products_list = collections.all.products
  endif

  assign card_border_w = '1px'
  unless section.settings.card_show_border
    assign card_border_w = '0px'
  endunless

  assign card_shadow_val = '0 4px 24px rgba(0,0,0,0.5)'
  unless section.settings.card_show_shadow
    assign card_shadow_val = 'none'
  endunless
-%}

<section
  id="lo-{{ sid }}"
  class="lo"
  aria-labelledby="lo-title-{{ sid }}"
  style="
    --lo-bg:             {{ bg_color }};
    --lo-card-bg:        {{ card_bg }};
    --lo-text:           {{ text_color }};
    --lo-title:          {{ title_color }};
    --lo-eyebrow:        {{ eyebrow_col }};
    --lo-subtitle-col:   {{ subtitle_col }};
    --lo-dot-active:     {{ dot_active }};
    --lo-dot-inactive:   {{ dot_inactive }};
    --lo-arrow-color:    {{ arrow_color }};
    --lo-title-size:     {{ title_size }}px;
    --lo-title-weight:   {{ title_weight }};
    --lo-eyebrow-size:   {{ eyebrow_size }}px;
    --lo-subtitle-size:  {{ subtitle_size }}px;
    --lo-img-ratio:      {{ img_ratio }};
    --lo-img-fit:        {{ img_fit }};
    --lo-card-radius:    {{ card_radius }}px;
    --lo-card-border-c:  {{ card_border_c }};
    --lo-card-border-w:  {{ card_border_w }};
    --lo-card-shadow:    {{ card_shadow_val }};
    --lo-name-color:     {{ card_name_col }};
    --lo-price-color:    {{ card_price_col }};
    --m19-card-discount-bg:  {{ discount_bg }};
    --m19-card-discount-txt: {{ discount_txt }};
    --lo-pt-m:           {{ pt_m }}px;
    --lo-pb-m:           {{ pb_m }}px;
    --lo-pt-d:           {{ pt_d }}px;
    --lo-pb-d:           {{ pb_d }}px;
    --lo-mt:             {{ mt }}px;
    --lo-mb:             {{ mb }}px;
    --lo-gap:            {{ gap_cards }}px;
    --lo-max-w:          {{ max_width }}px;
    --lo-arrow-size:     {{ arr_size }}px;
    --lo-arrow-radius:   {{ arr_radius }}px;
    --lo-dot-size:       {{ dot_size }}px;
    --lo-dot-gap:        {{ dot_gap_val }}px;
  "
>
  <div class="lo__inner">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="lo__header lo__header--{{ header_align }}">
      <div class="lo__header-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="lo__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="lo__title" id="lo-title-{{ sid }}">
          {{- section.settings.title | default: 'Opportunités Exceptionnelles à Saisir' -}}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="lo__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if show_cta and cta_url != blank -%}
        <a class="lo__cta" href="{{ cta_url }}">
          {{- cta_label -}}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} ── Swiper carousel ── {%- endcomment -%}
    <div class="lo__viewport-wrap">
      <div class="swiper lo__swiper" id="lo-swiper-{{ sid }}">
        <ul class="swiper-wrapper lo__track" role="list" aria-label="Offres limitées">
          {%- for product in products_list limit: max_products -%}
            {%- assign img1 = product.featured_image -%}
            {%- assign img2 = product.images[1] -%}
            <li class="swiper-slide lo__item">
              <article class="m19-card is-visible" aria-label="{{ product.title | escape }}">
                <a class="m19-card__media" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                  {%- if img1 != blank -%}
                    <img
                      class="m19-card__img m19-card__img--primary"
                      src="{{ img1 | image_url: width: 600 }}"
                      srcset="{{ img1 | image_url: width: 400 }} 400w, {{ img1 | image_url: width: 600 }} 600w, {{ img1 | image_url: width: 800 }} 800w"
                      sizes="(max-width:640px) calc((100vw - 48px) / 1.3), (max-width:1024px) calc((100vw - 76px) / 3.3), (max-width:1280px) calc((100vw - 96px) / 4.3), calc((100vw - 106px) / 5.3)"
                      alt="{{ img1.alt | default: product.title | escape }}"
                      loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}"
                      width="{{ img1.width }}"
                      height="{{ img1.height }}"
                    >
                    {%- if img2 != blank -%}
                      <img
                        class="m19-card__img m19-card__img--hover"
                        src="{{ img2 | image_url: width: 600 }}"
                        alt="{{ img2.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="{{ img2.width }}"
                        height="{{ img2.height }}"
                        aria-hidden="true"
                      >
                    {%- endif -%}
                  {%- else -%}
                    <div class="m19-card__media-fallback" aria-hidden="true"></div>
                  {%- endif -%}

                  {%- if show_badge and product.compare_at_price > product.price -%}
                    {%- assign lo_savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    <span class="m19-card__badge--discount" aria-label="Économie de {{ lo_savings }}%">-{{ lo_savings }}%</span>
                  {%- endif -%}

                  {%- if show_atc -%}
                    <button
                      class="m19-card__action"
                      type="button"
                      data-variant-id="{{ product.variants.first.id }}"
                      aria-label="Ajouter {{ product.title | escape }} au panier"
                    >
                      <svg class="m19-card__action-icon m19-card__action-icon--bag" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                      </svg>
                      <svg class="m19-card__action-icon m19-card__action-icon--check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </a>

                <div class="m19-card__body">
                  <a class="m19-card__name" href="{{ product.url }}">{{ product.title | truncate: 40 }}</a>
                  <div class="m19-card__pricing">
                    {%- if show_compare and product.compare_at_price > product.price -%}
                      <s class="m19-card__price--compare">{{ product.compare_at_price | money }}</s>
                    {%- endif -%}
                    <span class="m19-card__price">{{ product.price | money }}</span>
                  </div>
                </div>
              </article>
            </li>
          {%- else -%}
            <li class="lo__empty">Aucune offre disponible.</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ── Footer: dots LEFT, arrows RIGHT ── {%- endcomment -%}
    {%- if show_nav or show_arr -%}
      <div class="lo__footer">
        <div class="lo__footer-left">
          {%- if show_nav -%}
            <div class="lo__dots" id="lo-dots-{{ sid }}" role="tablist" aria-label="Position carousel">
              {%- assign dot_count = products_list | slice: 0, max_products | size -%}
              {%- for i in (1..dot_count) -%}
                <button
                  class="lo__dot{% if forloop.first %} lo__dot--active{% endif %}"
                  type="button"
                  role="tab"
                  aria-label="Page {{ forloop.index }}"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
        <div class="lo__footer-right">
          {%- if show_arr -%}
            <div class="lo__arrows">
              <button class="lo__arrow" id="lo-prev-{{ sid }}" aria-label="Offres précédentes" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="lo__arrow" id="lo-next-{{ sid }}" aria-label="Offres suivantes" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ═══════════════════════════════════════════════════
   Limited Offers — lo (Swiper) — dark bleu, full customisable
   mobile  ≤640px       → 1 + 0.3 partiel
   tablette 641-1024px  → 3 + 0.3 partiel
   moyen   1025-1280px  → 4 + 0.3 partiel
   grand   ≥1281px      → 6 + 0.3 partiel
   ═══════════════════════════════════════════════════ */

.lo {
  --lo-pad:      16px;
  --lo-ease:     cubic-bezier(0.4, 0, 0.2, 1);
  --lo-usable-w: min(100vw, var(--lo-max-w, 1400px));
  --lo-card-w:   calc((var(--lo-usable-w) - (2 * var(--lo-pad)) - (1 * var(--lo-gap, 14px))) / 1.3);

  background:    var(--lo-bg, #07090f);
  color:         var(--lo-text, #e8e8e8);
  margin-top:    var(--lo-mt, 0);
  margin-bottom: var(--lo-mb, 0);
  overflow-x:    clip;
  position:      relative;
}

.lo::before {
  content:  '';
  position: absolute;
  inset:    0;
  background:
    radial-gradient(ellipse 80% 60% at 15% 0%,   rgba(14, 42, 99, 0.55) 0%, transparent 65%),
    radial-gradient(ellipse 60% 50% at 85% 100%,  rgba(7,  24, 66, 0.45) 0%, transparent 60%),
    radial-gradient(ellipse 100% 100% at 50% 50%, rgba(3,  9,  28, 0.35) 0%, transparent 100%);
  pointer-events: none;
  z-index:        0;
}

.lo__inner { position: relative; z-index: 1; }

@media (min-width: 641px) {
  .lo {
    --lo-pad:    24px;
    --lo-card-w: calc((var(--lo-usable-w) - (2 * var(--lo-pad)) - (3 * var(--lo-gap, 14px))) / 3.3);
  }
}

@media (min-width: 1025px) {
  .lo {
    --lo-pad:    32px;
    --lo-card-w: calc((var(--lo-usable-w) - (2 * var(--lo-pad)) - (4 * var(--lo-gap, 14px))) / 4.3);
  }
}

@media (min-width: 1281px) {
  .lo {
    --lo-pad:    40px;
    --lo-card-w: calc((var(--lo-usable-w) - (2 * var(--lo-pad)) - (6 * var(--lo-gap, 14px))) / 6.3);
  }
}

/* ── Inner container ── */
.lo__inner {
  max-width: var(--lo-max-w, 1400px);
  margin: 0 auto;
  padding-top:    var(--lo-pt-m, 48px);
  padding-bottom: var(--lo-pb-m, 44px);
}
@media (min-width: 641px) {
  .lo__inner {
    padding-top:    var(--lo-pt-d, 64px);
    padding-bottom: var(--lo-pb-d, 52px);
  }
}

/* ── Header ── */
.lo__header {
  display:        flex;
  flex-direction: column;
  align-items:    flex-start;
  gap:            10px;
  padding:        0 var(--lo-pad) 28px;
}
.lo__header--center { align-items: center; text-align: center; }
.lo__header--right  { align-items: flex-end; text-align: right; }

@media (min-width: 641px) {
  .lo__header { flex-direction: row; align-items: flex-end; justify-content: space-between; }
  .lo__header--center { flex-direction: column; align-items: center; }
  .lo__header--right  { flex-direction: column; align-items: flex-end; }
}

.lo__header-text { display: flex; flex-direction: column; gap: 6px; }

.lo__eyebrow {
  font-size:      var(--lo-eyebrow-size, 11px);
  font-weight:    700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color:          var(--lo-eyebrow, #f59e0b);
}

.lo__title {
  font-family:    var(--font-body, 'Inter', sans-serif);
  font-size:      var(--lo-title-size, 32px);
  font-weight:    var(--lo-title-weight, 800);
  letter-spacing: -0.03em;
  color:          var(--lo-title, #ffffff);
  margin:         0;
  line-height:    1.1;
}

.lo__subtitle {
  font-size:   var(--lo-subtitle-size, 14px);
  color:       var(--lo-subtitle-col, #808080);
  margin:      0;
  max-width:   56ch;
  line-height: 1.6;
}

/* ── CTA "Voir tout" ── */
.lo__cta {
  display:         inline-flex;
  align-items:     center;
  gap:             5px;
  flex-shrink:     0;
  font-size:       0.8125rem;
  font-weight:     600;
  letter-spacing:  0.02em;
  color:           var(--lo-title, #ffffff);
  text-decoration: none;
  border:          1px solid rgba(255, 255, 255, 0.2);
  border-radius:   6px;
  padding:         7px 14px;
  transition:      background 180ms var(--lo-ease), border-color 180ms var(--lo-ease), color 180ms var(--lo-ease);
  white-space:     nowrap;
}
.lo__cta:hover {
  background:    rgba(255, 255, 255, 0.08);
  border-color:  rgba(255, 255, 255, 0.35);
}
.lo__cta svg { transition: transform 180ms var(--lo-ease); }
.lo__cta:hover svg { transform: translateX(2px); }

@media (max-width: 640px) {
  .lo__cta { display: none; }
}

/* ── Viewport wrap ── */
.lo__viewport-wrap {
  overflow:       hidden;
  padding-top:    8px;
  margin-top:     -8px;
  padding-bottom: 32px;
  margin-bottom:  -32px;
}

/* ── Swiper ── */
.lo__swiper {
  overflow: visible;
  padding:  20px var(--lo-pad) 28px;
}

.lo__swiper .lo__track {
  margin:     0;
  padding:    0;
  list-style: none;
  gap:        var(--lo-gap, 14px);
}

/* ── Slide ── */
.lo__swiper .lo__item {
  width:          var(--lo-card-w) !important;
  flex-shrink:    0;
  height:         auto;
  display:        flex;
  flex-direction: column;
}

/* ── Card dark mode overrides ── */
.lo__swiper .lo__item .m19-card {
  flex:          1;
  height:        100%;
  background:    var(--lo-card-bg, #1a1a1a);
  border-radius: var(--lo-card-radius, 8px);
  border-color:  var(--lo-card-border-c, #2d2d2d);
  border-width:  var(--lo-card-border-w, 1px);
  box-shadow:    var(--lo-card-shadow, 0 4px 24px rgba(0,0,0,0.5));
  transition:    transform 220ms var(--lo-ease), box-shadow 220ms var(--lo-ease);
}

.lo__swiper .lo__item .m19-card:hover {
  transform:  translateY(-2px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.65);
}

.lo__swiper .lo__item .m19-card__body {
  background: transparent;
}

.lo__swiper .lo__item .m19-card__media-fallback {
  background: #222;
}

/* Image */
.lo__swiper .lo__item .m19-card__media {
  aspect-ratio: var(--lo-img-ratio, 4 / 5);
}
.lo__swiper .lo__item .m19-card__img {
  object-fit: var(--lo-img-fit, contain);
}

/* Card name & price */
.lo__swiper .lo__item .m19-card__name  { color: var(--lo-name-color, #f0f0f0); }
.lo__swiper .lo__item .m19-card__price { color: var(--lo-price-color, #ffffff); }

.lo__swiper .lo__item .m19-card__price--compare {
  color:                rgba(255, 255, 255, 0.3);
  text-decoration-color: rgba(255, 255, 255, 0.3);
}

.lo__empty { padding: 24px; font-size: 0.875rem; color: #555; }

/* ── Footer ── */
.lo__footer {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  padding:         18px var(--lo-pad) 0;
  gap:             16px;
}

@media (max-width: 640px) {
  .lo__footer       { justify-content: center; }
  .lo__footer-right { display: none !important; }
  .lo__footer-left  { margin: 0 auto; }
}

.lo__footer-left  { display: flex; align-items: center; }
.lo__footer-right { display: flex; align-items: center; }

/* ── Arrows ── */
.lo__arrows { display: flex; gap: 4px; }
.lo__arrow {
  display:         flex;
  align-items:     center;
  justify-content: center;
  width:           var(--lo-arrow-size, 36px);
  height:          var(--lo-arrow-size, 36px);
  border-radius:   var(--lo-arrow-radius, 6px);
  border:          1px solid rgba(255, 255, 255, 0.12);
  background:      transparent;
  color:           var(--lo-arrow-color, #ffffff);
  cursor:          pointer;
  padding:         0;
  transition:      background 180ms var(--lo-ease), border-color 180ms var(--lo-ease);
}
.lo__arrow svg {
  width:   calc(var(--lo-arrow-size, 36px) * 0.45);
  height:  calc(var(--lo-arrow-size, 36px) * 0.45);
  display: block;
}
.lo__arrow:hover         { background: rgba(255, 255, 255, 0.1); border-color: rgba(255,255,255,0.25); }
.lo__arrow:disabled      { opacity: 0.25; cursor: default; pointer-events: none; }
.lo__arrow:focus-visible { outline: 2px solid var(--lo-eyebrow, #f59e0b); outline-offset: 2px; }

/* ── Dots ── */
.lo__dots { display: flex; align-items: center; gap: var(--lo-dot-gap, 8px); }

.lo__dot {
  width:        var(--lo-dot-size, 6px);
  height:       var(--lo-dot-size, 6px);
  padding:      0;
  border:       none;
  border-radius: 50%;
  background:   var(--lo-dot-inactive, #2d2d2d);
  cursor:       pointer;
  transition:   width 280ms var(--lo-ease), border-radius 280ms var(--lo-ease),
                background 280ms var(--lo-ease), transform 280ms ease, opacity 280ms ease;
}
.lo__dot--active { width: calc(var(--lo-dot-size, 6px) * 3.5); border-radius: 3px; background: var(--lo-dot-active, #ffffff); }
.lo__dot--small  { transform: scale(0.6); opacity: 0.5; }
.lo__dot--hidden { display: none; }
.lo__dot:focus-visible { outline: 2px solid var(--lo-eyebrow, #f59e0b); outline-offset: 2px; }

/* ── Masquer navigation Swiper native ── */
.lo__swiper .swiper-pagination,
.lo__swiper .swiper-button-next,
.lo__swiper .swiper-button-prev { display: none !important; }

{%- if section.settings.hide_on_mobile -%}
@media (max-width: 640px) { #lo-{{ sid }} { display: none !important; } }
{%- endif -%}
{%- if section.settings.hide_on_desktop -%}
@media (min-width: 641px) { #lo-{{ sid }} { display: none !important; } }
{%- endif -%}
{%- if section.settings.custom_css != blank -%}
{{ section.settings.custom_css }}
{%- endif -%}
</style>

<script>
(function () {
  'use strict';
  var sid         = '{{ sid }}';
  var autoplay    = {{ autoplay | json }};
  var apDelay     = {{ ap_delay }};
  var loopEnabled = {{ loop_enabled | json }};
  var speed       = {{ carousel_spd }};

  function init() {
    var section  = document.getElementById('lo-' + sid);
    if (!section || typeof Swiper === 'undefined') return;

    var swiperEl = document.getElementById('lo-swiper-' + sid);
    if (!swiperEl) return;

    var dotsWrap = document.getElementById('lo-dots-' + sid);
    var btnPrev  = document.getElementById('lo-prev-' + sid);
    var btnNext  = document.getElementById('lo-next-' + sid);
    var dots     = [];

    var swiperOpts = {
      slidesPerView: 'auto',
      spaceBetween:  0,
      loop:          loopEnabled,
      speed:         speed,
      grabCursor:    true
    };

    if (autoplay) {
      swiperOpts.autoplay = {
        delay:                apDelay,
        disableOnInteraction: true,
        pauseOnMouseEnter:    true
      };
    }

    var swiper = new Swiper(swiperEl, swiperOpts);

    /* ── Dots ── */
    dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.lo__dot')) : [];

    dots.forEach(function (btn, idx) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        swiper.slideToLoop(idx);
      });
    });

    function updateDots() {
      if (!dots.length) return;
      var maxV = 5;
      var idx  = swiper.realIndex;
      dots.forEach(function (d, i) {
        var active = i === idx;
        d.className = 'lo__dot' + (active ? ' lo__dot--active' : '');
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      if (dots.length > maxV) {
        var half  = Math.floor(maxV / 2);
        var start = Math.max(0, idx - half);
        var end   = Math.min(dots.length, start + maxV);
        if (end - start < maxV) start = Math.max(0, end - maxV);
        dots.forEach(function (d, i) {
          if (i < start || i >= end) {
            if (i === start - 1 || i === end) d.classList.add('lo__dot--small');
            else d.classList.add('lo__dot--hidden');
          }
        });
      }
    }

    swiper.on('slideChange', updateDots);
    updateDots();

    /* ── Arrows ── */
    if (btnPrev) btnPrev.addEventListener('click', function (e) { e.preventDefault(); swiper.slidePrev(); });
    if (btnNext) btnNext.addEventListener('click', function (e) { e.preventDefault(); swiper.slideNext(); });

    /* ── ATC ── */
    section.addEventListener('click', function (e) {
      var btn = e.target.closest('.m19-card__action');
      if (!btn || btn.disabled) return;
      e.preventDefault();
      e.stopPropagation();
      var id = btn.dataset.variantId;
      if (!id) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body:    JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.status) { btn.disabled = false; return; }
          btn.classList.add('is-added');
          var counter = document.querySelector('[data-cart-count]');
          if (counter) fetch('/cart.js').then(function (r) { return r.json(); }).then(function (c) { counter.textContent = c.item_count; });
          setTimeout(function () { btn.classList.remove('is-added'); btn.disabled = false; }, 2200);
        })
        .catch(function () { btn.disabled = false; });
    });
  }

  function safeInit() {
    if (typeof Swiper !== 'undefined') { init(); return; }
    var interval = setInterval(function () {
      if (typeof Swiper !== 'undefined') { clearInterval(interval); init(); }
    }, 50);
    setTimeout(function () { clearInterval(interval); }, 5000);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', safeInit);
  else safeInit();
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sid) safeInit();
  });
})();
</script>

{% schema %}
{
  "name": "Offres Limitées",
  "tag": "section",
  "class": "section-limited-offers",
  "settings": [
    { "type": "header", "content": "Contenu" },
    { "type": "text",     "id": "eyebrow",   "label": "Label eyebrow",  "default": "Offres Limitées" },
    { "type": "text",     "id": "title",     "label": "Titre",          "default": "Opportunités Exceptionnelles à Saisir" },
    { "type": "textarea", "id": "subtitle",  "label": "Sous-titre",     "default": "Des prix rares sur des pièces soigneusement sélectionnées. Ne laissez pas passer votre prochaine trouvaille." },

    { "type": "header",   "content": "Lien \"Voir tout\"" },
    { "type": "checkbox", "id": "show_view_all",  "label": "Afficher le bouton \"Voir tout\"", "default": true },
    { "type": "text",     "id": "view_all_label", "label": "Libellé", "default": "Voir tout" },
    { "type": "url",      "id": "view_all_url",   "label": "URL cible" },

    { "type": "header", "content": "Produits" },
    { "type": "collection", "id": "collection",   "label": "Collection source", "info": "Vide = toutes les collections" },
    { "type": "range",      "id": "max_products", "label": "Nombre de produits", "min": 4, "max": 24, "step": 2, "default": 12 },
    { "type": "checkbox",   "id": "show_discount_badge", "label": "Afficher les badges de réduction", "default": true },
    { "type": "checkbox",   "id": "show_compare_price",  "label": "Afficher les prix barrés",          "default": true },
    { "type": "checkbox",   "id": "show_atc",             "label": "Bouton ajouter au panier",          "default": true },

    { "type": "header", "content": "Carousel" },
    { "type": "checkbox", "id": "loop_enabled",     "label": "Boucle infinie",      "default": true },
    { "type": "checkbox", "id": "autoplay_enabled", "label": "Autoplay",            "default": false },
    { "type": "range",    "id": "autoplay_delay",   "label": "Délai autoplay (ms)", "min": 2000, "max": 9000, "step": 500,  "default": 4000 },
    { "type": "range",    "id": "carousel_speed",   "label": "Vitesse animation (ms)", "min": 100, "max": 1500, "step": 50, "default": 500 },

    { "type": "header", "content": "Navigation" },
    { "type": "checkbox", "id": "show_arrows",        "label": "Flèches",             "default": true },
    { "type": "checkbox", "id": "show_dots",          "label": "Dots",                "default": true },
    { "type": "range",    "id": "arrow_size",         "label": "Taille flèches (px)", "min": 28, "max": 64, "step": 2, "default": 36 },
    { "type": "range",    "id": "arrow_border_radius","label": "Rayon flèches (px)",  "min": 0,  "max": 32, "step": 1, "default": 6 },
    { "type": "range",    "id": "dot_size",           "label": "Taille dots (px)",    "min": 4,  "max": 14, "step": 1, "default": 6 },
    { "type": "range",    "id": "dot_gap",            "label": "Espacement dots (px)","min": 4,  "max": 20, "step": 1, "default": 8 },

    { "type": "header", "content": "Carte produit" },
    {
      "type": "select", "id": "image_ratio", "label": "Proportion image", "default": "4 / 5",
      "options": [
        { "value": "1 / 1",  "label": "Carré (1:1)" },
        { "value": "4 / 5",  "label": "Portrait (4:5)" },
        { "value": "3 / 4",  "label": "Haut (3:4)" },
        { "value": "16 / 9", "label": "Large (16:9)" }
      ]
    },
    {
      "type": "select", "id": "image_fit", "label": "Recadrage image", "default": "contain",
      "options": [
        { "value": "contain", "label": "Contenir" },
        { "value": "cover",   "label": "Couvrir" }
      ]
    },
    { "type": "range",    "id": "card_border_radius", "label": "Rayon bordure carte (px)", "min": 0,  "max": 32, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "card_show_border",   "label": "Bordure carte",            "default": true },
    { "type": "color",    "id": "card_border_color",  "label": "Couleur bordure carte",    "default": "#2d2d2d" },
    { "type": "checkbox", "id": "card_show_shadow",   "label": "Ombre carte",              "default": true },
    { "type": "color",    "id": "card_name_color",    "label": "Couleur nom produit",      "default": "#f0f0f0" },
    { "type": "color",    "id": "card_price_color",   "label": "Couleur prix",             "default": "#ffffff" },

    { "type": "header", "content": "Couleurs — Section" },
    { "type": "color", "id": "bg_color",      "label": "Fond section",    "default": "#0d0d0d" },
    { "type": "color", "id": "card_bg",       "label": "Fond cartes",     "default": "#1a1a1a" },
    { "type": "color", "id": "text_color",    "label": "Texte général",   "default": "#e8e8e8" },
    { "type": "color", "id": "title_color",   "label": "Couleur titre",   "default": "#ffffff" },
    { "type": "color", "id": "subtitle_color","label": "Couleur sous-titre", "default": "#808080" },
    { "type": "color", "id": "eyebrow_color", "label": "Couleur eyebrow", "default": "#0787ea" },

    { "type": "header", "content": "Couleurs — Badges" },
    { "type": "color", "id": "discount_badge_bg",   "label": "Fond badge réduction",  "default": "#e63946" },
    { "type": "color", "id": "discount_badge_text", "label": "Texte badge réduction", "default": "#ffffff" },

