          "default": "✅",
          "info": "Copiez-collez un emoji : ✅ 🔒 🚚 ↩️ 🛡️ ⭐"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte du badge",
          "default": "Commande 100% sécurisée"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page Panier",
      "blocks": [
        { "type": "badge", "settings": { "icon": "🔒", "text": "Commande 100% sécurisée" } },
        { "type": "badge", "settings": { "icon": "🚚", "text": "Livraison rapide disponible" } }
      ]
    }
  ]
}
