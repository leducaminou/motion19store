    { "type": "text", "id": "name_label",     "label": "Label Nom complet", "default": "Nom complet" },
    { "type": "text", "id": "city_label",     "label": "Label Ville",       "default": "Ville" },
    { "type": "text", "id": "phone_label",    "label": "Label Téléphone",   "default": "Numéro de téléphone" },

    { "type": "header", "content": "━━ Couleurs" },
