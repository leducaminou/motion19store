    { "type": "color", "id": "page_bg",       "label": "Fond de la page",            "default": "#ffffff" },
    { "type": "color", "id": "card_bg",       "label": "Fond des blocs",             "default": "#f8f8f8" },
    { "type": "color", "id": "border_color",  "label": "Bordures",                   "default": "#e5e5e7" },
