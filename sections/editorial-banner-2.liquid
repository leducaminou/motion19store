    { "type": "header", "content": "── 1. Layout général" },
    {
      "type": "select", "id": "layout_desktop", "label": "Disposition desktop", "default": "content-left",
      "options": [
        { "value": "content-left",  "label": "Texte gauche / Image droite" },
        { "value": "content-right", "label": "Image gauche / Texte droite" }
      ]
    },
    {
      "type": "select", "id": "layout_mobile", "label": "Disposition mobile", "default": "content-top",
      "options": [
        { "value": "content-top", "label": "Texte en haut" },
        { "value": "image-top",   "label": "Image en haut" }
      ]
    },
    {
      "type": "select", "id": "col_split", "label": "Répartition colonnes (desktop)", "default": "50-50",
      "options": [
        { "value": "50-50", "label": "50 / 50" },
        { "value": "55-45", "label": "55 / 45" },
        { "value": "45-55", "label": "45 / 55" },
        { "value": "60-40", "label": "60 / 40" },
        { "value": "40-60", "label": "40 / 60" }
      ]
    },
    {
      "type": "select", "id": "section_height", "label": "Hauteur section", "default": "large",
      "options": [
        { "value": "small",  "label": "Petite (~60vh)" },
        { "value": "medium", "label": "Moyenne (~72vh)" },
        { "value": "large",  "label": "Grande (~80vh)" },
        { "value": "custom", "label": "Personnalisée" }
      ]
    },
    { "type": "range", "id": "height_desktop",    "label": "Hauteur personnalisée (px)", "min": 400, "max": 1200, "step": 10, "default": 720, "unit": "px" },
    { "type": "range", "id": "img_height_mobile", "label": "Hauteur image mobile (px)",  "min": 200, "max": 700,  "step": 10, "default": 380, "unit": "px" },
    { "type": "range", "id": "col_gap",           "label": "Espace entre colonnes (px)", "min": 0, "max": 80, "step": 4, "default": 0, "unit": "px" },

    { "type": "header", "content": "── 2. Fond & Effets section" },
    { "type": "color",    "id": "container_bg",       "label": "Couleur de fond",                  "default": "#0a0a0a" },
    { "type": "checkbox", "id": "show_dots_texture",   "label": "Texture pointillée",               "default": true },
    { "type": "checkbox", "id": "show_halo",           "label": "Halo lumineux",                    "default": true },
    { "type": "color",    "id": "halo_color",          "label": "Couleur du halo",                  "default": "#0787ea" },
    { "type": "range",    "id": "halo_intensity",      "label": "Intensité halo (%)",               "min": 2, "max": 40, "step": 1, "default": 12 },
    { "type": "checkbox", "id": "show_grain",          "label": "Effet grain / noise",              "default": false },
    { "type": "range",    "id": "grain_opacity",       "label": "Opacité grain (%)",                "min": 1, "max": 15, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "enable_large_float",  "label": "Flotter sur grand écran (1500px+)","default": true },
    { "type": "range",    "id": "large_screen_margin", "label": "Marge côtés grand écran (px)",     "min": 8, "max": 120, "step": 4, "default": 40, "unit": "px" },
    { "type": "range",    "id": "large_screen_radius", "label": "Border-radius grand écran (px)",   "min": 0, "max": 48,  "step": 2, "default": 16, "unit": "px" },

    { "type": "header", "content": "── 3. Colonne texte" },
    {
      "type": "select", "id": "text_align", "label": "Alignement texte", "default": "left",
      "options": [
        { "value": "left",   "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Droite" }
      ]
    },
    { "type": "range",    "id": "content_max_width",    "label": "Largeur max contenu (px)",    "min": 280, "max": 800, "step": 10, "default": 520, "unit": "px" },
    { "type": "range",    "id": "content_gap",          "label": "Espace entre éléments (px)",  "min": 8, "max": 56, "step": 2, "default": 20, "unit": "px" },
    { "type": "checkbox", "id": "content_glass",        "label": "Effet glass sur le contenu",  "default": false },
    { "type": "range",    "id": "content_backdrop_blur","label": "Backdrop blur contenu (px)",  "min": 0, "max": 40, "step": 2, "default": 0, "unit": "px" },
    { "type": "range",    "id": "content_bg_overlay",   "label": "Opacité fond contenu (%)",    "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range",    "id": "content_radius",       "label": "Border-radius contenu (px)",  "min": 0, "max": 32, "step": 2, "default": 0, "unit": "px" },

    { "type": "header", "content": "── 4. Badge" },
    { "type": "text",  "id": "badge_text",  "label": "Texte badge / eyebrow" },
    {
      "type": "select", "id": "badge_style", "label": "Style badge", "default": "line",
      "options": [
        { "value": "line",     "label": "Ligne (défaut)" },
        { "value": "filled",   "label": "Filled" },
        { "value": "outline",  "label": "Outline" },
        { "value": "ghost",    "label": "Ghost" },
        { "value": "glass",    "label": "Glass" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    { "type": "color", "id": "badge_color",  "label": "Couleur badge",          "default": "#0787ea" },
    { "type": "color", "id": "badge_bg",     "label": "Fond badge (filled)" },
    { "type": "color", "id": "badge_border", "label": "Bordure badge (outline)" },
    { "type": "range", "id": "badge_fs",     "label": "Taille police (px)",     "min": 8,  "max": 18, "step": 1,  "default": 11, "unit": "px" },
    {
      "type": "select", "id": "badge_fw", "label": "Graisse", "default": "600",
      "options": [
        { "value": "400", "label": "Regular" }, { "value": "500", "label": "Medium" },
        { "value": "600", "label": "SemiBold" }, { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "range", "id": "badge_ls",     "label": "Letter-spacing (×0.01em)", "min": 0, "max": 40, "step": 1, "default": 18 },
    { "type": "range", "id": "badge_radius", "label": "Border-radius (px)",        "min": 0, "max": 20, "step": 1, "default": 4, "unit": "px" },
    { "type": "range", "id": "badge_py",     "label": "Padding vertical (px)",     "min": 2, "max": 16, "step": 1, "default": 4, "unit": "px" },
    { "type": "range", "id": "badge_px",     "label": "Padding horizontal (px)",   "min": 4, "max": 32, "step": 2, "default": 10, "unit": "px" },

    { "type": "header", "content": "── 5. Titre" },
    { "type": "text",  "id": "heading",           "label": "Titre",           "default": "Une expérience visuelle unique." },
    { "type": "color", "id": "heading_color",     "label": "Couleur titre",   "default": "#f5f5f7" },
    { "type": "range", "id": "heading_sz_desktop","label": "Taille desktop (px)", "min": 24, "max": 96, "step": 2, "default": 48, "unit": "px" },
    { "type": "range", "id": "heading_sz_tablet", "label": "Taille tablet (px)",  "min": 20, "max": 72, "step": 2, "default": 36, "unit": "px" },
    { "type": "range", "id": "heading_sz_mobile", "label": "Taille mobile (px)",  "min": 18, "max": 56, "step": 2, "default": 28, "unit": "px" },
    {
      "type": "select", "id": "heading_fw", "label": "Graisse", "default": "700",
      "options": [
        { "value": "300", "label": "Light 300" }, { "value": "400", "label": "Regular 400" },
        { "value": "600", "label": "SemiBold 600" }, { "value": "700", "label": "Bold 700" },
        { "value": "800", "label": "ExtraBold 800" }
      ]
    },
    {
      "type": "select", "id": "heading_lh", "label": "Interligne", "default": "1.05",
      "options": [
        { "value": "0.95", "label": "Très serré" }, { "value": "1.0", "label": "Serré" },
        { "value": "1.05", "label": "Compact" }, { "value": "1.15", "label": "Normal" },
        { "value": "1.3",  "label": "Aéré" }
      ]
    },
    {
      "type": "select", "id": "heading_ls", "label": "Letter-spacing", "default": "-0.03",
      "options": [
        { "value": "-0.04", "label": "-0.04em" }, { "value": "-0.03", "label": "-0.03em" },
        { "value": "-0.02", "label": "-0.02em" }, { "value": "0",     "label": "0" }
      ]
    },
    { "type": "checkbox", "id": "heading_gradient",  "label": "Titre en dégradé",      "default": false },
    { "type": "color",    "id": "heading_grad_from", "label": "Couleur dégradé départ", "default": "#ffffff" },
    { "type": "color",    "id": "heading_grad_to",   "label": "Couleur dégradé fin",    "default": "#0787ea" },

    { "type": "header", "content": "── 6. Description" },
    { "type": "richtext","id": "richtext",        "label": "Description", "default": "<p>Découvrez notre sélection premium. Des produits pensés pour les exigeants, fabriqués pour durer.</p>" },
    { "type": "color",  "id": "body_color",       "label": "Couleur texte",       "default": "#999999" },
    { "type": "range",  "id": "body_fs_desktop",  "label": "Taille desktop (px)", "min": 12, "max": 24, "step": 1, "default": 16, "unit": "px" },
    { "type": "range",  "id": "body_fs_mobile",   "label": "Taille mobile (px)",  "min": 12, "max": 20, "step": 1, "default": 14, "unit": "px" },
    {
      "type": "select", "id": "body_fw", "label": "Graisse", "default": "400",
      "options": [
        { "value": "300", "label": "Light" }, { "value": "400", "label": "Regular" }, { "value": "500", "label": "Medium" }
      ]
    },
    {
      "type": "select", "id": "body_lh", "label": "Interligne", "default": "1.72",
      "options": [
        { "value": "1.4", "label": "Compact" }, { "value": "1.55", "label": "Normal" },
        { "value": "1.72", "label": "Aéré" }, { "value": "1.9", "label": "Très aéré" }
      ]
    },
    { "type": "range", "id": "body_max_width", "label": "Largeur max (ch)", "min": 20, "max": 80, "step": 2, "default": 46 },

    { "type": "header", "content": "── 7. Bouton principal" },
    { "type": "text",     "id": "cta1_label",       "label": "Texte",             "default": "Découvrir" },
    { "type": "url",      "id": "cta1_url",         "label": "Lien" },
    { "type": "checkbox", "id": "cta1_new_tab",     "label": "Ouvrir dans nouvel onglet", "default": false },
    {
      "type": "select", "id": "cta1_style", "label": "Style", "default": "solid",
      "options": [
        { "value": "solid",         "label": "Solid blanc" },
        { "value": "primary",       "label": "Primary" },
        { "value": "outline-white", "label": "Outline blanc" },
        { "value": "ghost",         "label": "Ghost" },
        { "value": "dark",          "label": "Dark" },
        { "value": "gradient",      "label": "Gradient" },
        { "value": "glass",         "label": "Glass" },
        { "value": "neon",          "label": "Neon" },
        { "value": "minimal",       "label": "Minimal" },
        { "value": "pill",          "label": "Pill" },
        { "value": "luxury",        "label": "Luxury" }
      ]
    },
    { "type": "color",    "id": "cta1_bg",          "label": "Fond (override)" },
    { "type": "color",    "id": "cta1_color",       "label": "Texte (override)" },
    { "type": "color",    "id": "cta1_hover_bg",    "label": "Fond hover (override)" },
    { "type": "checkbox", "id": "cta1_hover_scale", "label": "Scale au hover",  "default": false },
    { "type": "checkbox", "id": "cta1_hover_glow",  "label": "Glow au hover",   "default": false },

    { "type": "header", "content": "── 8. Bouton secondaire" },
    { "type": "text",     "id": "cta2_label",    "label": "Texte (optionnel)" },
    { "type": "url",      "id": "cta2_url",      "label": "Lien" },
    { "type": "checkbox", "id": "cta2_new_tab",  "label": "Ouvrir dans nouvel onglet", "default": false },
    {
      "type": "select", "id": "cta2_style", "label": "Style", "default": "ghost",
      "options": [
        { "value": "solid",         "label": "Solid blanc" },
        { "value": "primary",       "label": "Primary" },
        { "value": "outline-white", "label": "Outline blanc" },
        { "value": "ghost",         "label": "Ghost" },
        { "value": "dark",          "label": "Dark" },
        { "value": "gradient",      "label": "Gradient" },
        { "value": "glass",         "label": "Glass" },
        { "value": "neon",          "label": "Neon" },
        { "value": "minimal",       "label": "Minimal" },
        { "value": "pill",          "label": "Pill" },
        { "value": "luxury",        "label": "Luxury" }
      ]
    },
    { "type": "color", "id": "cta2_bg",       "label": "Fond (override)" },
    { "type": "color", "id": "cta2_color",    "label": "Texte (override)" },
    { "type": "color", "id": "cta2_hover_bg", "label": "Fond hover (override)" },

    { "type": "header", "content": "── 9. Boutons — style commun" },
    { "type": "range",    "id": "cta1_radius",  "label": "Border-radius (px)",       "min": 0, "max": 40, "step": 1, "default": 2, "unit": "px" },
    { "type": "range",    "id": "btn_py",        "label": "Padding vertical (px)",    "min": 6, "max": 32, "step": 1, "default": 14, "unit": "px" },
    { "type": "range",    "id": "btn_px",        "label": "Padding horizontal (px)",  "min": 10,"max": 60, "step": 2, "default": 26, "unit": "px" },
    { "type": "range",    "id": "btn_fs",        "label": "Taille police (px)",       "min": 11, "max": 18, "step": 1, "default": 13, "unit": "px" },
    {
      "type": "select", "id": "btn_fw", "label": "Graisse", "default": "600",
      "options": [
        { "value": "400", "label": "Regular" }, { "value": "500", "label": "Medium" },
        { "value": "600", "label": "SemiBold" }, { "value": "700", "label": "Bold" }
      ]
    },
    { "type": "range",    "id": "btn_ls",        "label": "Letter-spacing (×0.01em)","min": 0, "max": 20, "step": 1, "default": 2 },
    { "type": "range",    "id": "ctas_gap",      "label": "Espace entre boutons (px)","min": 4, "max": 40, "step": 2, "default": 10, "unit": "px" },
    { "type": "checkbox", "id": "cta_fw_mobile", "label": "Pleine largeur mobile",   "default": true },

    { "type": "header", "content": "── 10. Images" },
    { "type": "image_picker", "id": "img_desktop", "label": "Image desktop" },
    { "type": "image_picker", "id": "img_tablet",  "label": "Image tablet (optionnel — fallback desktop)" },
    { "type": "image_picker", "id": "img_mobile",  "label": "Image mobile (optionnel — fallback desktop)" },
    {
      "type": "select", "id": "img_style", "label": "Style image", "default": "normal",
      "options": [
        { "value": "normal",        "label": "Normal" },
        { "value": "rounded",       "label": "Arrondi" },
        { "value": "floating",      "label": "Floating" },
        { "value": "framed",        "label": "Encadré" },
