    { "type": "range", "id": "img_scale",      "label": "Échelle image (%)", "min": 80, "max": 120, "step": 1,  "default": 100 },

    { "type": "header", "content": "── 12. Colonne image — style" },
    { "type": "color",    "id": "media_bg",          "label": "Fond colonne image",     "default": "#111111" },
    { "type": "range",    "id": "media_radius",       "label": "Border-radius (px)",     "min": 0, "max": 32, "step": 2, "default": 0, "unit": "px" },
    { "type": "checkbox", "id": "show_vignette",      "label": "Vignette",               "default": true },
    { "type": "range",    "id": "vignette_intensity", "label": "Intensité vignette (%)", "min": 0, "max": 60, "step": 5, "default": 20 },
    { "type": "checkbox", "id": "enable_hover_zoom",  "label": "Zoom survol section",    "default": true },
    {
