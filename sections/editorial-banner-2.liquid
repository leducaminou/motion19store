{%- comment -%}Editorial Banner 2 — Motion19 — v5.0 — namespace ebn2{%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign layout_desktop = section.settings.layout_desktop    | default: 'content-left'
  assign layout_mobile  = section.settings.layout_mobile     | default: 'content-top'
  assign col_split      = section.settings.col_split         | default: '50-50'
  assign section_height = section.settings.section_height    | default: 'large'
  assign h_desk         = section.settings.height_desktop    | default: 720
  assign img_height_mob = section.settings.img_height_mobile | default: 380

  assign container_bg   = section.settings.container_bg      | default: '#0a0a0a'
  assign ph_desk        = section.settings.ph_desktop        | default: 80
  assign ph_tab         = section.settings.ph_tablet         | default: 48
  assign ph_mob         = section.settings.ph_mobile         | default: 24
  assign show_dots      = section.settings.show_dots_texture
  assign show_halo      = section.settings.show_halo
  assign halo_color     = section.settings.halo_color        | default: '#0787ea'
  assign halo_intensity = section.settings.halo_intensity    | default: 12
  assign show_grain     = section.settings.show_grain
  assign grain_opacity  = section.settings.grain_opacity     | default: 3

  assign badge_text     = section.settings.badge_text
  assign badge_style    = section.settings.badge_style       | default: 'line'
  assign badge_color    = section.settings.badge_color       | default: '#0787ea'
  assign badge_bg       = section.settings.badge_bg
  assign badge_border   = section.settings.badge_border
  assign badge_fs       = section.settings.badge_fs          | default: 11
  assign badge_fw       = section.settings.badge_fw          | default: '600'
  assign badge_ls       = section.settings.badge_ls          | default: 18
  assign badge_radius   = section.settings.badge_radius      | default: 4
  assign badge_py       = section.settings.badge_py          | default: 4
  assign badge_px       = section.settings.badge_px          | default: 10

  assign heading        = section.settings.heading
  assign richtext       = section.settings.richtext
  assign content_mw     = section.settings.content_max_width | default: 520
  assign text_align     = section.settings.text_align        | default: 'left'
  assign content_gap    = section.settings.content_gap       | default: 20
  assign content_glass  = section.settings.content_glass     | default: false
  assign content_blur   = section.settings.content_backdrop_blur | default: 0
  assign content_bg_ov  = section.settings.content_bg_overlay | default: 0
  assign content_radius = section.settings.content_radius    | default: 0

  assign heading_color  = section.settings.heading_color     | default: '#f5f5f7'
  assign body_color     = section.settings.body_color        | default: 'rgba(245,245,247,0.65)'
  assign heading_fw     = section.settings.heading_fw        | default: '700'
  assign heading_lh     = section.settings.heading_lh        | default: '1.05'
  assign heading_ls     = section.settings.heading_ls        | default: '-0.03'
  assign heading_sz_d   = section.settings.heading_sz_desktop | default: 48
  assign heading_sz_t   = section.settings.heading_sz_tablet  | default: 36
  assign heading_sz_m   = section.settings.heading_sz_mobile  | default: 28
  assign heading_gradient = section.settings.heading_gradient | default: false
  assign heading_grad_from = section.settings.heading_grad_from | default: '#ffffff'
  assign heading_grad_to   = section.settings.heading_grad_to   | default: '#0787ea'

  assign body_fs_d      = section.settings.body_fs_desktop   | default: 16
  assign body_fs_m      = section.settings.body_fs_mobile    | default: 14
  assign body_fw        = section.settings.body_fw           | default: '400'
  assign body_lh        = section.settings.body_lh           | default: '1.72'
  assign body_mw        = section.settings.body_max_width    | default: 46

  assign cta1_label     = section.settings.cta1_label
  assign cta1_url       = section.settings.cta1_url          | default: '#'
  assign cta1_new_tab   = section.settings.cta1_new_tab      | default: false
  assign cta1_style     = section.settings.cta1_style        | default: 'solid'
  assign cta1_radius    = section.settings.cta1_radius       | default: 2
  assign cta1_bg        = section.settings.cta1_bg
  assign cta1_color     = section.settings.cta1_color
  assign cta1_hover_bg  = section.settings.cta1_hover_bg
  assign cta1_hover_scale = section.settings.cta1_hover_scale | default: false
  assign cta1_hover_glow  = section.settings.cta1_hover_glow  | default: false

  assign cta2_label     = section.settings.cta2_label
  assign cta2_url       = section.settings.cta2_url          | default: '#'
  assign cta2_new_tab   = section.settings.cta2_new_tab      | default: false
  assign cta2_style     = section.settings.cta2_style        | default: 'ghost'
  assign cta2_bg        = section.settings.cta2_bg
  assign cta2_color     = section.settings.cta2_color
  assign cta2_hover_bg  = section.settings.cta2_hover_bg

  assign cta_fw_mobile  = section.settings.cta_fw_mobile     | default: true
  assign ctas_gap       = section.settings.ctas_gap          | default: 10
  assign btn_py         = section.settings.btn_py            | default: 14
  assign btn_px         = section.settings.btn_px            | default: 26
  assign btn_fs         = section.settings.btn_fs            | default: 13
  assign btn_fw         = section.settings.btn_fw            | default: '600'
  assign btn_ls         = section.settings.btn_ls            | default: 2

  assign img_desktop    = section.settings.img_desktop
  assign img_tablet     = section.settings.img_tablet
  assign img_mobile     = section.settings.img_mobile
  assign img_fit        = section.settings.img_fit           | default: 'cover'
  assign img_fit_mob    = section.settings.img_fit_mobile    | default: 'contain'
  assign img_focal      = section.settings.img_focal         | default: 'center center'
  assign img_loading    = section.settings.img_loading       | default: 'lazy'
  assign hide_img_mob   = section.settings.hide_img_mobile   | default: false
  assign img_style      = section.settings.img_style         | default: 'normal'
  assign img_opacity    = section.settings.img_opacity       | default: 100
  assign img_brightness = section.settings.img_brightness    | default: 100
  assign img_contrast   = section.settings.img_contrast      | default: 100
  assign img_blur_fx    = section.settings.img_blur_effect   | default: 0
  assign img_scale      = section.settings.img_scale         | default: 100

  assign media_bg       = section.settings.media_bg          | default: '#111111'
  assign media_r        = section.settings.media_radius      | default: 0
  assign enable_zoom    = section.settings.enable_hover_zoom
  assign zoom_scale     = section.settings.zoom_scale        | default: '1.04'
  assign show_vignette  = section.settings.show_vignette
  assign vignette_intensity = section.settings.vignette_intensity | default: 20

  assign overlay_color  = section.settings.overlay_color
  assign overlay_op     = section.settings.overlay_opacity   | default: 0 | divided_by: 100.0

  assign pt_mob         = section.settings.pt_mobile         | default: 56
  assign pb_mob         = section.settings.pb_mobile         | default: 56
  assign pt_desk        = section.settings.pt_desktop        | default: 80
  assign pb_desk        = section.settings.pb_desktop        | default: 80
  assign mt             = section.settings.margin_top        | default: 0
  assign mb             = section.settings.margin_bottom     | default: 0
  assign col_gap        = section.settings.col_gap           | default: 0

  assign enable_float   = section.settings.enable_large_float
  assign large_margin   = section.settings.large_screen_margin | default: 40
  assign large_radius   = section.settings.large_screen_radius | default: 16

  assign anim_enable    = section.settings.anim_enable       | default: true
  assign anim_type      = section.settings.anim_type         | default: 'fade-up'
  assign anim_delay     = section.settings.anim_delay        | default: 0
  assign anim_stagger   = section.settings.anim_stagger      | default: true
  assign anim_img_type  = section.settings.anim_image_type   | default: 'none'
  assign anim_dis_mob   = section.settings.anim_disable_mobile | default: false
  assign custom_id      = section.settings.custom_id
  assign custom_classes = section.settings.custom_classes
  assign custom_css     = section.settings.custom_css

  assign ov_r = 0
  assign ov_g = 0
  assign ov_b = 0
  if overlay_color != blank
    assign ov_r = overlay_color.red
    assign ov_g = overlay_color.green
    assign ov_b = overlay_color.blue
  endif

  assign halo_r = 7
  assign halo_g = 135
  assign halo_b = 234
  if halo_color != blank
    assign halo_r = halo_color.red
    assign halo_g = halo_color.green
    assign halo_b = halo_color.blue
  endif

  if img_desktop != blank
    assign img_url_d    = img_desktop | image_url: width: 1400
    assign img_url_d_2x = img_desktop | image_url: width: 2000
  else
    assign img_url_d    = 'hp-cta-2.jpg' | asset_url
    assign img_url_d_2x = img_url_d
  endif

  if img_tablet != blank
    assign img_url_t = img_tablet | image_url: width: 1000
  elsif img_desktop != blank
    assign img_url_t = img_desktop | image_url: width: 1000
  else
    assign img_url_t = img_url_d
  endif

  if img_mobile != blank
    assign img_url_m = img_mobile | image_url: width: 800
  elsif img_desktop != blank
    assign img_url_m = img_desktop | image_url: width: 800
  else
    assign img_url_m = 'hp-cta-2.jpg' | asset_url
  endif

  assign img_filter = 'opacity(' | append: img_opacity | append: '%) brightness(' | append: img_brightness | append: '%) contrast(' | append: img_contrast | append: '%)'
  if img_blur_fx > 0
    assign img_filter = img_filter | append: ' blur(' | append: img_blur_fx | append: 'px)'
  endif

  assign img_scale_val = img_scale | divided_by: 100.0

  assign sec_cls = 'ebn2 ebn2--layout-' | append: layout_desktop
  assign sec_cls = sec_cls | append: ' ebn2--mob-' | append: layout_mobile
  assign sec_cls = sec_cls | append: ' ebn2--split-' | append: col_split
  assign sec_cls = sec_cls | append: ' ebn2--h-' | append: section_height
  assign sec_cls = sec_cls | append: ' ebn2--img-' | append: img_style
  unless show_dots
    assign sec_cls = sec_cls | append: ' ebn2--no-dots'
  endunless
  unless show_halo
    assign sec_cls = sec_cls | append: ' ebn2--no-halo'
  endunless
  unless show_vignette
    assign sec_cls = sec_cls | append: ' ebn2--no-vignette'
  endunless
  if show_grain
    assign sec_cls = sec_cls | append: ' ebn2--grain'
  endif
  if enable_zoom
    assign sec_cls = sec_cls | append: ' ebn2--zoom'
  endif
  if enable_float
    assign sec_cls = sec_cls | append: ' ebn2--float'
  endif
  if hide_img_mob
    assign sec_cls = sec_cls | append: ' ebn2--hide-img-mob'
  endif
  if content_glass
    assign sec_cls = sec_cls | append: ' ebn2--glass-content'
  endif
  if heading_gradient
    assign sec_cls = sec_cls | append: ' ebn2--title-gradient'
  endif
  if cta1_hover_scale
    assign sec_cls = sec_cls | append: ' ebn2--btn1-scale'
  endif
  if cta1_hover_glow
    assign sec_cls = sec_cls | append: ' ebn2--btn1-glow'
  endif
  if anim_enable and anim_type != 'none'
    assign sec_cls = sec_cls | append: ' ebn2--anim-' | append: anim_type
  endif
  if anim_stagger and anim_enable and anim_type != 'none'
    assign sec_cls = sec_cls | append: ' ebn2--stagger'
  endif
  if anim_img_type != 'none'
    assign sec_cls = sec_cls | append: ' ebn2--img-anim-' | append: anim_img_type
  endif
  if anim_dis_mob
    assign sec_cls = sec_cls | append: ' ebn2--anim-no-mob'
  endif
  if custom_classes != blank
    assign sec_cls = sec_cls | append: ' ' | append: custom_classes
  endif

  assign section_id = 'ebn2-' | append: sid
  if custom_id != blank
    assign section_id = custom_id
  endif
-%}

{%- if img_loading == 'eager' -%}
  <link rel="preload" as="image" href="{{ img_url_d }}" media="(min-width: 768px)">
{%- endif -%}

<section
  id="{{ section_id }}"
  class="{{ sec_cls }}"
  style="
    --ebn2-bg:          {{ container_bg }};
    --ebn2-mt:          {{ mt }}px;
    --ebn2-mb:          {{ mb }}px;
    --ebn2-pt-m:        {{ pt_mob }}px;
    --ebn2-pb-m:        {{ pb_mob }}px;
    --ebn2-pt-d:        {{ pt_desk }}px;
    --ebn2-pb-d:        {{ pb_desk }}px;
    --ebn2-ph-d:        {{ ph_desk }}px;
    --ebn2-ph-t:        {{ ph_tab }}px;
    --ebn2-ph-m:        {{ ph_mob }}px;
    --ebn2-col-gap:     {{ col_gap }}px;
    --ebn2-content-mw:  {{ content_mw }}px;
    --ebn2-content-gap: {{ content_gap }}px;
    --ebn2-content-r:   {{ content_radius }}px;
    --ebn2-content-blur:{{ content_blur }}px;
    --ebn2-content-bg-ov: {{ content_bg_ov | divided_by: 100.0 }};
    --ebn2-img-h-m:     {{ img_height_mob }}px;
    --ebn2-h-d:         {{ h_desk }}px;
    --ebn2-ov-r:        {{ ov_r }};
    --ebn2-ov-g:        {{ ov_g }};
    --ebn2-ov-b:        {{ ov_b }};
    --ebn2-ov-a:        {{ overlay_op }};
    --ebn2-anim-delay:  {{ anim_delay }}ms;
    --ebn2-heading-color:    {{ heading_color }};
    --ebn2-heading-grad-from:{{ heading_grad_from }};
    --ebn2-heading-grad-to:  {{ heading_grad_to }};
    --ebn2-body-color:       {{ body_color }};
    --ebn2-heading-fw:       {{ heading_fw }};
    --ebn2-heading-lh:       {{ heading_lh }};
    --ebn2-heading-ls:       {{ heading_ls }}em;
    --ebn2-heading-sz-d:     {{ heading_sz_d }}px;
    --ebn2-heading-sz-t:     {{ heading_sz_t }}px;
    --ebn2-heading-sz-m:     {{ heading_sz_m }}px;
    --ebn2-body-fs-d:        {{ body_fs_d }}px;
    --ebn2-body-fs-m:        {{ body_fs_m }}px;
    --ebn2-body-fw:          {{ body_fw }};
    --ebn2-body-lh:          {{ body_lh }};
    --ebn2-body-mw:          {{ body_mw }}ch;
    --ebn2-badge-color:      {{ badge_color }};
    --ebn2-badge-fs:         {{ badge_fs }}px;
    --ebn2-badge-fw:         {{ badge_fw }};
    --ebn2-badge-ls:         calc({{ badge_ls }} * 0.01em);
    --ebn2-badge-r:          {{ badge_radius }}px;
    --ebn2-badge-py:         {{ badge_py }}px;
    --ebn2-badge-px:         {{ badge_px }}px;
    {% if badge_bg != blank %}--ebn2-badge-bg: {{ badge_bg }};{% endif %}
    {% if badge_border != blank %}--ebn2-badge-border: {{ badge_border }};{% endif %}
    --ebn2-btn-r:     {{ cta1_radius }}px;
    --ebn2-btn-py:    {{ btn_py }}px;
    --ebn2-btn-px:    {{ btn_px }}px;
    --ebn2-btn-fs:    {{ btn_fs }}px;
    --ebn2-btn-fw:    {{ btn_fw }};
    --ebn2-btn-ls:    calc({{ btn_ls }} * 0.01em);
    --ebn2-ctas-gap:  {{ ctas_gap }}px;
    --ebn2-media-bg:  {{ media_bg }};
    --ebn2-media-r:   {{ media_r }}px;
    --ebn2-zoom:      {{ zoom_scale }};
    --ebn2-vignette:  {{ vignette_intensity | divided_by: 100.0 }};
    --ebn2-large-margin: {{ large_margin }}px;
    --ebn2-large-radius: {{ large_radius }}px;
    --ebn2-img-fit-m: {{ img_fit_mob }};
    --ebn2-img-filter: {{ img_filter }};
    --ebn2-img-scale: {{ img_scale_val }};
    --ebn2-halo-r:    {{ halo_r }};
    --ebn2-halo-g:    {{ halo_g }};
    --ebn2-halo-b:    {{ halo_b }};
    --ebn2-halo-int:  {{ halo_intensity | divided_by: 100.0 }};
    --ebn2-grain-op:  {{ grain_opacity | divided_by: 100.0 }};
  "
>
  <div class="ebn2__grid">

    {%- comment -%} ── COL TEXTE ── {%- endcomment -%}
    <div class="ebn2__col ebn2__col--text">
      <div class="ebn2__content ebn2__content--{{ text_align }}">

        {%- if badge_text != blank -%}
          <span class="ebn2__badge ebn2__badge--{{ badge_style }}">{{ badge_text | escape }}</span>
        {%- endif -%}

        {%- if heading != blank -%}
          <h2 class="ebn2__title">{{ heading | escape }}</h2>
        {%- endif -%}

        {%- if richtext != blank -%}
          <div class="ebn2__subtitle">{{ richtext }}</div>
        {%- endif -%}

        {%- if cta1_label != blank or cta2_label != blank -%}
          <div class="ebn2__ctas{% if cta_fw_mobile %} ebn2__ctas--fw-mob{% endif %}">

            {%- if cta1_label != blank -%}
              <a href="{{ cta1_url }}"
                 class="ebn2__cta ebn2__cta--{{ cta1_style }}{% if cta1_bg != blank %} ebn2__cta--custom{% endif %}"
                 {% if cta1_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                 {% if cta1_bg != blank %}style="--ebn2-cb:{{ cta1_bg }};--ebn2-ct:{{ cta1_color | default: '#ffffff' }};--ebn2-chob:{{ cta1_hover_bg | default: cta1_bg }};"{% endif %}
                 aria-label="{{ cta1_label | escape }}">
                <span class="ebn2__cta-label">{{ cta1_label | escape }}</span>
                <span class="ebn2__cta-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </a>
            {%- endif -%}

            {%- if cta2_label != blank -%}
              <a href="{{ cta2_url }}"
                 class="ebn2__cta ebn2__cta--{{ cta2_style }}{% if cta2_bg != blank %} ebn2__cta--custom{% endif %}"
                 {% if cta2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                 {% if cta2_bg != blank %}style="--ebn2-cb:{{ cta2_bg }};--ebn2-ct:{{ cta2_color | default: '#ffffff' }};--ebn2-chob:{{ cta2_hover_bg | default: cta2_bg }};"{% endif %}
                 aria-label="{{ cta2_label | escape }}">
                <span class="ebn2__cta-label">{{ cta2_label | escape }}</span>
              </a>
            {%- endif -%}

          </div>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%} ── COL IMAGE ── {%- endcomment -%}
    <div class="ebn2__col ebn2__col--media" aria-hidden="true">
      <div class="ebn2__media-inner">
        <picture>
          <source media="(max-width: 479px)"  srcset="{{ img_url_m }}">
          <source media="(max-width: 1023px)" srcset="{{ img_url_t }}">
          <img
            class="ebn2__img"
            src="{{ img_url_d }}"
            srcset="{{ img_url_d }} 1x, {{ img_url_d_2x }} 2x"
            alt=""
            loading="{{ img_loading }}"
            decoding="async"
            style="object-fit: {{ img_fit }}; object-position: {{ img_focal }};"
          >
        </picture>
        {%- if overlay_op > 0 -%}
          <div class="ebn2__img-overlay" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{%- if custom_css != blank -%}
  <style>#{{ section_id }} { {{ custom_css }} }</style>
{%- endif -%}

<style>
/* ═══════════════════════════════════════════════════
   EDITORIAL BANNER 2 — Motion19 — v5.0
   Préfixe .ebn2 — namespace isolé
═══════════════════════════════════════════════════ */

.ebn2 {
  background-color: var(--ebn2-bg, #0a0a0a);
  margin-top:    var(--ebn2-mt, 0px);
  margin-bottom: var(--ebn2-mb, 0px);
  overflow: hidden;
  position: relative;
}

/* ── Grille mobile : 1 colonne ── */
.ebn2__grid {
  display: grid;
  grid-template-columns: 1fr;
}

/* Mobile : cellules carrées */
@media (max-width: 767px) {
  .ebn2__col--text,
  .ebn2__col--media { aspect-ratio: 1 / 1; }
  .ebn2--hide-img-mob .ebn2__col--media { display: none; }
}

/* Ordre mobile */
.ebn2--mob-content-top .ebn2__col--text  { order: 1; }
.ebn2--mob-content-top .ebn2__col--media { order: 2; }
.ebn2--mob-image-top   .ebn2__col--text  { order: 2; }
.ebn2--mob-image-top   .ebn2__col--media { order: 1; }

/* ── Colonne texte ── */
.ebn2__col--text {
  background-color: var(--ebn2-bg, #0a0a0a);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: var(--ebn2-pt-m, 56px) var(--ebn2-ph-m, 24px) var(--ebn2-pb-m, 56px);
  position: relative;
  z-index: 0;
  overflow: hidden;
}

/* ── Texture dots ── */
.ebn2__col--text::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
  z-index: 0;
}
.ebn2--no-dots .ebn2__col--text::before { display: none; }

/* ── Halo lumineux ── */
.ebn2__col--text::after {
  content: '';
  position: absolute;
  bottom: -80px;
  left: -60px;
  width: 360px;
  height: 360px;
  background: radial-gradient(circle,
    rgba(var(--ebn2-halo-r,7), var(--ebn2-halo-g,135), var(--ebn2-halo-b,234), var(--ebn2-halo-int,0.12)) 0%,
    transparent 65%
  );
  pointer-events: none;
  z-index: 0;
}
.ebn2--no-halo .ebn2__col--text::after { display: none; }

/* ── Grain / Noise ── */
.ebn2--grain .ebn2__col--text {
  isolation: isolate;
}
.ebn2--grain .ebn2__col--text::before {
  background-image:
    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E"),
    radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 200px 200px, 24px 24px;
  opacity: var(--ebn2-grain-op, 0.03);
  mix-blend-mode: screen;
}

/* ── Contenu interne ── */
.ebn2__content {
  display: flex;
  flex-direction: column;
  gap: var(--ebn2-content-gap, 20px);
  max-width: var(--ebn2-content-mw, 520px);
  width: 100%;
  position: relative;
  z-index: 1;
  border-radius: var(--ebn2-content-r, 0px);
}

/* Glass mode */
.ebn2--glass-content .ebn2__content {
  background: rgba(255,255,255,var(--ebn2-content-bg-ov, 0.05));
  backdrop-filter: blur(var(--ebn2-content-blur, 0px));
  -webkit-backdrop-filter: blur(var(--ebn2-content-blur, 0px));
  padding: 28px 32px;
  border: 1px solid rgba(255,255,255,0.08);
}

.ebn2__content--left   { align-items: flex-start; text-align: left; }
.ebn2__content--center { align-items: center;      text-align: center; margin-left: auto; margin-right: auto; }
.ebn2__content--right  { align-items: flex-end;    text-align: right;  margin-left: auto; }

/* ── Badge ── */
.ebn2__badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: var(--ebn2-badge-fs, 11px);
  font-weight: var(--ebn2-badge-fw, 600);
  letter-spacing: var(--ebn2-badge-ls, 0.18em);
  text-transform: uppercase;
  color: var(--ebn2-badge-color, #0787ea);
}

.ebn2__badge--line { background: transparent; }
.ebn2__badge--line::before {
  content: '';
  display: block;
  width: 22px;
  height: 1.5px;
  background: currentColor;
  flex-shrink: 0;
}
.ebn2__content--center .ebn2__badge--line::before,
.ebn2__content--right  .ebn2__badge--line::before { display: none; }

.ebn2__badge--filled {
  background: var(--ebn2-badge-bg, var(--ebn2-badge-color, #0787ea));
  color: var(--ebn2-badge-color, #fff);
  padding: var(--ebn2-badge-py,4px) var(--ebn2-badge-px,10px);
  border-radius: var(--ebn2-badge-r,12px);
}

.ebn2__badge--outline {
  background: transparent;
  border: 1.5px solid var(--ebn2-badge-border, var(--ebn2-badge-color, #0787ea));
  padding: var(--ebn2-badge-py,4px) var(--ebn2-badge-px,10px);
  border-radius: var(--ebn2-badge-r,12px);
}

.ebn2__badge--ghost {
  background: rgba(255,255,255,0.08);
  padding: var(--ebn2-badge-py,4px) var(--ebn2-badge-px,10px);
  border-radius: var(--ebn2-badge-r,12px);
}

.ebn2__badge--glass {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.18);
  padding: var(--ebn2-badge-py,4px) var(--ebn2-badge-px,10px);
  border-radius: var(--ebn2-badge-r,12px);
  color: #fff;
}

.ebn2__badge--gradient {
  background: linear-gradient(90deg, var(--ebn2-heading-grad-from,#fff), var(--ebn2-heading-grad-to,#0787ea));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Titre ── */
.ebn2__title {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: var(--ebn2-heading-sz-m, 28px);
  font-weight: var(--ebn2-heading-fw, 700);
  line-height: var(--ebn2-heading-lh, 1.05);
  letter-spacing: var(--ebn2-heading-ls, -0.03em);
  color: var(--ebn2-heading-color, #f5f5f7);
  margin: 0;
  text-wrap: balance;
  position: relative;
  padding-bottom: 16px;
}
.ebn2__title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 36px;
  height: 3px;
  background: var(--ebn2-badge-color, #0787ea);
  border-radius: 2px;
}
.ebn2__content--center .ebn2__title::after { left: 50%; transform: translateX(-50%); }
.ebn2__content--right  .ebn2__title::after { left: auto; right: 0; }

.ebn2--title-gradient .ebn2__title {
  background: linear-gradient(135deg, var(--ebn2-heading-grad-from,#fff) 0%, var(--ebn2-heading-grad-to,#0787ea) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Corps texte ── */
.ebn2__subtitle {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: var(--ebn2-body-fs-m, 14px);
  font-weight: var(--ebn2-body-fw, 400);
  line-height: var(--ebn2-body-lh, 1.72);
  color: var(--ebn2-body-color, rgba(245,245,247,0.65));
  max-width: var(--ebn2-body-mw, 46ch);
}
.ebn2__content--center .ebn2__subtitle,
.ebn2__content--right  .ebn2__subtitle { max-width: unset; }
.ebn2__subtitle p            { margin: 0 0 0.6em; }
.ebn2__subtitle p:last-child { margin-bottom: 0; }
.ebn2__subtitle a            { color: var(--color-primary, #0787ea); text-decoration: underline; }
.ebn2__subtitle strong       { font-weight: 600; color: var(--ebn2-heading-color, #f5f5f7); }

/* ── CTAs ── */
.ebn2__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--ebn2-ctas-gap, 10px);
  align-items: center;
}
.ebn2__content--center .ebn2__ctas { justify-content: center; }
.ebn2__content--right  .ebn2__ctas { justify-content: flex-end; }
@media (max-width: 767px) {
  .ebn2__ctas--fw-mob           { flex-direction: column; }
  .ebn2__ctas--fw-mob .ebn2__cta { width: 100%; justify-content: center; }
}

/* ── Boutons base ── */
.ebn2__cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: var(--ebn2-btn-fs, 13px);
  font-weight: var(--ebn2-btn-fw, 600);
  letter-spacing: var(--ebn2-btn-ls, 0.025em);
  text-decoration: none;
  border-radius: var(--ebn2-btn-r, 999px);
  border: 1.5px solid transparent;
  padding: var(--ebn2-btn-py, 14px) var(--ebn2-btn-px, 26px);
  transition: background 200ms ease, color 200ms ease, border-color 200ms ease,
              transform 180ms ease, box-shadow 200ms ease;
  white-space: nowrap;
  cursor: pointer;
}
.ebn2__cta-icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.ebn2__cta:focus-visible { outline: 2px solid var(--color-primary, #0787ea); outline-offset: 3px; }

.ebn2__cta--solid { background: #fff; color: #0a0a0a; border-color: #fff; }
@media (hover: hover) {
  .ebn2__cta--solid:hover { background: var(--color-primary, #0787ea); color: #fff; border-color: var(--color-primary, #0787ea); box-shadow: 0 8px 32px rgba(7,135,234,0.36); }
  .ebn2__cta--solid:hover .ebn2__cta-icon { transform: translateX(4px); }
}

.ebn2__cta--primary { background: var(--color-primary, #0787ea); color: #fff; border-color: var(--color-primary, #0787ea); }
@media (hover: hover) {
  .ebn2__cta--primary:hover { background: var(--color-primary-hover, #0672c7); box-shadow: 0 6px 20px rgba(7,135,234,0.38); transform: translateY(-1px); }
  .ebn2__cta--primary:hover .ebn2__cta-icon { transform: translateX(4px); }
}

.ebn2__cta--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,0.55); }
@media (hover: hover) {
  .ebn2__cta--outline-white:hover { background: #fff; color: #0a0a0a; border-color: #fff; transform: translateY(-1px); }
}

.ebn2__cta--ghost { background: transparent; color: var(--ebn2-heading-color, #f5f5f7); border-color: transparent; padding-left: 0; padding-right: 0; gap: 6px; }
@media (hover: hover) {
  .ebn2__cta--ghost:hover { opacity: 0.7; }
  .ebn2__cta--ghost:hover .ebn2__cta-icon { transform: translateX(5px); }
}

.ebn2__cta--dark { background: #0a0a0a; color: #f5f5f7; border-color: #333; }
@media (hover: hover) {
  .ebn2__cta--dark:hover { background: #1a1a1a; transform: translateY(-1px); }
  .ebn2__cta--dark:hover .ebn2__cta-icon { transform: translateX(4px); }
}

.ebn2__cta--gradient {
  background: linear-gradient(135deg, var(--ebn2-heading-grad-from,#0787ea), var(--ebn2-heading-grad-to,#0052b4));
  color: #fff;
  border-color: transparent;
}
@media (hover: hover) {
  .ebn2__cta--gradient:hover { filter: brightness(1.12); transform: translateY(-1px); box-shadow: 0 8px 28px rgba(7,135,234,0.4); }
  .ebn2__cta--gradient:hover .ebn2__cta-icon { transform: translateX(4px); }
}

.ebn2__cta--glass {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: #fff;
  border-color: rgba(255,255,255,0.2);
}
@media (hover: hover) {
  .ebn2__cta--glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }
}

.ebn2__cta--neon {
  background: transparent;
  color: var(--color-primary, #0787ea);
  border-color: var(--color-primary, #0787ea);
  box-shadow: 0 0 12px rgba(7,135,234,0.3), inset 0 0 12px rgba(7,135,234,0.05);
}
@media (hover: hover) {
  .ebn2__cta--neon:hover { background: var(--color-primary, #0787ea); color: #fff; box-shadow: 0 0 24px rgba(7,135,234,0.6), 0 0 48px rgba(7,135,234,0.3); }
}

.ebn2__cta--minimal {
  background: transparent;
  color: var(--ebn2-heading-color, #f5f5f7);
  border-color: rgba(255,255,255,0.2);
}
@media (hover: hover) {
  .ebn2__cta--minimal:hover { border-color: rgba(255,255,255,0.6); transform: translateY(-1px); }
}

.ebn2__cta--pill { border-radius: 999px; }
.ebn2__cta--pill.ebn2__cta--solid { background: #fff; color: #0a0a0a; border-color: #fff; }
@media (hover: hover) { .ebn2__cta--pill.ebn2__cta--solid:hover { background: var(--color-primary, #0787ea); color: #fff; border-color: var(--color-primary, #0787ea); } }

.ebn2__cta--luxury {
  background: transparent;
  color: var(--ebn2-heading-color, #f5f5f7);
  border-color: rgba(255,255,255,0.35);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-size: calc(var(--ebn2-btn-fs,13px) * 0.9);
}
@media (hover: hover) {
  .ebn2__cta--luxury:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.7); }
}

@media (hover: hover) {
  .ebn2--btn1-scale .ebn2__ctas .ebn2__cta:first-child:hover { transform: scale(1.04) translateY(-1px); }
  .ebn2--btn1-glow  .ebn2__ctas .ebn2__cta:first-child:hover { box-shadow: 0 0 24px rgba(7,135,234,0.5), 0 8px 32px rgba(7,135,234,0.25); }
}

.ebn2__cta--custom {
  background:   var(--ebn2-cb) !important;
  color:        var(--ebn2-ct, #fff) !important;
  border-color: var(--ebn2-cb) !important;
}
@media (hover: hover) {
  .ebn2__cta--custom:hover { background: var(--ebn2-chob, var(--ebn2-cb)) !important; border-color: var(--ebn2-chob, var(--ebn2-cb)) !important; }
  .ebn2__cta--custom:hover .ebn2__cta-icon { transform: translateX(4px); }
}

/* ── Colonne image ── */
.ebn2__col--media {
  position: relative;
  overflow: hidden;
  background: var(--ebn2-media-bg, #111);
  border-radius: var(--ebn2-media-r, 0px);
}

.ebn2__media-inner {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

/* Image styles */
.ebn2--img-floating .ebn2__col--media { padding: 24px; }
.ebn2--img-floating .ebn2__media-inner { inset: 24px; border-radius: 12px; box-shadow: 0 24px 80px rgba(0,0,0,0.4); }

.ebn2--img-framed .ebn2__col--media { padding: 16px; border: 1px solid rgba(255,255,255,0.1); }
.ebn2--img-framed .ebn2__media-inner { inset: 16px; }

.ebn2--img-shadow-xl .ebn2__media-inner { box-shadow: 0 40px 120px rgba(0,0,0,0.5); }

.ebn2--img-glassmorphism .ebn2__col--media {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.12);
}

.ebn2--img-cinematic .ebn2__col--media::after {
  background:
    linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, transparent 20%, transparent 80%, rgba(0,0,0,0.4) 100%),
    linear-gradient(to right, rgba(0,0,0,0.3) 0%, transparent 30%);
}

.ebn2--img-rounded .ebn2__col--media {
  border-radius: max(var(--ebn2-media-r, 0px), 16px);
  overflow: hidden;
}

.ebn2__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  transition: transform 720ms cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
  filter: var(--ebn2-img-filter, none);
  transform: scale(var(--ebn2-img-scale, 1));
}

@media (max-width: 479px) {
  .ebn2__img {
    object-fit: var(--ebn2-img-fit-m, contain) !important;
    object-position: center center !important;
  }
}

@media (hover: hover) {
  .ebn2--zoom:hover .ebn2__img { transform: scale(calc(var(--ebn2-img-scale,1) * var(--ebn2-zoom, 1.04))); }
}

/* Vignette */
.ebn2__col--media::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(10,10,10,var(--ebn2-vignette,0.2)) 0%, transparent 35%),
    linear-gradient(to top,   rgba(0,0,0,calc(var(--ebn2-vignette,0.2) * 0.5)) 0%, transparent 40%);
  pointer-events: none;
  z-index: 1;
}
.ebn2--no-vignette .ebn2__col--media::after { display: none; }

.ebn2__img-overlay {
  position: absolute;
  inset: 0;
  background: rgba(var(--ebn2-ov-r,0), var(--ebn2-ov-g,0), var(--ebn2-ov-b,0), var(--ebn2-ov-a,0));
  pointer-events: none;
  z-index: 2;
}

/* ── Tablet 768px–1023px — hauteur immersive (≈72vh) ── */
@media (min-width: 768px) {
  .ebn2__grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--ebn2-col-gap, 0px);
    height: clamp(480px, 72vh, 820px);
  }
  .ebn2--h-small  .ebn2__grid { height: clamp(360px, 58vh, 640px); }
  .ebn2--h-medium .ebn2__grid { height: clamp(480px, 72vh, 820px); }
  .ebn2--h-large  .ebn2__grid { height: clamp(600px, 85vh, 1040px); }
  .ebn2--h-custom .ebn2__grid { height: var(--ebn2-h-d, 720px); }

  .ebn2__col--media { height: auto; }

  .ebn2__col--text {
    padding: var(--ebn2-pt-m, 56px) var(--ebn2-ph-t, 48px) var(--ebn2-pb-m, 56px);
  }

  .ebn2--layout-content-left  .ebn2__col--text  { order: 1; }
  .ebn2--layout-content-left  .ebn2__col--media { order: 2; }
  .ebn2--layout-content-right .ebn2__col--text  { order: 2; }
  .ebn2--layout-content-right .ebn2__col--media { order: 1; }

  .ebn2--split-50-50 .ebn2__grid { grid-template-columns: 1fr 1fr; }
  .ebn2--split-55-45 .ebn2__grid { grid-template-columns: 11fr 9fr; }
  .ebn2--split-45-55 .ebn2__grid { grid-template-columns: 9fr 11fr; }
  .ebn2--split-60-40 .ebn2__grid { grid-template-columns: 3fr 2fr; }
  .ebn2--split-40-60 .ebn2__grid { grid-template-columns: 2fr 3fr; }

  .ebn2__title { font-size: var(--ebn2-heading-sz-t, 36px); }
  .ebn2__subtitle { font-size: var(--ebn2-body-fs-d, 16px); }
}

/* ── Desktop 1024px+ — hauteur immersive (≈80vh) ── */
@media (min-width: 1024px) {
  .ebn2__col--text {
    padding: var(--ebn2-pt-d, 80px) var(--ebn2-ph-d, 80px) var(--ebn2-pb-d, 80px);
  }
  .ebn2__title { font-size: var(--ebn2-heading-sz-d, 48px); }

  /* Override des hauteurs à 1024px+ pour effet immersif */
  .ebn2__grid                { height: clamp(560px, 80vh, 1000px); }
  .ebn2--h-small  .ebn2__grid{ height: clamp(400px, 62vh, 700px); }
  .ebn2--h-medium .ebn2__grid{ height: clamp(560px, 80vh, 1000px); }
  .ebn2--h-large  .ebn2__grid{ height: clamp(680px, 90vh, 1100px); }
  .ebn2--h-custom .ebn2__grid{ height: var(--ebn2-h-d, 720px); }
}

/* ── Grand écran 1500px+ : floating ── */
@media (min-width: 1500px) {
  .ebn2--float {
    margin-left:   var(--ebn2-large-margin, 40px);
    margin-right:  var(--ebn2-large-margin, 40px);
    border-radius: var(--ebn2-large-radius, 16px);
    overflow: hidden;
  }
}

/* ── Animations section ── */
.ebn2--anim-fade-up    .ebn2__content,
.ebn2--anim-fade-down  .ebn2__content,
.ebn2--anim-fade-left  .ebn2__content,
.ebn2--anim-fade-right .ebn2__content,
.ebn2--anim-fade       .ebn2__content { opacity: 0; }

.ebn2--anim-fade-up    .ebn2__content { transform: translateY(18px); }
.ebn2--anim-fade-down  .ebn2__content { transform: translateY(-18px); }
.ebn2--anim-fade-left  .ebn2__content { transform: translateX(18px); }
.ebn2--anim-fade-right .ebn2__content { transform: translateX(-18px); }

.ebn2.is-visible .ebn2__content {
  opacity: 1;
  transform: none;
  transition:
    opacity   550ms cubic-bezier(0.22, 1, 0.36, 1) var(--ebn2-anim-delay, 0ms),
    transform 550ms cubic-bezier(0.22, 1, 0.36, 1) var(--ebn2-anim-delay, 0ms);
}

/* Stagger */
.ebn2--stagger .ebn2__badge,
.ebn2--stagger .ebn2__title,
.ebn2--stagger .ebn2__subtitle,
.ebn2--stagger .ebn2__ctas {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 480ms cubic-bezier(0.22,1,0.36,1), transform 480ms cubic-bezier(0.22,1,0.36,1);
}
.ebn2--stagger.is-visible .ebn2__badge   { opacity: 1; transform: none; transition-delay: calc(var(--ebn2-anim-delay,0ms) + 0ms); }
.ebn2--stagger.is-visible .ebn2__title   { opacity: 1; transform: none; transition-delay: calc(var(--ebn2-anim-delay,0ms) + 80ms); }
.ebn2--stagger.is-visible .ebn2__subtitle{ opacity: 1; transform: none; transition-delay: calc(var(--ebn2-anim-delay,0ms) + 160ms); }
.ebn2--stagger.is-visible .ebn2__ctas    { opacity: 1; transform: none; transition-delay: calc(var(--ebn2-anim-delay,0ms) + 240ms); }

/* Animation image */
.ebn2--img-anim-fade    .ebn2__col--media { opacity: 0; transition: opacity 800ms ease; }
.ebn2--img-anim-zoom    .ebn2__col--media .ebn2__img { transform: scale(1.1); transition: transform 1200ms cubic-bezier(0.22,1,0.36,1); }
.ebn2--img-anim-slide   .ebn2__col--media { transform: translateX(40px); opacity: 0; transition: transform 700ms cubic-bezier(0.22,1,0.36,1), opacity 700ms ease; }

.ebn2.is-visible.ebn2--img-anim-fade  .ebn2__col--media { opacity: 1; }
.ebn2.is-visible.ebn2--img-anim-zoom  .ebn2__col--media .ebn2__img { transform: scale(var(--ebn2-img-scale, 1)); }
.ebn2.is-visible.ebn2--img-anim-slide .ebn2__col--media { transform: none; opacity: 1; }

/* Désactiver animation mobile */
@media (max-width: 767px) {
  .ebn2--anim-no-mob .ebn2__content,
  .ebn2--anim-no-mob .ebn2__badge,
  .ebn2--anim-no-mob .ebn2__title,
  .ebn2--anim-no-mob .ebn2__subtitle,
  .ebn2--anim-no-mob .ebn2__ctas {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ebn2--anim-fade-up    .ebn2__content,
  .ebn2--anim-fade-down  .ebn2__content,
  .ebn2--anim-fade-left  .ebn2__content,
  .ebn2--anim-fade-right .ebn2__content,
  .ebn2--anim-fade       .ebn2__content,
  .ebn2--stagger .ebn2__badge,
  .ebn2--stagger .ebn2__title,
  .ebn2--stagger .ebn2__subtitle,
  .ebn2--stagger .ebn2__ctas { opacity: 1; transform: none; }
  .ebn2__img { transition: none; }
}
</style>

<script>
(function () {
  'use strict';
  var sec = document.getElementById('{{ section_id }}');
  if (!sec) return;
  {% if anim_enable and anim_type != 'none' %}
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('is-visible');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.08 });
    obs.observe(sec);
  } else {
    sec.classList.add('is-visible');
  }
  {% else %}
  sec.classList.add('is-visible');
  {% endif %}
})();
</script>

{% schema %}
{
  "name": "Editorial Banner 2",
  "tag": "section",
  "class": "section-editorial-banner-2",
