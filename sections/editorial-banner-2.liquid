        { "value": "1.02", "label": "Très léger (2%)" }, { "value": "1.04", "label": "Léger (4%)" },
        { "value": "1.06", "label": "Modéré (6%)" }, { "value": "1.08", "label": "Fort (8%)" },
        { "value": "1.1",  "label": "Très fort (10%)" }
      ]
    },

    { "type": "header", "content": "── 13. Overlay image" },
    { "type": "color", "id": "overlay_color",   "label": "Couleur overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Opacité (%)", "min": 0, "max": 80, "step": 5, "default": 0, "unit": "%" },

    { "type": "header", "content": "── 14. Espacement" },
