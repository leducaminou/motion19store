    { "type": "range", "id": "pb_desktop",    "label": "Padding bas desktop (px)",   "min": 0, "max": 160, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "pt_mobile",     "label": "Padding haut mobile (px)",   "min": 0, "max": 120, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "pb_mobile",     "label": "Padding bas mobile (px)",    "min": 0, "max": 120, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "ph_desktop",    "label": "Padding horizontal desktop", "min": 0, "max": 160, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "ph_tablet",     "label": "Padding horizontal tablet",  "min": 0, "max": 100, "step": 4, "default": 48, "unit": "px" },
    { "type": "range", "id": "ph_mobile",     "label": "Padding horizontal mobile",  "min": 0, "max": 48,  "step": 2, "default": 24, "unit": "px" },
    { "type": "range", "id": "margin_top",    "label": "Marge externe haut (px)",    "min": 0, "max": 120, "step": 4, "default": 0,  "unit": "px" },
    { "type": "range", "id": "margin_bottom", "label": "Marge externe bas (px)",     "min": 0, "max": 120, "step": 4, "default": 0,  "unit": "px" },

