{%- comment -%} Editorial Banner 2 — Motion19 — v3.0 — Fully Theme-Customizer-driven {%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign eyebrow_text  = section.settings.eyebrow_text
  assign title_text    = section.settings.title_text
  assign subtitle_text = section.settings.subtitle_text
  assign cta_label     = section.settings.cta_label
  assign cta_url       = section.settings.cta_url    | default: '#'
  assign cta_new_tab   = section.settings.cta_new_tab | default: false
  assign cta_style     = section.settings.cta_style   | default: 'outline-white'
  assign cta_radius    = section.settings.cta_radius  | default: 2
  assign cta2_label    = section.settings.cta2_label
  assign cta2_url      = section.settings.cta2_url    | default: '#'
  assign cta2_new_tab  = section.settings.cta2_new_tab | default: false
  assign cta2_style    = section.settings.cta2_style   | default: 'ghost'

  assign fallback_img  = section.settings.fallback_image
  assign content_align  = section.settings.content_align  | default: 'center'
  assign content_valign = section.settings.content_valign | default: 'start'
  assign overlay_style  = section.settings.overlay_style  | default: 'cinematic'

  assign overlay_op    = section.settings.overlay_opacity | default: 30 | divided_by: 100.0

  assign mt           = section.settings.margin_top    | default: 0
  assign mb           = section.settings.margin_bottom | default: 0
  assign large_margin = section.settings.large_screen_margin | default: 40
  assign large_radius = section.settings.large_screen_radius | default: 12
  assign enable_float = section.settings.enable_large_float  | default: true

  assign anim_enable  = section.settings.anim_enable | default: true

  assign h_desktop    = section.settings.height_desktop   | default: 800
  assign h_medium     = section.settings.height_medium    | default: 640
  assign min_h_mobile = section.settings.min_height_mobile | default: 520

  assign section_bg   = section.settings.section_bg
  if section_bg == blank
    assign section_bg = 'var(--color-bg-dark)'
  endif

  assign content_max_width = section.settings.content_max_width | default: 720
  assign content_gap       = section.settings.content_gap       | default: 20

  assign pt_mobile  = section.settings.pt_mobile  | default: 20
  assign pt_tablet  = section.settings.pt_tablet  | default: 20
  assign pt_desktop = section.settings.pt_desktop | default: 72
  assign ph_mobile  = section.settings.ph_mobile  | default: 24
  assign ph_tablet  = section.settings.ph_tablet  | default: 40
  assign ph_desktop = section.settings.ph_desktop | default: 80

  assign eyebrow_color = section.settings.eyebrow_color
  if eyebrow_color == blank
    assign ey_r = 255
    assign ey_g = 255
    assign ey_b = 255
  else
    assign ey_r = eyebrow_color.red
    assign ey_g = eyebrow_color.green
    assign ey_b = eyebrow_color.blue
  endif
  assign eyebrow_opacity = section.settings.eyebrow_opacity | default: 65 | divided_by: 100.0
  assign eyebrow_fs      = section.settings.eyebrow_fs      | default: 16
  assign eyebrow_lh      = section.settings.eyebrow_lh      | default: 20
  assign eyebrow_fw      = section.settings.eyebrow_fw      | default: '400'
  assign eyebrow_ls_raw  = section.settings.eyebrow_ls      | default: 2

  assign title_color = section.settings.title_color
  if title_color == blank
    assign title_color = 'var(--color-bg)'
  endif
  assign title_fs_desktop = section.settings.title_fs_desktop | default: 32
  assign title_fs_mobile  = section.settings.title_fs_mobile  | default: 24
  assign title_fw         = section.settings.title_fw         | default: '800'
  assign title_lh_raw     = section.settings.title_lh         | default: 95 | divided_by: 100.0
  assign title_ls         = section.settings.title_ls         | default: '-0.03'

  assign subtitle_color = section.settings.subtitle_color
  if subtitle_color == blank
    assign sub_r = 255
    assign sub_g = 255
    assign sub_b = 255
  else
    assign sub_r = subtitle_color.red
    assign sub_g = subtitle_color.green
    assign sub_b = subtitle_color.blue
  endif
  assign subtitle_opacity    = section.settings.subtitle_opacity    | default: 80 | divided_by: 100.0
  assign subtitle_fs_desktop = section.settings.subtitle_fs_desktop | default: 20
  assign subtitle_fs_mobile  = section.settings.subtitle_fs_mobile  | default: 16
  assign subtitle_lh_desktop = section.settings.subtitle_lh_desktop | default: 24
  assign subtitle_lh_mobile  = section.settings.subtitle_lh_mobile  | default: 22
  assign subtitle_fw         = section.settings.subtitle_fw         | default: '500'

  assign btn_fs     = section.settings.btn_fs     | default: 13
  assign btn_fw     = section.settings.btn_fw     | default: '600'
  assign btn_py     = section.settings.btn_py     | default: 14
  assign btn_px     = section.settings.btn_px     | default: 26
  assign btn_ls_raw = section.settings.btn_ls     | default: 2

  assign video_filename = section.settings.video_filename | default: 'hp-editorial.mp4'

  if fallback_img != blank
    assign bg_img_url    = fallback_img | image_url: width: 2000
    assign bg_img_url_sm = fallback_img | image_url: width: 900
    assign img_w         = fallback_img.width  | default: 1920
    assign img_h         = fallback_img.height | default: 800
  else
    assign bg_img_url    = 'hp-editorial-5.jpg' | asset_url
    assign bg_img_url_sm = bg_img_url
    assign img_w         = 1920
    assign img_h         = 800
  endif

  assign video_asset = video_filename | asset_url

  assign sec_cls = 'eb2'
  if enable_float
    assign sec_cls = sec_cls | append: ' eb2--float'
  endif
  unless anim_enable
    assign sec_cls = sec_cls | append: ' eb2--no-anim'
  endunless
-%}

<section
  id="eb2-{{ sid }}"
  class="{{ sec_cls }}"
  style="
    --eb2-bg:             {{ section_bg }};
    --eb2-mt:             {{ mt }}px;
    --eb2-mb:             {{ mb }}px;
    --eb2-h-d:            {{ h_desktop }}px;
    --eb2-h-med:          {{ h_medium }}px;
    --eb2-min-h-mob:      {{ min_h_mobile }}px;
    --eb2-large-margin:   {{ large_margin }}px;
    --eb2-large-radius:   {{ large_radius }}px;
    --eb2-overlay-op:     {{ overlay_op }};
    --eb2-content-mw:     {{ content_max_width }}px;
    --eb2-content-gap:    {{ content_gap }}px;
    --eb2-pt-mob:         {{ pt_mobile }}px;
    --eb2-pt-tab:         {{ pt_tablet }}px;
    --eb2-pt-desk:        {{ pt_desktop }}px;
    --eb2-ph-mob:         {{ ph_mobile }}px;
    --eb2-ph-tab:         {{ ph_tablet }}px;
    --eb2-ph-desk:        {{ ph_desktop }}px;
    --eb2-eyebrow-color:  rgba({{ ey_r }},{{ ey_g }},{{ ey_b }},{{ eyebrow_opacity }});
    --eb2-eyebrow-fs:     {{ eyebrow_fs }}px;
    --eb2-eyebrow-lh:     {{ eyebrow_lh }}px;
    --eb2-eyebrow-fw:     {{ eyebrow_fw }};
    --eb2-eyebrow-ls:     calc({{ eyebrow_ls_raw }} * 0.01em);
    --eb2-title-color:    {{ title_color }};
    --eb2-title-fs-d:     {{ title_fs_desktop }}px;
    --eb2-title-fs-m:     {{ title_fs_mobile }}px;
    --eb2-title-fw:       {{ title_fw }};
    --eb2-title-lh:       {{ title_lh_raw }};
    --eb2-title-ls:       {{ title_ls }}em;
    --eb2-subtitle-color: rgba({{ sub_r }},{{ sub_g }},{{ sub_b }},{{ subtitle_opacity }});
    --eb2-subtitle-fs-d:  {{ subtitle_fs_desktop }}px;
    --eb2-subtitle-fs-m:  {{ subtitle_fs_mobile }}px;
    --eb2-subtitle-fw:    {{ subtitle_fw }};
    --eb2-subtitle-lh-d:  {{ subtitle_lh_desktop }}px;
    --eb2-subtitle-lh-m:  {{ subtitle_lh_mobile }}px;
    --eb2-cta-r:          {{ cta_radius }}px;
    --eb2-btn-fs:         {{ btn_fs }}px;
    --eb2-btn-fw:         {{ btn_fw }};
    --eb2-btn-py:         {{ btn_py }}px;
    --eb2-btn-px:         {{ btn_px }}px;
    --eb2-btn-ls:         calc({{ btn_ls_raw }} * 0.01em);
  "
  aria-label="{{ title_text | default: 'Section éditoriale' | escape }}"
>
  {%- comment -%}── Background : image + vidéo ──{%- endcomment -%}
  <div class="eb2__media" aria-hidden="true">
    <picture>
      <source media="(max-width: 767px)" srcset="{{ bg_img_url_sm }}">
      <img
        class="eb2__bg-img"
        src="{{ bg_img_url }}"
        alt=""
        loading="lazy"
        decoding="async"
        width="{{ img_w }}"
        height="{{ img_h }}"
      >
    </picture>
    <video
      class="eb2__video"
      data-src="{{ video_asset }}"
      muted
      playsinline
      loop
      preload="none"
    ></video>
    <div class="eb2__overlay eb2__overlay--{{ overlay_style }}" aria-hidden="true"></div>
  </div>

  {%- comment -%}── Contenu centré ──{%- endcomment -%}
  <div class="eb2__inner eb2__inner--av-{{ content_valign }}">
    <div class="eb2__content eb2__content--{{ content_align }}">

      {%- if eyebrow_text != blank -%}
        <p class="eb2__eyebrow">{{ eyebrow_text | escape }}</p>
      {%- endif -%}

      {%- if title_text != blank -%}
        <h2 class="eb2__title">{{ title_text | escape }}</h2>
      {%- endif -%}

      {%- if subtitle_text != blank -%}
        <p class="eb2__subtitle">{{ subtitle_text | escape }}</p>
      {%- endif -%}

      {%- if cta_label != blank or cta2_label != blank -%}
        <div class="eb2__ctas">
          {%- if cta_label != blank -%}
            <a
              href="{{ cta_url }}"
              class="eb2__cta eb2__cta--{{ cta_style }}"
              {% if cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              aria-label="{{ cta_label | escape }}"
            >
              <span class="eb2__cta-label">{{ cta_label | escape }}</span>
              <span class="eb2__cta-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </a>
          {%- endif -%}
          {%- if cta2_label != blank -%}
            <a
              href="{{ cta2_url }}"
              class="eb2__cta eb2__cta--{{ cta2_style }}"
              {% if cta2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              aria-label="{{ cta2_label | escape }}"
            >
              <span class="eb2__cta-label">{{ cta2_label | escape }}</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

</section>

<style>
/* ═══════════════════════════════════════════════════
   EDITORIAL BANNER 2 — Motion19 — v3.0
   Préfixe .eb2 — Toutes valeurs pilotées via CSS custom properties
═══════════════════════════════════════════════════ */

/* ── Section ── */
.eb2 {
  position:      relative;
  overflow:      hidden;
  height:        var(--eb2-h-d, 800px);
  margin-top:    var(--eb2-mt, 0px);
  margin-bottom: var(--eb2-mb, 0px);
  background:    var(--eb2-bg, var(--color-bg-dark));
}

/* ── Écran moyen ≤ 1300px ── */
@media (max-width: 1300px) {
  .eb2 { height: var(--eb2-h-med, 640px); }
}

/* ── Viewport hauteur réduite ≤ 900px ── */
@media (max-height: 900px) {
  .eb2 { max-height: 696px; padding-top: 64px; }
}

/* ── Mobile ── */
@media (max-width: 767px) {
  .eb2 { height: auto; min-height: var(--eb2-min-h-mob, 520px); padding: 20px 0 64px; }
}

/* ── Grand écran 1500px+ : floating ── */
@media (min-width: 1500px) {
  .eb2--float {
    margin-left:   var(--eb2-large-margin, 40px);
    margin-right:  var(--eb2-large-margin, 40px);
    border-radius: var(--eb2-large-radius, 12px);
    overflow:      hidden;
  }
}

/* ── Media background ── */
.eb2__media {
  position: absolute;
  inset:    0;
  z-index:  0;
}

.eb2__bg-img {
  position:        absolute;
  inset:           0;
  width:           100%;
  height:          100%;
  object-fit:      cover;
  object-position: center;
  display:         block;
  transition:      opacity 700ms cubic-bezier(0.4, 0, 0.2, 1);
  will-change:     opacity;
  z-index:         1;
}

.eb2__video {
  position:        absolute;
  inset:           0;
  width:           100%;
  height:          100%;
  object-fit:      cover;
  object-position: center;
  display:         block;
  opacity:         0;
  transition:      opacity 900ms cubic-bezier(0.4, 0, 0.2, 1) 150ms;
  will-change:     opacity;
  z-index:         2;
}

/* Activation : vidéo visible, image masquée */
.eb2--video-active .eb2__video  { opacity: 1; }
.eb2--video-active .eb2__bg-img { opacity: 0; }

/* ── Overlay styles ── */
.eb2__overlay {
  position:       absolute;
  inset:          0;
  z-index:        3;
  pointer-events: none;
}
/* cinematic (default) — vignette 4 bords */
.eb2__overlay--cinematic {
  background:
    linear-gradient(to bottom,
      rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 0.55)) 0%,
      rgba(0,0,0,0) 30%,
      rgba(0,0,0,0) 60%,
      rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 0.75)) 100%
    ),
    linear-gradient(to right,
      rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 0.35)) 0%,
      transparent 35%,
      transparent 65%,
      rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 0.35)) 100%
    );
}
/* solid — aplat uniforme */
.eb2__overlay--solid {
  background: rgba(0,0,0,var(--eb2-overlay-op, 0.3));
}
/* bottom — dégradé bas vers haut */
.eb2__overlay--bottom {
  background: linear-gradient(to top,
    rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 1.8)) 0%,
    rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 0.4)) 50%,
    transparent 100%
  );
}
/* top — dégradé haut vers bas */
.eb2__overlay--top {
  background: linear-gradient(to bottom,
    rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 1.8)) 0%,
    transparent 60%
  );
}
/* left */
.eb2__overlay--left {
  background: linear-gradient(to right,
    rgba(0,0,0,calc(var(--eb2-overlay-op, 0.3) * 1.8)) 0%,
    transparent 65%
  );
}
/* none */
.eb2__overlay--none { display: none; }

/* ── Inner — conteneur centré (hauteur complète) ── */
.eb2__inner {
  position:        relative;
  z-index:         4;
  height:          100%;
  min-height:      inherit;
  display:         flex;
  align-items:     flex-start;
  justify-content: center;
  padding:         var(--eb2-pt-mob, 20px) var(--eb2-ph-mob, 24px) 0;
}
.eb2__inner--av-start  { align-items: flex-start; }
.eb2__inner--av-center { align-items: center; }
.eb2__inner--av-end    { align-items: flex-end; padding-top: 0; padding-bottom: var(--eb2-pt-mob, 20px); }
@media (min-width: 641px) {
  .eb2__inner--av-end { padding-bottom: var(--eb2-pt-tab, 20px); }
}
@media (min-width: 1025px) {
  .eb2__inner--av-end { padding-bottom: var(--eb2-pt-desk, 72px); }
}

@media (min-width: 641px)  { .eb2__inner { padding: var(--eb2-pt-tab, 20px) var(--eb2-ph-tab, 40px) 0; } }
@media (min-width: 1025px) { .eb2__inner { padding: var(--eb2-pt-desk, 72px) var(--eb2-ph-desk, 80px) 0; } }

/* ── Contenu ── */
.eb2__content {
  display:        flex;
  flex-direction: column;
  gap:            var(--eb2-content-gap, 20px);
  max-width:      var(--eb2-content-mw, 720px);
  width:          100%;
}

.eb2__content--center { align-items: center; text-align: center; margin: 0 auto; }
.eb2__content--left   { align-items: flex-start; text-align: left; }
.eb2__content--right  { align-items: flex-end; text-align: right; margin-left: auto; }

/* ── Eyebrow ── */
.eb2__eyebrow {
  font-family:    var(--font-body, 'Inter', sans-serif);
  color:          var(--eb2-eyebrow-color, rgba(255,255,255,.65));
  font-size:      var(--eb2-eyebrow-fs, 16px);
  line-height:    var(--eb2-eyebrow-lh, 20px);
  font-weight:    var(--eb2-eyebrow-fw, 400);
  letter-spacing: var(--eb2-eyebrow-ls, 0.02em);
  margin:         0;
}

/* ── Titre ── */
.eb2__title {
  font-family:    var(--font-body, 'Inter', sans-serif);
  font-size:      var(--eb2-title-fs-d, 32px);
  font-weight:    var(--eb2-title-fw, 800);
  line-height:    var(--eb2-title-lh, 0.95);
  letter-spacing: var(--eb2-title-ls, -0.03em);
  color:          var(--eb2-title-color, #fff);
  margin:         0;
  text-wrap:      balance;
}

@media (max-width: 767px) {
  .eb2__title { font-size: var(--eb2-title-fs-m, 24px); }
}

/* ── Sous-titre ── */
.eb2__subtitle {
  font-family:    var(--font-body, 'Inter', sans-serif);
  font-size:      var(--eb2-subtitle-fs-d, 20px);
  line-height:    var(--eb2-subtitle-lh-d, 24px);
  font-weight:    var(--eb2-subtitle-fw, 500);
  color:          var(--eb2-subtitle-color, rgba(255,255,255,0.82));
  margin:         0;
}

@media (max-width: 767px) {
  .eb2__subtitle {
    font-size:   var(--eb2-subtitle-fs-m, 16px);
    line-height: var(--eb2-subtitle-lh-m, 22px);
  }
}

/* ── CTAs ── */
.eb2__ctas {
  display:    flex;
  flex-wrap:  wrap;
  gap:        12px;
  margin-top: 8px;
}

.eb2__content--center .eb2__ctas { justify-content: center; }
.eb2__content--right  .eb2__ctas { justify-content: flex-end; }

@media (max-width: 479px) {
  .eb2__ctas { flex-direction: column; }
  .eb2__cta  { width: 100%; justify-content: center; }
}

/* ── Bouton ── */
.eb2__cta {
  display:         inline-flex;
  align-items:     center;
  gap:             10px;
  font-family:     var(--font-body, 'Inter', sans-serif);
  font-size:       var(--eb2-btn-fs, 13px);
  font-weight:     var(--eb2-btn-fw, 600);
  letter-spacing:  var(--eb2-btn-ls, 0.025em);
  text-decoration: none;
  border-radius:   var(--eb2-cta-r, 2px);
  border:          1.5px solid transparent;
  padding:         var(--eb2-btn-py, 14px) var(--eb2-btn-px, 26px);
  transition:      background 200ms ease, color 200ms ease, border-color 200ms ease,
                   transform 180ms ease, box-shadow 200ms ease;
  white-space:     nowrap;
  cursor:          pointer;
}
.eb2__cta-icon {
  display:     flex;
  align-items: center;
  flex-shrink: 0;
  transition:  transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.eb2__cta:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }

/* Solid blanc */
.eb2__cta--solid { background: none; color: #fff;  border-color: #fff;  }
@media (hover: hover) {
  .eb2__cta--solid:hover { background: #fff; color: #000; border-color: #fff; box-shadow: 0 8px 32px rgba(7,135,234,0.36); }
  .eb2__cta--solid:hover .eb2__cta-icon { transform: translateX(4px); }
}

/* Primary */
.eb2__cta--primary { background: var(--color-primary, var(--color-primary)); color: #fff; border-color: var(--color-primary, var(--color-primary)); }
@media (hover: hover) {
  .eb2__cta--primary:hover { background: var(--color-primary-hover); box-shadow: 0 6px 20px rgba(7,135,234,0.38); transform: translateY(-1px); }
  .eb2__cta--primary:hover .eb2__cta-icon { transform: translateX(4px); }
}

/* Outline blanc */
.eb2__cta--outline-white { background: transparent; color: #fff; border-color: #fff; }
@media (hover: hover) {
  .eb2__cta--outline-white:hover { background: #fff; color: var(--color-bg-dark); border-color: #fff; transform: translateY(-1px); }
}

/* Ghost */
.eb2__cta--ghost { background: transparent; color: #fff; border-color: transparent; padding-left: 0; padding-right: 0; gap: 6px; }
@media (hover: hover) {
  .eb2__cta--ghost:hover { opacity: 0.7; }
  .eb2__cta--ghost:hover .eb2__cta-icon { transform: translateX(5px); }
}

/* Glass */
.eb2__cta--glass { background: rgba(255,255,255,0.1); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); color: #fff; border-color: rgba(255,255,255,0.2); }
@media (hover: hover) {
  .eb2__cta--glass:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }
}

/* ── Animations fade-up stagger ── */
.eb2__eyebrow,
.eb2__title,
.eb2__subtitle,
.eb2__ctas {
  opacity:   0;
  transform: translateY(22px);
  transition: opacity 640ms cubic-bezier(0.22, 1, 0.36, 1),
              transform 640ms cubic-bezier(0.22, 1, 0.36, 1);
}

.eb2.is-visible .eb2__eyebrow  { opacity: 1; transform: none; transition-delay: 0ms; }
.eb2.is-visible .eb2__title    { opacity: 1; transform: none; transition-delay: 110ms; }
.eb2.is-visible .eb2__subtitle { opacity: 1; transform: none; transition-delay: 220ms; }
.eb2.is-visible .eb2__ctas     { opacity: 1; transform: none; transition-delay: 340ms; }

/* ── Désactivation animation via classe CSS ── */
.eb2--no-anim .eb2__eyebrow,
.eb2--no-anim .eb2__title,
.eb2--no-anim .eb2__subtitle,
.eb2--no-anim .eb2__ctas {
  opacity: 1 !important;
  transform: none !important;
  transition: none !important;
}

{%- unless anim_enable -%}
.eb2__eyebrow,
.eb2__title,
.eb2__subtitle,
.eb2__ctas { opacity: 1 !important; transform: none !important; transition: none !important; }
{%- endunless -%}

@media (prefers-reduced-motion: reduce) {
  .eb2__eyebrow, .eb2__title, .eb2__subtitle, .eb2__ctas { opacity: 1; transform: none; transition: none; }
  .eb2__bg-img, .eb2__video { transition: none; }
}

{%- if section.settings.custom_css != blank -%}
{{ section.settings.custom_css }}
{%- endif -%}
</style>

<script>
(function () {
  'use strict';
  var sec = document.getElementById('eb2-{{ sid }}');
  if (!sec) return;

  var video      = sec.querySelector('.eb2__video');
  var videoReady = false;
  var animEnable = {{ anim_enable | json }};

  function loadAndPlay() {
    if (videoReady || !video) return;
    var src = video.dataset.src;
    if (!src) return;
    videoReady = true;
    video.src = src;
    video.load();
    var p = video.play();
    if (p !== undefined) {
      p.then(function () { sec.classList.add('eb2--video-active'); })
       .catch(function () { videoReady = false; });
    } else {
      sec.classList.add('eb2--video-active');
    }
  }

  function activate() {
    sec.classList.add('is-visible');
    loadAndPlay();
  }

  if (!animEnable) {
    activate();
  } else if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        activate();
        obs.unobserve(sec);
      });
    }, { threshold: 0.08 });
    obs.observe(sec);
  } else {
    activate();
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (!e.detail || e.detail.sectionId !== '{{ sid }}') return;
    videoReady = false;
    sec.classList.remove('is-visible', 'eb2--video-active');
    if (video) { video.pause(); video.removeAttribute('src'); }
    setTimeout(activate, 80);
  });
})();
</script>

