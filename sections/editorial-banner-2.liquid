    { "type": "range", "id": "img_brightness", "label": "Luminosité (%)",    "min": 50, "max": 150, "step": 5,  "default": 100 },
    { "type": "range", "id": "img_contrast",   "label": "Contraste (%)",     "min": 50, "max": 150, "step": 5,  "default": 100 },
