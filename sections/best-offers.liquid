    { "type": "range", "id": "padding_bottom_mobile",  "label": "Padding bas mobile",     "min": 0, "max": 120, "step": 4, "default": 36,  "unit": "px" },
    { "type": "range", "id": "padding_top_desktop",    "label": "Padding haut desktop",   "min": 0, "max": 120, "step": 4, "default": 52,  "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bas desktop",    "min": 0, "max": 120, "step": 4, "default": 36,  "unit": "px" },
    { "type": "range", "id": "margin_top",    "label": "Marge haut",            "min": 0, "max": 120, "step": 4, "default": 0,   "unit": "px" },
    { "type": "range", "id": "margin_bottom", "label": "Marge bas",             "min": 0, "max": 120, "step": 4, "default": 0,   "unit": "px" },
    { "type": "range", "id": "cards_gap",     "label": "Espacement cartes (px)","min": 0, "max": 48,  "step": 2, "default": 14,  "unit": "px" },

