{{ 'card.css' | asset_url | stylesheet_tag }}
{{ 'embla-carousel-auto-scroll.js' | asset_url | script_tag }}
{%- comment -%}Best Offers — Motion19 — OS 2.0 v1.0{%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign bg_color     = section.settings.bg_color            | default: '#f7f7f8'
  assign card_bg      = section.settings.card_bg             | default: '#ffffff'
  assign text_color   = section.settings.text_color          | default: '#0a0a0a'
  assign title_color  = section.settings.title_color         | default: '#0a0a0a'
  assign desc_color   = section.settings.desc_color          | default: '#666666'
  assign dot_active   = section.settings.dot_active_color    | default: '#0a0a0a'
  assign dot_inactive = section.settings.dot_inactive_color  | default: 'rgba(10,10,10,0.18)'
  assign arrow_color  = section.settings.arrow_color         | default: '#0a0a0a'

  assign autoplay     = section.settings.autoplay_enabled
  assign ap_speed     = section.settings.autoplay_speed      | default: 1.5
  assign ap_delay     = section.settings.autoplay_delay      | default: 0
  assign pause_hover  = section.settings.pause_on_hover
  assign show_arr     = section.settings.show_arrows
  assign show_nav     = section.settings.show_dots
  assign arr_size     = section.settings.arrow_size          | default: 36
  assign dot_size     = section.settings.dot_size            | default: 6
  assign gap_cards    = section.settings.cards_gap           | default: 14
  assign drag_free    = section.settings.drag_free

  assign pt_m         = section.settings.padding_top_mobile     | default: 40
  assign pb_m         = section.settings.padding_bottom_mobile  | default: 56
  assign pt_d         = section.settings.padding_top_desktop    | default: 52
  assign pb_d         = section.settings.padding_bottom_desktop | default: 56
  assign mt           = section.settings.margin_top             | default: 0
  assign mb           = section.settings.margin_bottom          | default: 0
  assign col_gap      = section.settings.column_gap             | default: 40
  assign max_width    = section.settings.section_max_width      | default: 1400

  assign badge_text   = section.settings.badge_text
  assign badge_color  = section.settings.badge_color     | default: '#0787ea'
  assign badge_bg     = section.settings.badge_bg        | default: 'rgba(7,135,234,0.08)'
  assign badge_border = section.settings.badge_border    | default: 'rgba(7,135,234,0.18)'

  assign btn_text     = section.settings.btn_text        | default: 'En savoir plus'
  assign btn_url      = section.settings.btn_url         | default: '/collections/all'
  assign btn_radius   = section.settings.btn_radius      | default: 8
  assign btn_primary  = section.settings.btn_primary_color | default: '#0787ea'

  assign show_discount_badge = section.settings.show_discount_badge
  assign show_atc     = section.settings.show_atc
  assign coll_handle  = section.settings.collection
  assign max_products = section.settings.max_products    | default: 12

  assign custom_id    = section.settings.custom_id
  assign custom_class = section.settings.custom_class
  assign custom_css_val = section.settings.custom_css

  if coll_handle != blank and collections[coll_handle] != blank
    assign products_list = collections[coll_handle].products
  else
    assign products_list = collections.all.products
  endif
-%}

<section
  id="{% if custom_id != blank %}{{ custom_id }}{% else %}bo-{{ sid }}{% endif %}"
  class="bo{% if custom_class != blank %} {{ custom_class }}{% endif %}"
  aria-labelledby="bo-title-{{ sid }}"
  style="
    --bo-bg:           {{ bg_color }};
    --bo-card-bg:      {{ card_bg }};
    --bo-text:         {{ text_color }};
    --bo-title:        {{ title_color }};
    --bo-desc:         {{ desc_color }};
    --bo-dot-active:   {{ dot_active }};
    --bo-dot-inactive: {{ dot_inactive }};
    --bo-arrow-color:  {{ arrow_color }};
    --bo-pt-m:         {{ pt_m }}px;
    --bo-pb-m:         {{ pb_m }}px;
    --bo-pt-d:         {{ pt_d }}px;
    --bo-pb-d:         {{ pb_d }}px;
    --bo-mt:           {{ mt }}px;
    --bo-mb:           {{ mb }}px;
    --bo-gap:          {{ gap_cards }}px;
    --bo-col-gap:      {{ col_gap }}px;
    --bo-max-w:        {{ max_width }}px;
    --bo-arrow-size:   {{ arr_size }}px;
    --bo-dot-size:     {{ dot_size }}px;
    --bo-btn-radius:   {{ btn_radius }}px;
    --bo-btn-primary:  {{ btn_primary }};
    --bo-badge-color:  {{ badge_color }};
    --bo-badge-bg:     {{ badge_bg }};
    --bo-badge-border: {{ badge_border }};
  "
>
  <div class="bo__inner">
    <div class="bo__grid">

      {%- comment -%} ── Left column ── {%- endcomment -%}
      <div class="bo__left">
        {%- if badge_text != blank -%}
          <span class="bo__badge">{{ badge_text }}</span>
        {%- endif -%}
        <h2 class="bo__title" id="bo-title-{{ sid }}">
          {{- section.settings.title | default: 'Meilleures offres' -}}
        </h2>
        {%- if section.settings.description != blank -%}
          <div class="bo__desc">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if btn_text != blank -%}
          <a class="bo__btn" href="{{ btn_url }}">{{ btn_text }}</a>
        {%- endif -%}
      </div>

      {%- comment -%} ── Right column: carousel ── {%- endcomment -%}
      <div class="bo__right">
        <div class="bo__viewport-wrap">
          <div class="bo__viewport" id="bo-viewport-{{ sid }}">
            <ul class="bo__track" id="bo-track-{{ sid }}" role="list" aria-label="Meilleures offres produits">
              {%- for product in products_list limit: max_products -%}
                {%- assign img1 = product.featured_image -%}
                {%- assign img2 = product.images[1] -%}
                {%- assign on_sale = false -%}
                {%- assign discount_pct = 0 -%}
                {%- if product.compare_at_price > product.price -%}
                  {%- assign on_sale = true -%}
                  {%- assign diff = product.compare_at_price | minus: product.price -%}
                  {%- assign discount_pct = diff | times: 100.0 | divided_by: product.compare_at_price | round -%}
                {%- endif -%}
                <li class="bo__item">
                  <article class="m19-card is-visible" aria-label="{{ product.title | escape }}">
                    <a class="m19-card__media m19-card__media--square" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
                      {%- if img1 != blank -%}
                        <img
                          class="m19-card__img m19-card__img--primary"
                          src="{{ img1 | image_url: width: 600 }}"
                          srcset="{{ img1 | image_url: width: 400 }} 400w, {{ img1 | image_url: width: 600 }} 600w, {{ img1 | image_url: width: 800 }} 800w"
                          sizes="(max-width:767px) calc((100vw - 32px) / 1.5), (max-width:1280px) calc((100vw - 48px - 40px) * 0.75 / 2.5), calc((min(100vw, 1400px) - 80px - 40px) * 0.80 / 3.5)"
                          alt="{{ img1.alt | default: product.title | escape }}"
                          loading="{% if forloop.index <= 3 %}eager{% else %}lazy{% endif %}"
                          width="{{ img1.width }}"
                          height="{{ img1.height }}"
                        >
                        {%- if img2 != blank -%}
                          <img
                            class="m19-card__img m19-card__img--hover"
                            src="{{ img2 | image_url: width: 600 }}"
                            alt="{{ img2.alt | default: product.title | escape }}"
                            loading="lazy"
                            width="{{ img2.width }}"
                            height="{{ img2.height }}"
                            aria-hidden="true"
                          >
                        {%- endif -%}
                      {%- else -%}
                        <div class="m19-card__media-fallback" aria-hidden="true"></div>
                      {%- endif -%}

                      {%- if show_discount_badge and on_sale -%}
                        <span class="m19-card__badge bo__discount-badge" aria-hidden="true">-{{ discount_pct }}%</span>
                      {%- endif -%}

                      {%- if show_atc -%}
                        <button
                          class="m19-card__action"
                          type="button"
                          data-variant-id="{{ product.variants.first.id }}"
                          aria-label="Ajouter {{ product.title | escape }} au panier"
                        >
                          <svg class="m19-card__action-icon m19-card__action-icon--bag" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                          </svg>
                          <svg class="m19-card__action-icon m19-card__action-icon--check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                        </button>
                      {%- endif -%}
                    </a>

                    <div class="m19-card__body">
                      <a class="m19-card__name" href="{{ product.url }}">{{ product.title | truncate: 40 }}</a>
                      <div class="m19-card__pricing">
                        {%- if on_sale -%}
                          <s class="m19-card__price--compare">{{ product.compare_at_price | money }}</s>
                        {%- endif -%}
                        <span class="m19-card__price">{{ product.price | money }}</span>
                      </div>
                    </div>
                  </article>
                </li>
              {%- else -%}
                <li class="bo__empty">Aucun produit disponible.</li>
              {%- endfor -%}
            </ul>
          </div>
        </div>

        {%- if show_nav or show_arr -%}
          <div class="bo__footer">
            <div class="bo__footer-left">
              {%- if show_nav -%}
                <div class="bo__dots" id="bo-dots-{{ sid }}" role="tablist" aria-label="Position carousel"></div>
              {%- endif -%}
            </div>
            <div class="bo__footer-right">
              {%- if show_arr -%}
                <div class="bo__arrows">
                  <button class="bo__arrow" id="bo-prev-{{ sid }}" aria-label="Offres précédentes" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                  </button>
                  <button class="bo__arrow" id="bo-next-{{ sid }}" aria-label="Offres suivantes" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </button>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- if custom_css_val != blank -%}
  <style>#bo-{{ sid }}{ {{ custom_css_val }} }</style>
{%- endif -%}

<style>
/* ═══════════════════════════════════════════════════════
   Best Offers — bo — Motion19 OS 2.0 v1.0
   Grid: mobile 1col | tablet 1/4+3/4 | desktop 1/5+4/5
   ═══════════════════════════════════════════════════════ */

.bo {
  --bo-pad:    16px;
  --bo-ease:   cubic-bezier(0.4, 0, 0.2, 1);
  /* mobile: colonne pleine largeur, 1.5 cards visibles → hint slide suivant */
  --bo-card-w: calc((100vw - 32px - var(--bo-gap, 14px)) / 1.5);

  background:    var(--bo-bg, #f7f7f8);
  color:         var(--bo-text, #0a0a0a);
  margin-top:    var(--bo-mt, 0);
  margin-bottom: var(--bo-mb, 0);
}

/* ── Inner ── */
.bo__inner {
  max-width: var(--bo-max-w, 1400px);
  margin: 0 auto;
  padding-top:    var(--bo-pt-m, 40px);
  padding-bottom: var(--bo-pb-m, 56px);
  padding-left:   var(--bo-pad);
  padding-right:  var(--bo-pad);
}

/* ── Grid: mobile = 1 column ── */
.bo__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--bo-col-gap, 40px);
}

/* ── Tablet 768–1280px : 1/4 + 3/4, 2.5 cards visibles ── */
@media (min-width: 768px) {
  .bo {
    --bo-pad: 24px;
    /* colonne droite = 3/4 de (100vw - 2*pad - col-gap) ; 2.5 cards visibles */
    --bo-card-w: calc(((100vw - 48px - var(--bo-col-gap, 40px)) * 0.75 - (1.5 * var(--bo-gap, 14px))) / 2.5);
  }
  .bo__inner {
    padding-top:    var(--bo-pt-d, 52px);
    padding-bottom: var(--bo-pb-d, 56px);
  }
  .bo__grid {
    grid-template-columns: 1fr 3fr;
    align-items: center;
  }
}

/* ── Desktop ≥1281px : 1/5 + 4/5, 3.5 cards visibles ── */
@media (min-width: 1281px) {
  .bo {
    --bo-pad: 40px;
    /* colonne droite = 4/5 de (max-w - 2*pad - col-gap) ; 3.5 cards visibles */
    --bo-card-w: calc(((min(100vw, var(--bo-max-w, 1400px)) - 80px - var(--bo-col-gap, 40px)) * 0.80 - (2.5 * var(--bo-gap, 14px))) / 3.5);
  }
  .bo__grid {
    grid-template-columns: 1fr 4fr;
  }
}

/* ══════════════════════════
   LEFT COLUMN
   ══════════════════════════ */
.bo__left {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding-bottom: 8px;
}

@media (min-width: 768px) {
  .bo__left {
    gap: 20px;
    padding-right: 8px;
  }
}

/* Badge */
.bo__badge {
  display: inline-block;
  align-self: flex-start;
  padding: 4px 12px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border-radius: 50px;
  line-height: 1.6;
  color: var(--bo-badge-color, #0787ea);
  background: var(--bo-badge-bg, rgba(7,135,234,0.08));
  border: 1px solid var(--bo-badge-border, rgba(7,135,234,0.18));
}

/* Title */
.bo__title {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: clamp(1.4rem, 3vw, 2.4rem);
  font-weight: 800;
  letter-spacing: -0.035em;
  line-height: 1.1;
  color: var(--bo-title, #0a0a0a);
  margin: 0;
}

/* Description */
.bo__desc {
  font-size: 0.875rem;
  line-height: 1.65;
  color: var(--bo-desc, #666);
  max-width: 38ch;
}
.bo__desc p { margin: 0 0 0.5em; }
.bo__desc p:last-child { margin-bottom: 0; }

/* Button outline */
.bo__btn {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  gap: 8px;
  padding: 10px 22px;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  border-radius: var(--bo-btn-radius, 999px);
  border: 1.5px solid #0a0a0a;
  background: transparent;
  color: #0a0a0a;
  text-decoration: none;
  cursor: pointer;
  transition:
    background 200ms var(--bo-ease),
    color      200ms var(--bo-ease),
    border-color 200ms var(--bo-ease);
  white-space: nowrap;
}
.bo__btn:hover {
  background:   var(--bo-btn-primary, #0787ea);
  border-color: var(--bo-btn-primary, #0787ea);
  color: #fff;
}
.bo__btn:focus-visible {
  outline: 2px solid var(--bo-btn-primary, #0787ea);
  outline-offset: 2px;
}

/* ══════════════════════════
   RIGHT COLUMN — CAROUSEL
   ══════════════════════════ */
.bo__right {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* Cards toujours visibles — pas de dépendance JS pour l'affichage */
.bo .m19-card {
  opacity: 1;
  transform: none;
}

/* Viewport wrap — clip X, keep Y visible for card shadows */
.bo__viewport-wrap {
  overflow-x: clip;
  overflow-y: visible;
}

.bo__viewport {
  overflow-x: visible;
  overflow-y: visible;
  cursor: grab;
  user-select: none;
  -webkit-user-select: none;
}
.bo__viewport:active { cursor: grabbing; }

/* Track */
.bo__track {
  display: flex;
  gap: var(--bo-gap, 14px);
  padding-top: 20px;
  padding-bottom: 28px;
  margin: 0;
  padding-left: 0;
  padding-right: 4px;
  list-style: none;
}

/* Items */
.bo__item {
  flex: 0 0 var(--bo-card-w);
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.bo__item .m19-card {
  flex: 1;
  height: 100%;
  background: var(--bo-card-bg, #fff);
}

/* Discount badge */
.bo__discount-badge {
  background: #D74E09 !important;
  color: #fff !important;
  border: none !important;
  font-size: 9px !important;
  font-weight: 700 !important;
  letter-spacing: 0.05em !important;
  padding: 3px 8px !important;
  border-radius: 0.75rem !important;
}

.bo__empty { padding: 24px; font-size: 0.875rem; color: #aaa; }

/* ── Footer ── */
.bo__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 0 0;
  gap: 16px;
}

/* Mobile ≤767px : masquer dots, centrer flèches */
@media (max-width: 767px) {
  .bo__footer        { justify-content: center; }
  .bo__footer-left   { display: none; }
  .bo__footer-right  { margin: 0 auto; }
}

.bo__footer-left  { display: flex; align-items: center; }
.bo__footer-right { display: flex; align-items: center; }

/* Arrows */
.bo__arrows { display: flex; gap: 4px; }
.bo__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--bo-arrow-size, 36px);
  height: var(--bo-arrow-size, 36px);
  border-radius: 0.75rem;
  border: none;
  background: none;
  color: var(--bo-arrow-color, #0a0a0a);
  cursor: pointer;
  transition: background 180ms var(--bo-ease), color 180ms var(--bo-ease);
  padding: 0;
}
.bo__arrow:hover { background: rgba(10,10,10,0.07); }
.bo__arrow:disabled { opacity: 0.28; cursor: default; pointer-events: none; }
.bo__arrow:focus-visible { outline: 2px solid #0787ea; outline-offset: 2px; }

/* Dots */
.bo__dots { display: flex; align-items: center; gap: 8px; }
.bo__dot {
  width: var(--bo-dot-size, 6px);
  height: var(--bo-dot-size, 6px);
  padding: 0;
  border: none;
  border-radius: 50%;
  background: var(--bo-dot-inactive, rgba(10,10,10,0.18));
  cursor: pointer;
  transition:
    width       280ms var(--bo-ease),
    border-radius 280ms var(--bo-ease),
    background  280ms var(--bo-ease),
    transform   280ms ease,
    opacity     280ms ease;
}
.bo__dot--active {
  width: calc(var(--bo-dot-size, 6px) * 3.5);
  border-radius: 3px;
  background: var(--bo-dot-active, #0a0a0a);
}
.bo__dot--small  { transform: scale(0.6); opacity: 0.5; }
.bo__dot--hidden { display: none; }
.bo__dot:focus-visible { outline: 2px solid #0787ea; outline-offset: 2px; }
</style>

<script>
(function () {
  'use strict';
  var sid       = '{{ sid }}';
  var autoplay  = {{ autoplay | json }};
  var apSpeed   = {{ ap_speed }};
  var apDelay   = {{ ap_delay }};
  var pauseHover = {{ pause_hover | json }};

  function init() {
    var section  = document.getElementById('bo-{{ sid }}');
    if (!section || !window.EmblaCarousel) return;

    var viewport = document.getElementById('bo-viewport-' + sid);
    if (!viewport) return;

    var dotsWrap = document.getElementById('bo-dots-' + sid);
    var btnPrev  = document.getElementById('bo-prev-' + sid);
    var btnNext  = document.getElementById('bo-next-' + sid);
    var dots     = [];

    var plugins = [];
    if (autoplay && window.EmblaCarouselAutoScroll) {
      plugins.push(window.EmblaCarouselAutoScroll({
        direction:       'forward',
        speed:           apSpeed,
        startDelay:      apDelay,
        playOnInit:      true,
        stopOnMouseEnter: pauseHover,
        stopOnInteraction: true,
        stopOnFocusIn:   true
      }));
    }

    var embla = window.EmblaCarousel(viewport, {
      loop:           true,
      align:          'start',
      slidesToScroll: 1,
      dragFree:       {{ drag_free | default: false | json }},
      containScroll:  false
    }, plugins);

    /* ── Dots ── */
    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      dots = [];
      embla.scrollSnapList().forEach(function (_, i) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bo__dot';
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-label', 'Page ' + (i + 1));
        btn.addEventListener('click', function () {
          embla.scrollTo(i);
          if (autoplay && embla.plugins().autoScroll) embla.plugins().autoScroll.stop();
        });
        dotsWrap.appendChild(btn);
        dots.push(btn);
      });
      updateDots();
    }

    function updateDots() {
      var maxV = 5;
      var idx  = embla.selectedScrollSnap();
      dots.forEach(function (d, i) {
        var active = i === idx;
        d.className = 'bo__dot' + (active ? ' bo__dot--active' : '');
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      if (dots.length > maxV) {
        var half  = Math.floor(maxV / 2);
        var start = Math.max(0, idx - half);
        var end   = Math.min(dots.length, start + maxV);
        if (end - start < maxV) start = Math.max(0, end - maxV);
        dots.forEach(function (d, i) {
          if (i < start || i >= end) {
            if (i === start - 1 || i === end) d.classList.add('bo__dot--small');
            else d.classList.add('bo__dot--hidden');
          }
        });
      }
    }

    embla.on('select', updateDots);
    embla.on('reInit', buildDots);
    buildDots();

    /* ── Arrows ── */
    if (btnPrev) btnPrev.addEventListener('click', function () {
      embla.scrollPrev();
      if (autoplay && embla.plugins().autoScroll) embla.plugins().autoScroll.stop();
    });
    if (btnNext) btnNext.addEventListener('click', function () {
      embla.scrollNext();
      if (autoplay && embla.plugins().autoScroll) embla.plugins().autoScroll.stop();
    });

    /* ── ATC ── */
    section.addEventListener('click', function (e) {
      var btn = e.target.closest('.m19-card__action');
      if (!btn || btn.disabled) return;
      e.preventDefault();
      e.stopPropagation();
      var id = btn.dataset.variantId;
      if (!id) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.status) { btn.disabled = false; return; }
          btn.classList.add('is-added');
          var counter = document.querySelector('[data-cart-count]');
          if (counter) fetch('/cart.js').then(function (r) { return r.json(); }).then(function (c) { counter.textContent = c.item_count; });
          setTimeout(function () { btn.classList.remove('is-added'); btn.disabled = false; }, 2200);
        })
        .catch(function () { btn.disabled = false; });
    });

    /* ── Reveal cards ── */
    function showAllCards() {
      viewport.querySelectorAll('.m19-card').forEach(function (c) { c.classList.add('is-visible'); });
    }
    showAllCards();
    embla.on('init',   showAllCards);
    embla.on('reInit', showAllCards);
    embla.on('select', showAllCards);
  }

  function waitAndInit() {
    var elapsed = 0;
    var limit   = 5000;
    var step    = 60;
    (function poll() {
      if (window.EmblaCarousel) {
        if (!autoplay || window.EmblaCarouselAutoScroll) {
          init();
        } else if (elapsed < limit) {
          elapsed += step;
          setTimeout(poll, step);
        } else {
          init(); /* fallback sans autoscroll */
        }
      } else if (elapsed < limit) {
        elapsed += step;
        setTimeout(poll, step);
      }
    }());
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', waitAndInit);
  else waitAndInit();
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sid) waitAndInit();
  });
})();
</script>

