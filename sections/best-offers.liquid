    { "type": "textarea", "id": "subtitle",  "label": "Sous-titre" },

    { "type": "header", "content": "Typographie" },
    { "type": "range", "id": "title_font_size", "label": "Taille titre (px)", "min": 16, "max": 56, "step": 1, "default": 32, "unit": "px" },
    {
      "type": "select", "id": "title_font_weight", "label": "Graisse titre", "default": "800",
      "options": [
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Moyen (500)" },
        { "value": "600", "label": "Semi-gras (600)" },
        { "value": "700", "label": "Gras (700)" },
        { "value": "800", "label": "Extra-gras (800)" }
      ]
    },
    { "type": "range", "id": "eyebrow_font_size",  "label": "Taille eyebrow (px)",  "min": 8,  "max": 18, "step": 1, "default": 11, "unit": "px" },
    { "type": "range", "id": "subtitle_font_size", "label": "Taille sous-titre (px)","min": 10, "max": 24, "step": 1, "default": 14, "unit": "px" },
    { "type": "color", "id": "subtitle_color", "label": "Couleur sous-titre", "default": "#666666" },

    { "type": "header", "content": "Structure" },
    {
      "type": "select", "id": "header_align", "label": "Alignement header", "default": "left",
      "options": [
        { "value": "left",   "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Droite" }
      ]
    },
    { "type": "range", "id": "section_max_width", "label": "Largeur max section (px)", "min": 960, "max": 1920, "step": 40, "default": 1400 },
    { "type": "checkbox", "id": "separator_enabled", "label": "Afficher séparateur", "default": false },
    { "type": "text",     "id": "separator_text",    "label": "Texte séparateur" },
    {
      "type": "select", "id": "separator_style", "label": "Style séparateur", "default": "line",
      "options": [
        { "value": "line",   "label": "Ligne" },
        { "value": "dashed", "label": "Tirets" },
        { "value": "dots",   "label": "Centré" }
      ]
    },

    { "type": "header", "content": "Produits" },
    { "type": "collection", "id": "collection",   "label": "Collection", "info": "Vide = toutes" },
    { "type": "range",      "id": "max_products", "label": "Nb max produits", "min": 4, "max": 24, "step": 2, "default": 12 },

    { "type": "header", "content": "Onglets" },
    { "type": "checkbox", "id": "show_tabs", "label": "Afficher les onglets", "default": true },

    { "type": "header", "content": "Carte produit" },
    {
      "type": "select", "id": "image_ratio", "label": "Proportion image", "default": "4 / 5",
      "options": [
        { "value": "1 / 1",  "label": "Carré (1:1)" },
        { "value": "4 / 5",  "label": "Portrait (4:5)" },
        { "value": "3 / 4",  "label": "Haut (3:4)" },
        { "value": "16 / 9", "label": "Large (16:9)" }
      ]
    },
    {
      "type": "select", "id": "image_fit", "label": "Recadrage image", "default": "contain",
      "options": [
        { "value": "contain", "label": "Contenir" },
        { "value": "cover",   "label": "Couvrir" }
      ]
    },
    { "type": "range",    "id": "card_border_radius", "label": "Rayon bordure carte (px)", "min": 0,  "max": 32, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "card_show_border",   "label": "Bordure carte",            "default": true },
    { "type": "color",    "id": "card_border_color",  "label": "Couleur bordure",          "default": "#e8e8e8" },
    { "type": "checkbox", "id": "card_show_shadow",   "label": "Ombre carte",              "default": true },
    { "type": "color",    "id": "card_name_color",    "label": "Couleur nom produit",      "default": "#0a0a0a" },
    { "type": "color",    "id": "card_price_color",   "label": "Couleur prix",             "default": "#0a0a0a" },

