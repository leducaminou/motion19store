<script>
(function () {
  'use strict';

  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Pricing data ── */
  var pdpVariants   = {{ product.variants | json }};
  var pdpUnitCents  = {{ current_variant.price | json }};
  var pdpVariantId  = {{ current_variant.id | json }};
  var pdpCurrency   = '{{ shop.currency }}';

  /* ── Money formatter ── */
  function fmtMoney(cents) {
    return pdpCurrency + ' ' + (cents / 100).toFixed(2);
  }

  /* ────────────────────────────────────────────
     QTY SELECTOR
  ──────────────────────────────────────────── */
  window.pdpChangeQty = function (delta) {
    var inp = document.getElementById('pdpQtyInput');
    if (!inp) return;
    var val = Math.max(1, (parseInt(inp.value, 10) || 1) + delta);
    inp.value = val;
    var total = document.getElementById('pdpTotalPrice');
    if (total) total.textContent = fmtMoney(pdpUnitCents * val);
  };

  /* ────────────────────────────────────────────
     VARIANT PILLS
  ──────────────────────────────────────────── */
  window.pdpSelectPill = function (pill) {
    var group = pill.closest('.pdp__pills');
    if (!group) return;
    group.querySelectorAll('.pdp__pill').forEach(function (p) {
      p.classList.remove('is-selected');
      p.setAttribute('aria-checked', 'false');
      p.setAttribute('tabindex', '-1');
    });
    pill.classList.add('is-selected');
    pill.setAttribute('aria-checked', 'true');
    pill.setAttribute('tabindex', '0');
    pdpUpdateVariant();
  };

  function pdpGetSelectedOptions() {
    var options = {};
    document.querySelectorAll('.pdp__pill.is-selected').forEach(function (p) {
      options[p.dataset.option] = p.dataset.value;
    });
    return options;
  }

  function pdpUpdateVariant() {
    var selected = pdpGetSelectedOptions();
    var matched = null;

    for (var i = 0; i < pdpVariants.length; i++) {
      var v      = pdpVariants[i];
      var match  = true;
      var optMap = {
        [{{ product.options[0] | handleize | json }}]: v.option1,
        [{{ product.options[1] | handleize | json }}]: v.option2,
        [{{ product.options[2] | handleize | json }}]: v.option3
      };
      for (var key in selected) {
        if (optMap[key] !== selected[key]) { match = false; break; }
      }
      if (match) { matched = v; break; }
    }

    if (!matched) return;
    pdpVariantId = matched.id;
    pdpUnitCents = matched.price;

    /* Batch all DOM writes in a single rAF */
    requestAnimationFrame(function () {
      var btn = document.getElementById('pdpAtcBtn');
      if (btn) btn.dataset.variantId = matched.id;

      var priceEl = document.getElementById('pdpPrice');
      if (priceEl) priceEl.textContent = fmtMoney(matched.price);

      var qty = parseInt((document.getElementById('pdpQtyInput') || {}).value, 10) || 1;
      var total = document.getElementById('pdpTotalPrice');
      if (total) total.textContent = fmtMoney(matched.price * qty);

      var stickyP = document.getElementById('pdpStickyPrice');
      if (stickyP) stickyP.textContent = fmtMoney(matched.price);

      var stockEl = document.getElementById('pdpStock');
      if (stockEl) {
        stockEl.className = 'pdp__stock pdp__stock--' + (matched.available ? 'in' : 'out');
        stockEl.querySelector('.pdp__stock-label').textContent = matched.available ? 'En stock' : 'Épuisé';
      }

      if (window.history && window.history.replaceState) {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', matched.id);
        window.history.replaceState({}, '', url.toString());
      }
    });
  }

  /* ────────────────────────────────────────────
     ADD TO CART
  ──────────────────────────────────────────── */
  window.pdpAddToCart = function () {
    var btn = document.getElementById('pdpAtcBtn');
    var qty = parseInt((document.getElementById('pdpQtyInput') || {}).value, 10) || 1;
    if (!btn || btn.disabled) return;

    var original = btn.innerHTML;
    btn.disabled = true;
    btn.classList.add('is-loading');
    btn.innerHTML = '<span aria-hidden="true" style="display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:#fff;border-radius:50%;animation:pdpSpin 0.65s linear infinite;"></span><span style="margin-left:0.5rem;">Ajout...</span>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: pdpVariantId, quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      btn.disabled = false;
      btn.classList.remove('is-loading');
      btn.innerHTML = original;

      if (data.status) {
        alert('Erreur : ' + (data.description || 'Veuillez réessayer.'));
        return;
      }

      /* Feedback visuel is-added sur le bouton principal + les deux boutons sticky */
      var stickyBtns = document.querySelectorAll('.pdp__sticky-btn');
      var allBtns = [btn].concat(Array.prototype.slice.call(stickyBtns));
      allBtns.forEach(function (b) {
        if (!b) return;
        b.classList.add('is-added');
        b.disabled = true;
      });
      setTimeout(function () {
        allBtns.forEach(function (b) {
          if (!b) return;
          b.classList.remove('is-added');
          b.disabled = false;
        });
      }, 2500);

      /* Update cart badge and dispatch unified event */
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (c) {
          document.querySelectorAll('[data-cart-count]').forEach(function (el) {
            el.textContent = c.item_count;
          });
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { item_count: c.item_count } }));
        });
      if (window.M19Cart) window.M19Cart.refreshBadge();

      /* Google Ads — conversion "Ajout au panier" */
      if (typeof gtag === 'function') {
        var gadsPayload = {
          'send_to': 'AW-769885484',
          'value': (pdpUnitCents * qty) / 100,
          'currency': pdpCurrency
        };
        {% if customer %}
        gadsPayload['user_data'] = {
          'email_address': '{{ customer.email | downcase | strip | escape }}',
          'phone_number': '{{ customer.phone | strip | escape }}',
          'address': {
            'first_name': '{{ customer.first_name | downcase | strip | escape }}',
            'last_name': '{{ customer.last_name | downcase | strip | escape }}'
          }
        };
        {% endif %}
        gtag('event', 'conversion', gadsPayload);
      }

      /* Show modal */
      var qtyEl = document.getElementById('pdpCartModalQty');
      if (qtyEl) qtyEl.textContent = 'Quantité : ' + qty;
      var modal = document.getElementById('pdpCartModal');
      if (modal) {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        modal.querySelector('.pdp__cart-modal-close').focus();
      }
    })
    .catch(function () {
      btn.disabled = false;
      btn.classList.remove('is-loading');
      btn.innerHTML = original;
    });
  };

  /* ────────────────────────────────────────────
     CART MODAL
  ──────────────────────────────────────────── */
  window.pdpCloseCartModal = function () {
    var modal = document.getElementById('pdpCartModal');
    if (modal) {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
    }
  };

  /* Close on backdrop click */
  document.addEventListener('DOMContentLoaded', function () {
    var modal = document.getElementById('pdpCartModal');
    if (modal) {
      modal.addEventListener('click', function (e) {
        if (e.target === modal) pdpCloseCartModal();
      });
    }
  });

  /* ────────────────────────────────────────────
     DESKTOP GALLERY — preload on hover
  ──────────────────────────────────────────── */
  (function () {
    document.querySelectorAll('.pdp__gallery-thumb').forEach(function (thumb) {
      thumb.addEventListener('mouseenter', function () {
        var src = thumb.getAttribute('onclick');
        var match = src && src.match(/pdpSetImage\(this,'([^']+)'/);
        if (match && match[1]) {
          var preload = new Image();
          preload.src = match[1];
        }
      }, { passive: true });
    });
  })();
  window.pdpSetImage = function (thumb, src, alt, index) {
    var wrap = document.getElementById('pdpMainWrap');
    var img  = document.getElementById('pdpMainImg');
    if (!wrap || !img) return;

    document.querySelectorAll('.pdp__gallery-thumb').forEach(function (t) {
      t.classList.remove('is-active');
      t.setAttribute('aria-pressed', 'false');
    });
    thumb.classList.add('is-active');
    thumb.setAttribute('aria-pressed', 'true');

    img.onload = null;
    img.classList.add('is-switching');

    setTimeout(function () {
      img.onload = function () {
        img.classList.remove('is-switching');
        img.onload = null;
      };
      img.srcset = thumb.dataset.srcset || '';
      img.src    = src;
      img.alt    = alt;
      img.dataset.index = index;
      if (img.complete) {
        img.classList.remove('is-switching');
        img.onload = null;
      }
    }, 50);

    wrap.onclick = function () { pdpOpenLightbox(index); };
    wrap.setAttribute('aria-label', 'Agrandir l\'image ' + (index + 1));
  };

  /* ────────────────────────────────────────────
     SHARE — copie du lien
  ──────────────────────────────────────────── */
  window.pdpCopyLink = function (btn) {
    if (!btn || btn.disabled) return;
    navigator.clipboard.writeText(window.location.href).then(function () {
      btn.classList.add('is-copied');
      btn.disabled = true;
      setTimeout(function () {
        btn.classList.remove('is-copied');
        btn.disabled = false;
      }, 2000);
    });
  };

  /* ────────────────────────────────────────────
     DESCRIPTION READ MORE
  ──────────────────────────────────────────── */
  window.pdpToggleDescription = function (btn) {
    var desc = document.getElementById('pdpDescription');
    if (!desc) return;
    var expanded = desc.classList.toggle('is-expanded');
    btn.classList.toggle('is-expanded', expanded);
    btn.setAttribute('aria-expanded', expanded.toString());
    btn.querySelector('.pdp__read-more-text').textContent = expanded ? 'Lire moins' : 'Lire plus';
  };

  /* ────────────────────────────────────────────
     STICKY ATC — rAF throttled scroll
  ──────────────────────────────────────────── */
  (function () {
    var sticky  = document.getElementById('pdpStickyAtc');
    var trigger = document.getElementById('pdpAtcBtn');
    if (!sticky || !trigger) return;

    var rafPending = false;
    function onScroll() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(function () {
        rafPending = false;
        var below = trigger.getBoundingClientRect().bottom < 0;
        sticky.classList.toggle('is-visible', below);
        sticky.setAttribute('aria-hidden', below ? 'false' : 'true');
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

  /* ────────────────────────────────────────────
     LIGHTBOX
  ──────────────────────────────────────────── */
  var _lbSwiper = null;
  var _lbThumbsSwiper = null;

  window.pdpOpenLightbox = function (index) {
    var lb = document.getElementById('pdpLightbox');
    if (!lb) return;
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    if (!_lbThumbsSwiper && typeof Swiper !== 'undefined') {
      _lbThumbsSwiper = new Swiper('#pdpLbThumbs', {
        slidesPerView: 'auto',
        spaceBetween: 6,
        watchSlidesProgress: true,
        freeMode: !reducedMotion,
        observer: true,
        resizeObserver: true,
      });
    }

    if (!_lbSwiper && typeof Swiper !== 'undefined') {
      _lbSwiper = new Swiper('#pdpLbSwiper', {
        initialSlide: index,
        slidesPerView: 1,
        speed: reducedMotion ? 0 : 300,
        grabCursor: true,
        keyboard: { enabled: true },
        observer: true,
        resizeObserver: true,
        watchSlidesProgress: true,
        navigation: { nextEl: '#pdpLbNext', prevEl: '#pdpLbPrev' },
        thumbs: { swiper: _lbThumbsSwiper },
        on: {
          slideChange: function () { pdpUpdateLbCounter(this.realIndex); },
          init:        function () { pdpUpdateLbCounter(this.realIndex); },
        },
      });
    } else if (_lbSwiper) {
      _lbSwiper.slideTo(index, 0);
      pdpUpdateLbCounter(index);
    }

    var closeBtn = document.getElementById('pdpLightboxClose');
    if (closeBtn) closeBtn.focus();
  };

  function pdpCloseLightbox() {
    var lb = document.getElementById('pdpLightbox');
    if (!lb) return;
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function pdpUpdateLbCounter(index) {
    var total = document.querySelectorAll('#pdpLbSwiper .swiper-slide').length;
    var el    = document.getElementById('pdpLightboxCounter');
    if (el) el.textContent = (index + 1) + ' / ' + total;
  }

  /* Wire lightbox close controls */
  document.addEventListener('DOMContentLoaded', function () {
    var closeBtn   = document.getElementById('pdpLightboxClose');
    var backdrop   = document.getElementById('pdpLightboxBackdrop');

    if (closeBtn)  closeBtn.addEventListener('click',   pdpCloseLightbox);
    if (backdrop)  backdrop.addEventListener('click',   pdpCloseLightbox);

    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      pdpCloseLightbox();
      var cm = document.getElementById('pdpConseilOverlay');
      if (cm && cm.classList.contains('is-open')) pdpCloseConseilModal();
    });

    /* Conseil modal wiring */
    var conseilOverlay = document.getElementById('pdpConseilOverlay');
    var conseilCloseBtn = document.getElementById('pdpConseilClose');
    if (conseilCloseBtn) conseilCloseBtn.addEventListener('click', pdpCloseConseilModal);
    if (conseilOverlay) {
      conseilOverlay.addEventListener('click', function (e) {
        if (e.target === conseilOverlay) pdpCloseConseilModal();
      });
    }

    document.querySelectorAll('.pdp__conseil-topic-input').forEach(function (inp) {
      inp.addEventListener('change', function () {
        this.closest('.pdp__conseil-topic').classList.toggle('is-checked', this.checked);
      });
    });

    var conseilTa = document.getElementById('pdpConseilTextarea');
    if (conseilTa) {
      conseilTa.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 180) + 'px';
      });
    }

    /* WhatsApp URL */
    var waBtn = document.getElementById('pdpWaBtn');
    if (waBtn) {
      {%- if whatsapp_number != blank -%}
        var waMsg = encodeURIComponent('Bonjour, je voudrais en savoir plus sur ce produit : {{ product.title | escape }} — ' + window.location.href);
        waBtn.href = 'https://wa.me/{{ whatsapp_number | remove: "+" | remove: " " | remove: "-" }}?text=' + waMsg;
      {%- else -%}
        waBtn.style.display = 'none';
      {%- endif -%}
    }

  });

  /* ────────────────────────────────────────────
     SWIPER INIT — polling (Swiper may load after DOMContentLoaded)
  ──────────────────────────────────────────── */
  (function pdpSwiperPoll() {
    var waited = 0;
    (function tryInit() {
      if (typeof Swiper === 'undefined') {
        if (waited < 5000) { waited += 50; setTimeout(tryInit, 50); }
        return;
      }

      var thumbsStripEl = document.getElementById('pdpThumbsStrip');
      var thumbsStrip   = null;
      if (thumbsStripEl) {
        thumbsStrip = new Swiper(thumbsStripEl, {
          slidesPerView: 'auto',
          spaceBetween: {{ thumb_gap }},
          watchSlidesProgress: true,
          freeMode: !reducedMotion,
          observer: true,
          observeParents: true,
          resizeObserver: true,
        });
      }

      var mainOpts = {
        slidesPerView: 1,
        speed: reducedMotion ? 0 : 380,
        grabCursor: true,
        observer: true,
        observeParents: true,
        resizeObserver: true,
        watchSlidesProgress: true,
        on: {
          slideChange: function () {
            var i   = this.realIndex + 1;
            var cnt = this.slides.length;
            var ctr = document.getElementById('pdpSwiperCounter');
            if (ctr) ctr.textContent = i + ' / ' + cnt;
            var prevBtn = document.getElementById('pdpPrev');
            var nextBtn = document.getElementById('pdpNext');
            if (prevBtn) prevBtn.disabled = i === 1;
            if (nextBtn) nextBtn.disabled = i === cnt;
          },
          init: function () {
            var prevBtn = document.getElementById('pdpPrev');
            var nextBtn = document.getElementById('pdpNext');
            if (prevBtn) prevBtn.disabled = true;
            if (nextBtn) nextBtn.disabled = this.slides.length <= 1;
          },
        },
      };
      if (thumbsStrip) mainOpts.thumbs = { swiper: thumbsStrip };

      var mainSwiper = new Swiper('#pdpSwiper', mainOpts);

      var prevBtn = document.getElementById('pdpPrev');
      var nextBtn = document.getElementById('pdpNext');
      if (prevBtn) prevBtn.addEventListener('click', function () { mainSwiper.slidePrev(); }, { passive: true });
      if (nextBtn) nextBtn.addEventListener('click', function () { mainSwiper.slideNext(); }, { passive: true });
    }());
  }());

  /* ATC spin keyframe */
  if (!document.getElementById('pdpSpinStyle')) {
    var s = document.createElement('style');
    s.id = 'pdpSpinStyle';
    s.textContent = '@keyframes pdpSpin { to { transform: rotate(360deg); } }';
    document.head.appendChild(s);
  }

  /* ────────────────────────────────────────────
     CONSEIL MODAL
  ──────────────────────────────────────────── */
  window.pdpOpenConseilModal = function () {
    var overlay = document.getElementById('pdpConseilOverlay');
    if (!overlay) return;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(function () {
      var close = document.getElementById('pdpConseilClose');
      if (close) close.focus();
    }, 60);
  };

  window.pdpCloseConseilModal = function () {
    var overlay = document.getElementById('pdpConseilOverlay');
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var trigger = document.getElementById('pdpConseilBtn');
    if (trigger) trigger.focus();
  };

  window.pdpSendConseilWA = function () {
    var topics = [];
    document.querySelectorAll('#pdpConseilOverlay .pdp__conseil-topic-input:checked').forEach(function (inp) {
      topics.push(inp.value);
    });
    var textarea = document.getElementById('pdpConseilTextarea');
    var freeText = textarea ? textarea.value.trim() : '';

    var variant = '';
    var selPill = document.querySelector('.pdp__pill.is-selected');
    if (selPill) variant = selPill.dataset.value || '';

    var msg = 'Bonjour, je souhaite obtenir des conseils concernant ce produit :\n\n';
    msg += {{ product.title | json }} + '\n\nLien :\n' + window.location.href;
    if (variant) msg += '\n\nVariante :\n' + variant;
    if (topics.length) msg += '\n\nThèmes sélectionnés :\n' + topics.map(function (t) { return '— ' + t; }).join('\n');
    if (freeText) msg += '\n\nMon besoin :\n' + freeText;
    msg += '\n\nMerci.';

    var waNum = '{{ conseil_wa_num | remove: "+" | remove: " " | remove: "-" }}';
    var url = 'https://wa.me/' + (waNum || '') + '?text=' + encodeURIComponent(msg);
    window.open(url, '_blank', 'noopener,noreferrer');
  };

}());
</script>

