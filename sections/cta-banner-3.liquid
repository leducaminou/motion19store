{%- comment -%} CTA Banner 2 — Motion19 — 2-col dark, image droite {%- endcomment -%}

{%- render 'section-settings', section: section, prefix: 'cb3' -%}

{%- liquid
  assign has_picker_img = false
  if section.settings.image != blank
    assign has_picker_img = true
  endif
  assign asset_file = section.settings.asset_image | default: 'hp-editorial.jpg'
-%}

<section class="cb2" id="cb2-{{ section.id }}" aria-labelledby="cb2-title-{{ section.id }}">

  <div class="cb2__content">
    <h2 class="cb2__title" id="cb2-title-{{ section.id }}">
      {{- section.settings.title | default: 'Pack Créateur' -}}
    </h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="cb2__subtitle">{{- section.settings.subtitle -}}</p>
    {%- else -%}
      <p class="cb2__subtitle">Tout ce dont vous avez besoin pour créer du contenu professionnel — objectifs, stabilisateurs, éclairage et accessoires réunis dans un pack exclusif à prix réduit.</p>
    {%- endif -%}
    {%- if section.settings.cta_text != blank -%}
      <a
        class="cb2__btn"
        href="{{ section.settings.cta_url | default: '#' }}"
        {% if section.settings.cta_url == blank %}aria-disabled="true"{% endif %}
      >
        {{- section.settings.cta_text -}}
      </a>
    {%- endif -%}
  </div>

  <div class="cb2__media" aria-hidden="true">
    <div class="cb2__media-inner">
      {%- if has_picker_img -%}
        <img
          class="cb2__img"
          src="{{ section.settings.image | image_url: width: 1200 }}"
          srcset="
            {{ section.settings.image | image_url: width: 600  }} 600w,
            {{ section.settings.image | image_url: width: 900  }} 900w,
            {{ section.settings.image | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 767px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: '' | escape }}"
          loading="lazy"
          decoding="async"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- else -%}
        <img
          class="cb2__img"
          src="{{ asset_file | asset_url }}"
          alt=""
          loading="lazy"
          decoding="async"
          width="600"
          height="600"
        >
      {%- endif -%}
    </div>
  </div>

</section>

<style>
  /* ── Variables ──────────────────────────────────────── */
  .cb2 {
    --cb2-ease:  cubic-bezier(0.4, 0, 0.2, 1);
    --cb2-white: var(--color-bg);
    --cb2-blue:  var(--color-primary);
    --cb2-pad-x: clamp(24px, 5.5vw, 88px);
    --cb2-h:     clamp(400px, 58vh, 640px);
  }

  /* ── Section wrapper — grid 50/50 avec hauteur fixe ── */
  .cb2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: var(--cb2-h);
    background: var(--color-bg-dark);
    overflow: hidden;
    width: 100%;
  }

  /* ── Left — contenu ─────────────────────────────────── */
  .cb2__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    padding: clamp(32px, 4vw, 56px) var(--cb2-pad-x) clamp(32px, 4vw, 56px) clamp(20px, 5.5vw, 88px);
    overflow: hidden;
  }

  /* ── Titre ──────────────────────────────────────────── */
  .cb2__title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: clamp(2rem, 4.2vw, 3.6rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--cb2-white);
    margin: 0 0 20px;

    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity   540ms var(--cb2-ease),
      transform 540ms var(--cb2-ease);
  }

  /* ── Sous-titre ─────────────────────────────────────── */
  .cb2__subtitle {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: clamp(0.875rem, 1.3vw, 1rem);
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
    margin: 0 0 36px;
    max-width: 46ch;

    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity   540ms var(--cb2-ease) 90ms,
      transform 540ms var(--cb2-ease) 90ms;
  }

  /* ── Bouton ─────────────────────────────────────────── */
  .cb2__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 13px 32px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--cb2-white);
    background: transparent;
    border: 1.5px solid var(--cb2-white);
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;

    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity      540ms var(--cb2-ease) 180ms,
      transform    540ms var(--cb2-ease) 180ms,
      background   220ms ease,
      color        220ms ease,
      border-color 220ms ease,
      box-shadow   220ms ease;
    will-change: transform;
  }

  @media (hover: hover) {
    .cb2__btn:hover {
      background: var(--cb2-white);
      color: var(--color-bg-dark);
      box-shadow: 0 6px 24px rgba(255, 255, 255, 0.14);
    }
  }

  .cb2__btn:focus-visible {
    outline: 2px solid var(--cb2-blue);
    outline-offset: 3px;
  }

  /* ── Right — image ──────────────────────────────────── */
  .cb2__media {
    position: relative;
    overflow: hidden;
  }

  .cb2__media-inner {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .cb2__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Révélation scroll ──────────────────────────────── */
  .cb2.is-visible .cb2__title,
  .cb2.is-visible .cb2__subtitle,
  .cb2.is-visible .cb2__btn {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 767px) {
    .cb2 {
      grid-template-columns: 1fr;
      grid-template-rows: clamp(240px, 55vw, 340px) auto;
      height: auto;
    }

    .cb2__media { order: 1; }
    .cb2__content { order: 2; }

    .cb2__content {
      padding: 36px clamp(20px, 5vw, 40px) 48px;
      align-items: stretch;
    }

    .cb2__title {
      font-size: clamp(1.8rem, 7vw, 2.8rem);
      margin-bottom: 14px;
    }

    .cb2__subtitle {
      font-size: 0.875rem;
      margin-bottom: 28px;
      max-width: 100%;
    }

    .cb2__btn {
      align-self: stretch;
      justify-content: center;
      padding: 14px 24px;
    }

    .cb2__img {
      object-position: center center;
    }
  }
</style>

<script>
(function () {
  'use strict';
  var el = document.getElementById('cb2-{{ section.id }}');
  if (!el) return;
  if (!('IntersectionObserver' in window)) {
    el.classList.add('is-visible');
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      e.target.classList.add('is-visible');
      obs.unobserve(e.target);
    });
  }, { threshold: 0.08 });
  obs.observe(el);
})();
</script>

{% schema %}
{
  "name": "CTA Banner 2",
  "tag": "section",
  "class": "section-cta-banner-2",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Pack Créateur\nde Contenu"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Tout ce dont vous avez besoin pour créer du contenu professionnel — objectifs, stabilisateurs, éclairage et accessoires réunis dans un pack exclusif à prix réduit."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "DÉCOUVRIR LE PACK"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Image — Mobile first"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (médiathèque Shopify — prioritaire)"
    },
    {
      "type": "select",
      "id": "asset_image",
      "label": "Image (assets — fallback)",
      "default": "hp-editorial.jpg",
      "options": [
        { "value": "hp-editorial.jpg",   "label": "Editorial 1 (défaut)" },
        { "value": "hp-cta-2.png",       "label": "CTA 2" },
        { "value": "hp-cta.jpg",         "label": "CTA 1" },
        { "value": "hp-editorial-2.jpg", "label": "Editorial 2" },
        { "value": "hp-hero-1.jpg",      "label": "Hero 1" },
        { "value": "hp-hero-2.jpg",      "label": "Hero 2" },
        { "value": "hp-hero-3.jpg",      "label": "Hero 3" }
      ]
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond (colonne texte)",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Hauteur — Mobile first"
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Hauteur image mobile (px)",
      "min": 160,
      "max": 500,
      "step": 20,
      "default": 280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur section desktop (vh)",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "vh"
    },
    {
      "type": "header",
      "content": "Espacement — Mobile first"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding haut mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bas mobile (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding haut desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bas desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    { "type": "range", "id": "margin_top", "label": "Marge haut section (px)", "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px" },
    { "type": "range", "id": "margin_bottom", "label": "Marge bas section (px)", "min": 0, "max": 120, "step": 4, "default": 0, "unit": "px" },
    { "type": "header", "content": "✨ Animation" },
    { "type": "select", "id": "animation_type", "label": "Animation au scroll", "default": "fade-up", "options": [
        { "value": "none", "label": "Aucune" }, { "value": "fade", "label": "Fade" },
        { "value": "fade-up", "label": "Fade + slide haut" }, { "value": "zoom", "label": "Zoom" }
    ]},
    { "type": "header", "content": "👁️ Visibilité" },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Masquer sur mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Masquer sur desktop", "default": false },
    { "type": "header", "content": "⚙️ Avancé" },
    { "type": "text", "id": "custom_css", "label": "CSS personnalisé", "info": "Appliqué sur #shopify-section-ID" }
  ],
  "presets": [
    {
      "name": "CTA Banner 2"
    }
  ]
}
{% endschema %}
