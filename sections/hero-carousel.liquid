    { "type": "range",    "id": "transition_speed",      "label": "Vitesse transition (ms)",      "min": 300,  "max": 1200,  "step": 50,  "default": 700,  "unit": "ms" },
    { "type": "checkbox", "id": "loop_enabled",          "label": "Boucle infinie",               "default": true },
