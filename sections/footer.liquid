{%- comment -%} Footer — Motion19 v2.0 | Fully customisable OS 2.0 {%- endcomment -%}

{%- liquid
  assign f_bg          = section.settings.bg_color            | default: '#0a0a0a'
  assign f_accent      = section.settings.accent_color         | default: '#0787ea'
  assign f_text        = section.settings.text_color           | default: '#ffffff'
  assign f_text_muted  = section.settings.text_muted_color     | default: 'rgba(255,255,255,0.45)'
  assign f_border      = section.settings.border_color         | default: 'rgba(255,255,255,0.08)'
  assign f_link_c      = section.settings.link_color           | default: 'rgba(255,255,255,0.5)'
  assign f_link_hover  = section.settings.link_hover_color     | default: '#ffffff'
  assign f_col_title_c = section.settings.col_title_color      | default: '#ffffff'
  assign f_bottom_text = section.settings.bottom_text_color    | default: 'rgba(255,255,255,0.28)'
  assign f_social_c    = section.settings.social_icon_color    | default: 'rgba(255,255,255,0.6)'
  assign f_social_bg   = section.settings.social_bg_color      | default: 'transparent'
  assign f_social_border = section.settings.social_border_color | default: 'rgba(255,255,255,0.12)'

  assign f_col_title_s = section.settings.col_title_size       | default: 11
  assign f_col_title_w = section.settings.col_title_weight     | default: '700'
  assign f_link_s      = section.settings.link_size            | default: 14
  assign f_desc_s      = section.settings.brand_desc_size      | default: 13
  assign f_social_sz   = section.settings.social_btn_size      | default: 38
  assign f_logo_radius = section.settings.logo_border_radius   | default: 0

  assign f_maxw        = section.settings.footer_layout_width  | default: 'boxed'
  assign f_padx        = section.settings.footer_padding_x     | default: 20
  assign f_pt          = section.settings.footer_padding_top   | default: 64
  assign f_pb          = section.settings.footer_padding_bottom | default: 32
  assign f_col_gap     = section.settings.columns_gap          | default: 32

  assign f_logo        = section.settings.footer_logo
  assign f_logo_w      = section.settings.footer_logo_width    | default: 120
  assign f_logo_filter = section.settings.logo_filter          | default: 'invert-white'

  assign show_contact  = section.settings.show_contact         | default: true
  assign show_phone    = section.settings.show_phone           | default: true
  assign show_address  = section.settings.show_address         | default: true

  assign copy          = section.settings.copyright_text
  assign show_pay      = section.settings.show_payment_icons   | default: true
  assign show_border_top = section.settings.show_border_top    | default: false
  assign custom_css_f  = section.settings.custom_css_footer

  assign f_inner_maxw  = 1400
  if f_maxw == 'wide'
    assign f_inner_maxw = 1600
  elsif f_maxw == 'full'
    assign f_inner_maxw = 99999
  endif

  assign logo_filter_css = ''
  if f_logo_filter == 'invert-white'
    assign logo_filter_css = 'brightness(0) invert(1)'
  elsif f_logo_filter == 'invert-black'
    assign logo_filter_css = 'brightness(0)'
  endif
-%}

<style>
  .footer {
    --ft-bg:           {{ f_bg }};
    --ft-accent:       {{ f_accent }};
    --ft-text:         {{ f_text }};
    --ft-text-muted:   {{ f_text_muted }};
    --ft-border:       {{ f_border }};
    --ft-link:         {{ f_link_c }};
    --ft-link-hover:   {{ f_link_hover }};
    --ft-col-title:    {{ f_col_title_c }};
    --ft-bottom-text:  {{ f_bottom_text }};
    --ft-social-c:     {{ f_social_c }};
    --ft-social-bg:    {{ f_social_bg }};
    --ft-social-bdr:   {{ f_social_border }};
    --ft-col-title-s:  {{ f_col_title_s }}px;
    --ft-col-title-w:  {{ f_col_title_w }};
    --ft-link-s:       {{ f_link_s }}px;
    --ft-desc-s:       {{ f_desc_s }}px;
    --ft-social-sz:    {{ f_social_sz }}px;
    --ft-logo-r:       {{ f_logo_radius }}px;
    --ft-padx:         {{ f_padx }}px;
    --ft-pt:           {{ f_pt }}px;
    --ft-pb:           {{ f_pb }}px;
    --ft-col-gap:      {{ f_col_gap }}px;
    --ft-maxw:         {{ f_inner_maxw }}px;
  }
  {%- if show_border_top -%}
  .footer { border-top: 1px solid var(--ft-border); }
  {%- endif -%}
  {%- if custom_css_f != blank -%}.footer { {{ custom_css_f }} }{%- endif -%}
</style>

<style>
/* ============================================================
   FOOTER — Motion19 v2.0
   ============================================================ */
.footer {
  background: var(--ft-bg);
  color: var(--ft-text);
  font-family: var(--font-body, 'Inter', sans-serif);
}

.footer *, .footer *::before, .footer *::after { box-sizing: border-box; margin: 0; padding: 0; }
.footer a { text-decoration: none; color: inherit; }
.footer ul { list-style: none; }

/* ── Wrappers ─────────────────────────────────────────────── */
.footer__inner {
  max-width: var(--ft-maxw);
  margin: 0 auto;
  padding: var(--ft-pt) var(--ft-padx) calc(var(--ft-pt) / 2);
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
}

@media (min-width: 768px) {
  .footer__inner {
    grid-template-columns: 1.4fr 2fr;
    gap: var(--ft-col-gap);
  }
}

@media (min-width: 1024px) {
  .footer__inner { grid-template-columns: 1.2fr 2.4fr; }
}

/* ── Brand column ─────────────────────────────────────────── */
.footer__brand { display: flex; flex-direction: column; gap: 18px; }

.footer__logo-link { display: inline-flex; }

.footer__logo-img {
  max-width: var(--ft-logo-w, 120px);
  width: auto;
  height: auto;
  max-height: 48px;
  border-radius: var(--ft-logo-r);
  display: block;
}

.footer__shop-name {
  font-size: 1.4rem;
  font-weight: 900;
  letter-spacing: -0.03em;
  color: var(--ft-text);
  line-height: 1;
}

.footer__brand-desc {
  font-size: var(--ft-desc-s);
  line-height: 1.7;
  color: var(--ft-text-muted);
  max-width: 300px;
}

/* ── Contact ─────────────────────────────────────────────── */
.footer__contact { display: flex; flex-direction: column; gap: 10px; }

.footer__contact-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  color: var(--ft-text-muted);
  font-size: 0.82rem;
  line-height: 1.4;
  transition: color 0.2s;
}
.footer__contact-item:hover { color: var(--ft-text); }

.footer__contact-icon {
  flex-shrink: 0;
  width: 28px; height: 28px;
  border-radius: 50%;
  background: rgba(255,255,255,0.07);
  display: flex; align-items: center; justify-content: center;
}

/* ── Socials ──────────────────────────────────────────────── */
.footer__socials { display: flex; gap: 8px; flex-wrap: wrap; }

.footer__social-btn {
  width: var(--ft-social-sz);
  height: var(--ft-social-sz);
  border-radius: 50%;
  border: 1px solid var(--ft-social-bdr);
  background: var(--ft-social-bg);
  color: var(--ft-social-c);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  flex-shrink: 0;
}
.footer__social-btn:hover {
  background: var(--ft-accent);
  border-color: var(--ft-accent);
  color: #fff;
}

/* ── Nav columns ──────────────────────────────────────────── */
.footer__nav {
  display: flex;
  flex-direction: column;
  gap: 0;
}

@media (min-width: 768px) {
  .footer__nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0 24px;
  }
}

.footer__col-head {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%;
  background: transparent; border: none;
  color: var(--ft-col-title);
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: var(--ft-col-title-s);
  font-weight: var(--ft-col-title-w);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 16px 0;
  border-bottom: 1px solid var(--ft-border);
  cursor: pointer;
}

.footer__col-head .ft-chevron {
  flex-shrink: 0;
  color: rgba(255,255,255,0.35);
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.footer__col.is-open .footer__col-head .ft-chevron { transform: rotate(180deg); }

/* accordion body */
.footer__col-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1), padding 0.28s;
}
.footer__col.is-open .footer__col-body { max-height: 500px; padding: 14px 0 20px; }

@media (min-width: 768px) {
  .footer__col-head {
    cursor: default;
    pointer-events: none;
    border-bottom: none;
    padding: 0 0 14px;
  }
  .footer__col-head .ft-chevron { display: none; }
  .footer__col-body { max-height: none !important; overflow: visible; padding: 0 !important; }
}

.footer__col-list { display: flex; flex-direction: column; gap: 11px; }

.footer__col-link {
  font-size: var(--ft-link-s);
  color: var(--ft-link);
  transition: color 0.2s;
  display: inline-block;
}
.footer__col-link:hover { color: var(--ft-link-hover); }

/* ── Bottom bar ───────────────────────────────────────────── */
.footer__bottom {
  border-top: 1px solid var(--ft-border);
}
.footer__bottom-inner {
  max-width: var(--ft-maxw);
  margin: 0 auto;
  padding: var(--ft-pb) var(--ft-padx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-align: center;
}
@media (min-width: 640px) {
  .footer__bottom-inner {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
  }
}

.footer__copy {
  font-size: 0.75rem;
  color: var(--ft-bottom-text);
}

.footer__legal-links {
  display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;
}
@media (min-width: 640px) { .footer__legal-links { justify-content: flex-end; } }

.footer__legal-link {
  font-size: 0.75rem;
  color: var(--ft-bottom-text);
  transition: color 0.2s;
}
.footer__legal-link:hover { color: var(--ft-text); }

/* Payment icons */
.footer__payment-icons { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.footer__payment-icons svg { height: 22px; width: auto; border-radius: 3px; }
</style>

<footer class="footer" role="contentinfo">

  <div class="footer__inner">

    {%- comment -%}── BRAND COLUMN ──{%- endcomment -%}
    <div class="footer__brand">

      {%- comment -%} Logo {%- endcomment -%}
      {%- assign footer_logo_src = f_logo | default: settings.logo -%}
      {%- if footer_logo_src != blank -%}
        <a href="{{ routes.root_url }}" class="footer__logo-link" aria-label="{{ shop.name }} — Accueil">
          <img
            src="{{ footer_logo_src | image_url: width: 480 }}"
            alt="{{ shop.name }}"
            class="footer__logo-img"
            width="{{ f_logo_w }}"
            height="48"
            loading="lazy"
            style="max-width:{{ f_logo_w }}px;{% unless logo_filter_css == '' %}filter:{{ logo_filter_css }};{% endunless %}"
          >
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="footer__shop-name">{{ shop.name }}</a>
      {%- endif -%}

      {%- comment -%} Description {%- endcomment -%}
      {%- if section.settings.brand_desc != blank -%}
        <p class="footer__brand-desc">{{ section.settings.brand_desc }}</p>
      {%- endif -%}

      {%- comment -%} Réseaux sociaux {%- endcomment -%}
      {%- assign has_social = false -%}
      {%- if section.settings.show_instagram and section.settings.social_instagram != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_facebook  and section.settings.social_facebook  != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_youtube   and section.settings.social_youtube   != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_tiktok    and section.settings.social_tiktok    != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_twitter   and section.settings.social_twitter   != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_linkedin  and section.settings.social_linkedin  != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.show_pinterest and section.settings.social_pinterest != blank -%}{%- assign has_social = true -%}{%- endif -%}

      {%- if has_social -%}
      <div class="footer__socials" aria-label="Réseaux sociaux">
        {%- if section.settings.show_instagram and section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_facebook and section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_youtube and section.settings.social_youtube != blank -%}
          <a href="{{ section.settings.social_youtube }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_tiktok and section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.77 1.52V6.72a4.85 4.85 0 0 1-1-.03z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_twitter and section.settings.social_twitter != blank -%}
          <a href="{{ section.settings.social_twitter }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_linkedin and section.settings.social_linkedin != blank -%}
          <a href="{{ section.settings.social_linkedin }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.show_pinterest and section.settings.social_pinterest != blank -%}
          <a href="{{ section.settings.social_pinterest }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        {%- endif -%}
      </div>
      {%- endif -%}

      {%- comment -%} Contact {%- endcomment -%}
      {%- if show_contact -%}
        <div class="footer__contact">
          {%- if show_phone and section.settings.phone != blank -%}
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '/' | strip }}" class="footer__contact-item">
              <span class="footer__contact-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 11.8 19.79 19.79 0 0 1 1.11 3.2 2 2 0 0 1 3.08 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span>{{ section.settings.phone }}</span>
            </a>
          {%- endif -%}
          {%- if show_address and section.settings.address != blank -%}
            {%- assign map_href = section.settings.address_map_url | default: '#' -%}
            <a href="{{ map_href }}" class="footer__contact-item" {% if section.settings.address_map_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}>
              <span class="footer__contact-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              </span>
              <span>{{ section.settings.address }}</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%}── NAV COLUMNS ──{%- endcomment -%}
    <nav class="footer__nav" aria-label="Navigation pied de page">

      {%- for i in (1..4) -%}
        {%- assign col_title_key = 'col_' | append: i | append: '_title' -%}
        {%- assign col_menu_key  = 'col_' | append: i | append: '_menu' -%}
        {%- assign col_title = section.settings[col_title_key] -%}
        {%- assign col_menu  = section.settings[col_menu_key] -%}
        {%- if col_title != blank or col_menu != blank -%}
          <div class="footer__col">
            <button class="footer__col-head" aria-expanded="false" aria-controls="footer-col-{{ i }}">
              {{ col_title | default: 'Colonne' }}
              <svg class="ft-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="footer__col-body" id="footer-col-{{ i }}">
              {%- if col_menu != blank and linklists[col_menu] != blank -%}
                <ul class="footer__col-list" role="list">
                  {%- for link in linklists[col_menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__col-link"{% unless link.url contains shop.permanent_domain %} target="_blank" rel="noopener noreferrer"{% endunless %}>
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </nav>

  </div>

  {%- comment -%}── BOTTOM BAR ──{%- endcomment -%}
  <div class="footer__bottom">
    <div class="footer__bottom-inner">

      <p class="footer__copy">
        {%- if copy != blank -%}
          {{ copy }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.
        {%- endif -%}
      </p>

      <div class="footer__legal-links">
        {%- for i in (1..5) -%}
          {%- assign lbl_key = 'legal_' | append: i | append: '_label' -%}
          {%- assign url_key = 'legal_' | append: i | append: '_url' -%}
          {%- if section.settings[lbl_key] != blank -%}
            <a href="{{ section.settings[url_key] | default: '#' }}" class="footer__legal-link">{{ section.settings[lbl_key] }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if show_pay -%}
        <div class="footer__payment-icons" aria-label="Méthodes de paiement">
          {%- if section.settings.show_pay_visa -%}
            <svg height="22" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Visa"><rect width="38" height="24" rx="4" fill="#1A1F71"/><path d="M14.5 16H12l1.5-8H16L14.5 16zm5-8l-2 5.5-.3-1.3-.9-4.2H14l2.5 8h2.5L23 8h-3.5zM26.5 8c-.7 0-1.3.2-1.7.5l-.3 1.8c.4-.4 1-.6 1.5-.6.7 0 1 .4 1 .8l-.1.5h-.7c-1.7 0-2.7.8-2.7 2 0 .8.5 1.4 1.5 1.4.7 0 1.2-.3 1.6-.7l-.1.6h2.2l1-5.2C30 8.6 29 8 26.5 8zm.8 4.4c-.1.6-.5 1-1.1 1-.4 0-.6-.2-.6-.6 0-.6.4-.9 1.2-.9h.6l-.1.5z" fill="#fff"/></svg>
          {%- endif -%}
          {%- if section.settings.show_pay_mastercard -%}
            <svg height="22" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mastercard"><rect width="38" height="24" rx="4" fill="#252525"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/><path d="M19 7.5a7 7 0 0 1 0 9 7 7 0 0 1 0-9z" fill="#FF5F00"/></svg>
          {%- endif -%}
          {%- if section.settings.show_pay_paypal -%}
            <svg height="22" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="PayPal"><rect width="38" height="24" rx="4" fill="#fff" stroke="#e5e5e5" stroke-width="1"/><path d="M13.5 7H16c2.2 0 3 1 2.7 2.5-.4 2-1.8 2.5-3.5 2.5h-.8l-.6 3H12l1.5-8zm1.3 3.5h.7c.7 0 1.2-.2 1.3-.8.1-.5-.2-.7-.8-.7h-.7l-.5 1.5z" fill="#003087"/><path d="M20.5 9H23c2 0 2.8 1 2.5 2.5-.4 2-1.8 2.5-3.5 2.5h-.8l-.6 3H19l1.5-8zm1.3 3.5h.7c.7 0 1.2-.2 1.3-.8.1-.5-.2-.7-.8-.7h-.7l-.5 1.5z" fill="#009cde"/></svg>
          {%- endif -%}
          {%- if section.settings.show_pay_amex -%}
            <svg height="22" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Amex"><rect width="38" height="24" rx="4" fill="#016FD0"/><path d="M7 8l-4 8h4.5l.6-1.5h4.8l.6 1.5H18l-4-8H7zm1.5 5l1.5-3.8 1.5 3.8h-3zM18 8v8h2.5v-3h3v3H26v-8h-2.5v3h-3V8H18z" fill="#fff"/></svg>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

</footer>

<script>
(function () {
  var cols = document.querySelectorAll('.footer__col-head');
  cols.forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (getComputedStyle(btn).pointerEvents === 'none') return;
      var col = btn.closest('.footer__col');
      var isOpen = col.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', isOpen);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Logo & Marque" },
