{{ 'card.css' | asset_url | stylesheet_tag }}
{%- comment -%} Main Collection Premium — Motion19 OS 2.0 {%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign container_width  = section.settings.container_width  | default: 1400
  assign content_width    = section.settings.content_width    | default: 1200
  assign card_radius      = section.settings.card_radius      | default: 12
  assign btn_radius       = section.settings.btn_radius       | default: 3
  assign anim_speed       = section.settings.animation_speed  | default: 'normal'
  assign cols_desk        = section.settings.columns_desktop  | default: 3
  assign cols_tab         = section.settings.columns_tablet   | default: 2
  assign cols_mob         = section.settings.columns_mobile   | default: 1
  assign img_ratio        = section.settings.image_ratio      | default: 'portrait'
  assign hover_effect     = section.settings.hover_effect     | default: 'zoom'
  assign show_vendor      = section.settings.show_vendor      | default: false
  assign show_badge       = section.settings.show_badge       | default: true
  assign show_atc         = section.settings.show_quick_add   | default: true
  assign show_rating      = section.settings.show_rating      | default: false
  assign show_variants    = section.settings.show_variants    | default: false
  assign pagination_type  = section.settings.pagination_type  | default: 'loadmore'
  assign products_per_page = section.settings.products_per_page | default: 12
  assign show_hero        = section.settings.show_hero        | default: true
  assign show_filters     = section.settings.show_filters     | default: true
  assign show_brands      = section.settings.show_brands      | default: true
  assign show_guide       = section.settings.show_guide       | default: false
  assign sidebar_width    = section.settings.sidebar_width    | default: 260
  assign gap              = section.settings.grid_gap         | default: 20

  assign hero_height      = section.settings.hero_height      | default: 'medium'
  assign hero_h_mob       = section.settings.hero_height_mobile | default: 500
  assign hero_align       = section.settings.hero_content_align | default: 'left'
  assign hero_grad        = section.settings.hero_gradient_style | default: 'left'
  assign hero_ov_op       = section.settings.hero_overlay_opacity | default: 55 | divided_by: 100.0
  assign hero_show_stats  = section.settings.hero_show_stats  | default: true
  assign hero_show_bread  = section.settings.hero_show_breadcrumb | default: true
  assign hero_cta_label   = section.settings.hero_cta_label
  assign hero_cta_url     = section.settings.hero_cta_url
  assign hero_cta_style   = section.settings.hero_cta_style   | default: 'outline-white'

  assign accent_color     = section.settings.accent_color     | default: '#0787ea'
  assign text_color       = section.settings.text_color       | default: '#1a1a1a'
  assign bg_color         = section.settings.bg_color         | default: '#ffffff'
  assign card_bg          = section.settings.card_bg_color    | default: '#ffffff'
  assign sticky_bg        = section.settings.sticky_bar_bg    | default: 'rgba(255,255,255,0.88)'

  assign filter_menu_handle = section.settings.filter_menu

  assign img_ratio_css = '3/4'
  if img_ratio == 'square'
    assign img_ratio_css = '1/1'
  elsif img_ratio == 'landscape'
    assign img_ratio_css = '4/3'
  endif

  assign collection_title = collection.title | default: 'Tous nos produits'
  assign collection_desc  = collection.description | default: ''
  assign collection_count = collection.products_count | default: 0

  if collection.image != blank
    assign hero_img_url = collection.image | image_url: width: 1800
    assign hero_img_m   = collection.image | image_url: width: 800
  else
    assign hero_img_url = 'hp-hero-1.jpg' | asset_url
    assign hero_img_m   = 'hp-hero-1-mobile.jpg' | asset_url
  endif

  assign current_url = request.path
  assign current_sort = collection.sort_by | default: collection.default_sort_by
-%}

<div
  id="mcp-{{ sid }}"
  class="mcp mcp--speed-{{ anim_speed }}"
  style="
    --mcp-accent: {{ accent_color }};
    --mcp-text: {{ text_color }};
    --mcp-bg: {{ bg_color }};
    --mcp-card-bg: {{ card_bg }};
    --mcp-sticky-bg: {{ sticky_bg }};
    --mcp-radius: {{ card_radius }}px;
    --mcp-btn-radius: {{ btn_radius }}px;
    --mcp-container: {{ container_width }}px;
    --mcp-content: {{ content_width }}px;
    --mcp-sidebar: {{ sidebar_width }}px;
    --mcp-cols-desk: {{ cols_desk }};
    --mcp-cols-tab: {{ cols_tab }};
    --mcp-cols-mob: {{ cols_mob }};
    --mcp-gap: {{ gap }}px;
    --mcp-ratio: {{ img_ratio_css }};
    --mcp-hero-h-mob: {{ hero_h_mob }}px;
  "
>

{%- comment -%}━━━━━━━━━━━━━━━━━━━ 1. HERO ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
{%- if show_hero -%}
<section class="mcp__hero mcp__hero--h-{{ hero_height }} mcp__hero--align-{{ hero_align }}" aria-label="{{ collection_title | escape }}">
  <div class="mcp__hero-media" aria-hidden="true">
    <picture>
      <source media="(max-width:767px)" srcset="{{ hero_img_m }}">
      <img class="mcp__hero-bg" src="{{ hero_img_url }}" alt="" loading="eager" fetchpriority="high" decoding="async">
    </picture>
    <div class="mcp__hero-overlay mcp__hero-overlay--{{ hero_grad }}" style="--ov-a:{{ hero_ov_op }};"></div>
  </div>
  <div class="mcp__hero-glow" aria-hidden="true"></div>
  <div class="mcp__hero-content">
    <div class="mcp__hero-inner" id="mcp-hero-inner-{{ sid }}">
      {%- if hero_show_bread -%}
        <nav class="mcp__breadcrumb" aria-label="Fil d'Ariane">
          <a class="mcp__breadcrumb-link" href="/">Accueil</a>
          <span class="mcp__breadcrumb-sep" aria-hidden="true">/</span>
          <a class="mcp__breadcrumb-link" href="/collections">Collections</a>
          {%- if collection.title != blank -%}
            <span class="mcp__breadcrumb-sep" aria-hidden="true">/</span>
            <span class="mcp__breadcrumb-current">{{ collection_title }}</span>
          {%- endif -%}
        </nav>
      {%- endif -%}

      <h1 class="mcp__hero-title">{{ collection_title }}</h1>

      {%- if collection_desc != blank -%}
        <p class="mcp__hero-desc">{{ collection_desc | strip_html | truncate: 180 }}</p>
      {%- else -%}
        <p class="mcp__hero-desc">{{ section.settings.hero_fallback_desc | default: 'Découvrez notre sélection de matériel audiovisuel premium pour les créateurs de contenu nouvelle génération.' }}</p>
      {%- endif -%}

      {%- if hero_show_stats -%}
        <div class="mcp__hero-stats">
          <div class="mcp__hero-stat">
            <span class="mcp__hero-stat-num">{{ collection_count }}</span>
            <span class="mcp__hero-stat-label">{{ section.settings.stat_products_label | default: 'produits' }}</span>
          </div>
          {%- if section.settings.stat_2_value != blank -%}
            <div class="mcp__hero-stat-sep" aria-hidden="true"></div>
            <div class="mcp__hero-stat">
              <span class="mcp__hero-stat-num">{{ section.settings.stat_2_value }}</span>
              <span class="mcp__hero-stat-label">{{ section.settings.stat_2_label | default: 'marques' }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.stat_3_value != blank -%}
            <div class="mcp__hero-stat-sep" aria-hidden="true"></div>
            <div class="mcp__hero-stat">
              <span class="mcp__hero-stat-num">{{ section.settings.stat_3_value }}</span>
              <span class="mcp__hero-stat-label">{{ section.settings.stat_3_label | default: 'experts' }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if hero_cta_label != blank -%}
        <div class="mcp__hero-ctas">
          <a class="mcp__hero-btn mcp__hero-btn--{{ hero_cta_style }}" href="{{ hero_cta_url | default: '#mcp-grid' }}">
            <span>{{ hero_cta_label }}</span>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
  <div class="mcp__hero-scroll" aria-hidden="true">
    <div class="mcp__hero-scroll-line"></div>
    <span class="mcp__hero-scroll-label">Scroll</span>
  </div>
</section>
{%- endif -%}

{%- comment -%}━━━━━━━━━━━━━━━━━━━ 2. STICKY BAR ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
<div class="mcp__sticky" id="mcp-sticky-{{ sid }}" role="toolbar" aria-label="Barre de contrôle collection">
  <div class="mcp__sticky-inner">
    <div class="mcp__sticky-left">
      <button class="mcp__filter-toggle" id="mcp-filter-btn-{{ sid }}" aria-expanded="false" aria-controls="mcp-sidebar-{{ sid }}" aria-label="Ouvrir les filtres">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        <span>{{ section.settings.filter_btn_label | default: 'Filtres' }}</span>
        <span class="mcp__filter-count" id="mcp-filter-count-{{ sid }}" aria-live="polite" hidden>0</span>
      </button>
      <span class="mcp__product-count" id="mcp-count-{{ sid }}" aria-live="polite">
        {{ collection_count }} {{ section.settings.stat_products_label | default: 'produits' }}
      </span>
    </div>
    <div class="mcp__sticky-center">
      {%- if section.settings.nav_menu != blank -%}
        {%- assign nav_menu = linklists[section.settings.nav_menu] -%}
        {%- if nav_menu.links.size > 0 -%}
          <nav class="mcp__quick-nav" aria-label="Navigation rapide catégories">
            <div class="mcp__quick-nav-scroll">
              {%- for link in nav_menu.links -%}
                <a class="mcp__quick-nav-link{% if link.active %} is-active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </nav>
        {%- endif -%}
      {%- endif -%}
    </div>
    <div class="mcp__sticky-right">
      <div class="mcp__sort-wrap">
        <label class="sr-only" for="mcp-sort-{{ sid }}">{{ section.settings.sort_label | default: 'Trier par' }}</label>
        <select class="mcp__sort" id="mcp-sort-{{ sid }}" name="sort_by" aria-label="{{ section.settings.sort_label | default: 'Trier par' }}">
          {%- assign sort_options = collection.sort_options -%}
          {%- for opt in sort_options -%}
            <option value="{{ opt.value }}"{% if opt.value == current_sort %} selected{% endif %}>{{ opt.name }}</option>
          {%- endfor -%}
        </select>
        <svg class="mcp__sort-chevron" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="mcp__view-btns" role="group" aria-label="Mode d'affichage">
        <button class="mcp__view-btn is-active" data-view="grid" aria-label="Vue grille" aria-pressed="true">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
        <button class="mcp__view-btn" data-view="list" aria-label="Vue liste" aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><line x1="1" y1="4" x2="15" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

{%- comment -%}━━━━━━━━━━━━━━━━━━━ 3. LAYOUT (sidebar + grid) ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
<div class="mcp__layout" id="mcp-layout-{{ sid }}">
  <div class="mcp__layout-inner">

    {%- comment -%} SIDEBAR FILTERS {%- endcomment -%}
    {%- if show_filters -%}
    <aside
      class="mcp__sidebar"
      id="mcp-sidebar-{{ sid }}"
      aria-label="Filtres"
      aria-hidden="true"
      hidden
    >
      <div class="mcp__sidebar-header">
        <span class="mcp__sidebar-title">{{ section.settings.filter_panel_title | default: 'Filtres' }}</span>
        <button class="mcp__sidebar-close" aria-label="Fermer les filtres" id="mcp-sidebar-close-{{ sid }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="mcp__sidebar-body">
        {%- comment -%} Active filters {%- endcomment -%}
        {%- if collection.filters.size > 0 -%}
          {%- assign has_active = false -%}
          {%- for filter in collection.filters -%}
            {%- if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value -%}
              {%- assign has_active = true -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if has_active -%}
            <div class="mcp__active-filters" id="mcp-active-filters-{{ sid }}">
              <div class="mcp__active-filters-header">
                <span class="mcp__active-filters-label">Filtres actifs</span>
                <a href="{{ collection.url }}" class="mcp__clear-all">Tout effacer</a>
              </div>
              <div class="mcp__active-filters-list">
                {%- for filter in collection.filters -%}
                  {%- for v in filter.active_values -%}
                    <a href="{{ v.url_to_remove }}" class="mcp__active-pill" aria-label="Retirer le filtre {{ v.label }}">
                      {{ v.label }}
                      <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </a>
                  {%- endfor -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Shopify native filters {%- endcomment -%}
        {%- if collection.filters.size > 0 -%}
          {%- for filter in collection.filters -%}
            <div class="mcp__filter-group" id="mcp-fg-{{ sid }}-{{ forloop.index }}">
              <button
                class="mcp__filter-group-head"
                aria-expanded="true"
                aria-controls="mcp-fg-body-{{ sid }}-{{ forloop.index }}"
              >
                <span class="mcp__filter-group-label">{{ filter.label }}</span>
                {%- if filter.active_values.size > 0 -%}
                  <span class="mcp__filter-group-badge">{{ filter.active_values.size }}</span>
                {%- endif -%}
                <svg class="mcp__filter-chevron" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <div class="mcp__filter-group-body" id="mcp-fg-body-{{ sid }}-{{ forloop.index }}">
                {%- case filter.type -%}
                  {%- when 'boolean', 'list' -%}
                    <ul class="mcp__filter-list" role="list">
                      {%- for value in filter.values -%}
                        <li class="mcp__filter-item">
                          <label class="mcp__filter-label{% if value.active %} is-active{% endif %}">
                            <input
                              class="mcp__filter-cb sr-only"
                              type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              form="mcp-filter-form-{{ sid }}"
                            >
                            <span class="mcp__filter-check" aria-hidden="true"></span>
                            {%- if filter.label == 'Couleur' or filter.label == 'Color' or filter.label == 'Couleurs' -%}
                              <span class="mcp__color-swatch" style="background:{{ value.value | downcase }};"></span>
                            {%- endif -%}
                            <span class="mcp__filter-value-label">{{ value.label }}</span>
                            <span class="mcp__filter-count">({{ value.count }})</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- when 'price_range' -%}
                    {%- assign min_price = filter.range_min | divided_by: 100.0 -%}
                    {%- assign max_price = filter.range_max | divided_by: 100.0 -%}
                    {%- assign cur_min   = filter.min_value.value | default: filter.range_min | divided_by: 100.0 -%}
                    {%- assign cur_max   = filter.max_value.value | default: filter.range_max | divided_by: 100.0 -%}
                    <div class="mcp__price-range" data-min="{{ min_price }}" data-max="{{ max_price }}">
                      <div class="mcp__price-range-track">
                        <div class="mcp__price-range-fill" id="mcp-range-fill-{{ sid }}-{{ forloop.index }}"></div>
                        <input
                          class="mcp__price-range-input mcp__price-range-input--min"
                          type="range"
                          name="{{ filter.min_value.param_name }}"
                          min="{{ min_price }}"
                          max="{{ max_price }}"
                          value="{{ cur_min }}"
                          step="1"
                          form="mcp-filter-form-{{ sid }}"
                          aria-label="Prix minimum"
                        >
                        <input
                          class="mcp__price-range-input mcp__price-range-input--max"
                          type="range"
                          name="{{ filter.max_value.param_name }}"
                          min="{{ min_price }}"
                          max="{{ max_price }}"
                          value="{{ cur_max }}"
                          step="1"
                          form="mcp-filter-form-{{ sid }}"
                          aria-label="Prix maximum"
                        >
                      </div>
                      <div class="mcp__price-range-vals">
                        <span class="mcp__price-range-label" id="mcp-price-min-{{ sid }}-{{ forloop.index }}">{{ cur_min | money_without_trailing_zeros }}</span>
                        <span class="mcp__price-range-label" id="mcp-price-max-{{ sid }}-{{ forloop.index }}">{{ cur_max | money_without_trailing_zeros }}</span>
                      </div>
                    </div>
                {%- endcase -%}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Manual filter blocks from schema {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'filter_group' -%}
              <div class="mcp__filter-group" {{ block.shopify_attributes }}>
                <button class="mcp__filter-group-head" aria-expanded="true" aria-controls="mcp-fg-block-{{ block.id }}">
                  <span class="mcp__filter-group-label">{{ block.settings.label | default: 'Filtre' }}</span>
                  <svg class="mcp__filter-chevron" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="mcp__filter-group-body" id="mcp-fg-block-{{ block.id }}">
                  {%- assign filter_vals = block.settings.values | split: ',' -%}
                  <ul class="mcp__filter-list" role="list">
                    {%- for val in filter_vals -%}
                      {%- assign val_clean = val | strip -%}
                      <li class="mcp__filter-item">
                        <label class="mcp__filter-label">
                          <input class="mcp__filter-cb sr-only" type="checkbox" name="filter.p.tag" value="{{ val_clean }}">
                          <span class="mcp__filter-check" aria-hidden="true"></span>
                          <span class="mcp__filter-value-label">{{ val_clean }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="mcp__sidebar-footer">
        <button class="mcp__sidebar-apply" id="mcp-apply-{{ sid }}" form="mcp-filter-form-{{ sid }}" type="submit">
          {{ section.settings.filter_apply_label | default: 'Voir les résultats' }}
        </button>
      </div>
    </aside>
    {%- endif -%}

    <form id="mcp-filter-form-{{ sid }}" method="get" action="{{ collection.url }}">
      {%- if section.settings.sort_by_hidden != blank -%}
        <input type="hidden" name="sort_by" value="{{ current_sort }}">
      {%- endif -%}
    </form>

    {%- comment -%} MOBILE DRAWER OVERLAY {%- endcomment -%}
    <div class="mcp__drawer-overlay" id="mcp-overlay-{{ sid }}" aria-hidden="true" tabindex="-1"></div>

    {%- comment -%}━━━━━━━━━━━━━━━━━━━ MAIN CONTENT ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
    <main class="mcp__main" id="mcp-grid" tabindex="-1">

      {%- comment -%} PRODUCT GRID {%- endcomment -%}
      <div
        class="mcp__grid mcp__grid--{{ hover_effect }}"
        id="mcp-product-grid-{{ sid }}"
        aria-label="Grille de produits"
      >
        {%- assign editorial_blocks = '' -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'editorial_banner' -%}
            {%- assign editorial_blocks = editorial_blocks | append: block.id | append: ':' | append: block.settings.insert_after_product | append: ',' -%}
          {%- endif -%}
        {%- endfor -%}

        {%- paginate collection.products by products_per_page -%}
          {%- for product in collection.products -%}
            {%- comment -%} Insert editorial banners before matching product index {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'editorial_banner' -%}
                {%- assign insert_after = block.settings.insert_after_product | default: 6 | plus: 0 -%}
                {%- if forloop.index == insert_after -%}
                  <div class="mcp__editorial" {{ block.shopify_attributes }}
                    style="
                      --eb-bg: {{ block.settings.bg_color | default: '#0a0a0a' }};
                      --eb-text: {{ block.settings.text_color | default: '#ffffff' }};
                      --eb-accent: {{ block.settings.accent_color | default: '#0787ea' }};
                    "
                  >
                    {%- if block.settings.image != blank -%}
                      <img class="mcp__editorial-bg" src="{{ block.settings.image | image_url: width: 1200 }}" alt="" loading="lazy">
                    {%- endif -%}
                    <div class="mcp__editorial-overlay"></div>
                    <div class="mcp__editorial-content">
                      {%- if block.settings.eyebrow != blank -%}
                        <span class="mcp__editorial-eyebrow">{{ block.settings.eyebrow }}</span>
                      {%- endif -%}
                      <h3 class="mcp__editorial-title">{{ block.settings.title | default: 'Le setup parfait pour YouTube' }}</h3>
                      {%- if block.settings.desc != blank -%}
                        <p class="mcp__editorial-desc">{{ block.settings.desc }}</p>
                      {%- endif -%}
                      {%- if block.settings.cta_label != blank -%}
                        <a class="mcp__editorial-cta" href="{{ block.settings.cta_url | default: '#' }}">
                          {{ block.settings.cta_label }}
                          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} PRODUCT CARD {%- endcomment -%}
            {%- assign p = product -%}
            {%- assign p_img  = p.featured_image -%}
            {%- assign p_img2 = p.images[1] -%}
            {%- assign sale_pct = 0 -%}
            {%- if p.compare_at_price > p.price -%}
              {%- assign diff = p.compare_at_price | minus: p.price -%}
              {%- assign sale_pct = diff | times: 100 | divided_by: p.compare_at_price -%}
            {%- endif -%}

            <article
              class="mcp__card m19-card"
              style="transition-delay: {{ forloop.index0 | modulo: cols_desk | times: 60 }}ms;"
              aria-label="{{ p.title | escape }}"
            >
              <a class="m19-card__media m19-card__media--{{ img_ratio }}" href="{{ p.url }}" tabindex="-1" aria-hidden="true">
                {%- if p_img != blank -%}
                  <img
                    class="m19-card__img m19-card__img--primary"
                    src="{{ p_img | image_url: width: 600 }}"
                    srcset="{{ p_img | image_url: width: 300 }} 300w, {{ p_img | image_url: width: 600 }} 600w, {{ p_img | image_url: width: 900 }} 900w"
                    sizes="(max-width:599px) 100vw, (max-width:1023px) 50vw, {{ 100 | divided_by: cols_desk }}vw"
                    alt="{{ p_img.alt | default: p.title | escape }}"
                    loading="lazy"
                    decoding="async"
                    width="{{ p_img.width }}"
                    height="{{ p_img.height }}"
                  >
                  {%- if p_img2 != blank and hover_effect == 'swap' -%}
                    <img
                      class="m19-card__img m19-card__img--hover"
                      src="{{ p_img2 | image_url: width: 600 }}"
                      alt=""
                      loading="lazy"
                      decoding="async"
                      aria-hidden="true"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="m19-card__media-fallback" aria-hidden="true"></div>
                {%- endif -%}

                {%- if show_badge -%}
                  {%- if p.available == false -%}
                    <span class="m19-card__badge m19-card__badge--sale">{{ section.settings.badge_oos | default: 'Épuisé' }}</span>
                  {%- elsif sale_pct >= 5 -%}
                    <span class="m19-card__badge m19-card__badge--sale">-{{ sale_pct }}%</span>
                  {%- elsif p.tags contains 'nouveau' or p.tags contains 'new' -%}
                    <span class="m19-card__badge m19-card__badge--new">{{ section.settings.badge_new | default: 'Nouveau' }}</span>
                  {%- endif -%}
                {%- endif -%}

                {%- if show_atc and p.available -%}
                  <button
                    class="m19-card__action mcp__atc-icon"
                    type="button"
                    data-product-id="{{ p.id }}"
                    data-variant-id="{{ p.selected_or_first_available_variant.id }}"
                    aria-label="Ajouter {{ p.title | escape }} au panier"
                  >
                    <svg class="m19-card__action-icon m19-card__action-icon--bag" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    <svg class="m19-card__action-icon m19-card__action-icon--check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </button>
                {%- endif -%}
              </a>

              <div class="m19-card__body">
                {%- if show_vendor and p.vendor != blank -%}
                  <p class="m19-card__vendor">{{ p.vendor }}</p>
                {%- endif -%}

                <h3 class="m19-card__name">
                  <a href="{{ p.url }}">{{ p.title }}</a>
                </h3>

                {%- if show_rating -%}
                  <div class="mcp__rating" aria-label="Note produit">
                    <span class="mcp__rating-stars" aria-hidden="true">★★★★★</span>
                  </div>
                {%- endif -%}

                <div class="m19-card__pricing">
                  <span class="m19-card__price{% if sale_pct >= 5 %} m19-card__price--sale{% endif %}">
                    {{ p.price | money }}
                  </span>
                  {%- if p.compare_at_price > p.price -%}
                    <s class="m19-card__price--compare">{{ p.compare_at_price | money }}</s>
                  {%- endif -%}
                </div>

                {%- if show_variants and p.variants.size > 1 -%}
                  <div class="mcp__variants" aria-label="Variantes disponibles">
                    {%- for v in p.variants limit: 4 -%}
                      <button class="mcp__variant-dot{% if forloop.first %} is-selected{% endif %}" data-variant-id="{{ v.id }}" aria-label="{{ v.title }}" title="{{ v.title }}"></button>
                    {%- endfor -%}
                    {%- if p.variants.size > 4 -%}
                      <span class="mcp__variant-more">+{{ p.variants.size | minus: 4 }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if show_atc and p.available -%}
                  <button
                    class="m19-card__quick-add mcp__atc-text"
                    type="button"
                    data-product-id="{{ p.id }}"
                    data-variant-id="{{ p.selected_or_first_available_variant.id }}"
                    aria-label="Ajouter {{ p.title | escape }} au panier"
                  >{{ section.settings.atc_label | default: 'Ajouter au panier' }}</button>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}

          {%- comment -%}━━━ PAGINATION ━━━{%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            {%- if pagination_type == 'loadmore' -%}
              <div class="mcp__loadmore-wrap" id="mcp-loadmore-wrap-{{ sid }}">
                <button class="mcp__loadmore" id="mcp-loadmore-{{ sid }}" data-next-url="{{ paginate.next.url }}" aria-label="Charger plus de produits">
                  <span class="mcp__loadmore-label">{{ section.settings.loadmore_label | default: 'Charger plus' }}</span>
                  <span class="mcp__loadmore-info">{{ paginate.current_offset | plus: paginate.page_size | at_most: paginate.items }} / {{ paginate.items }}</span>
                </button>
              </div>
            {%- elsif pagination_type == 'pagination' -%}
              <nav class="mcp__pagination" aria-label="Pagination">
                {%- if paginate.previous -%}
                  <a class="mcp__page-btn" href="{{ paginate.previous.url }}" aria-label="Page précédente">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a class="mcp__page-num" href="{{ part.url }}" aria-label="Page {{ part.title }}">{{ part.title }}</a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span class="mcp__page-num is-current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="mcp__page-ellipsis">…</span>
                  {%- endif -%}
                {%- endfor -%}
                {%- if paginate.next -%}
                  <a class="mcp__page-btn" href="{{ paginate.next.url }}" aria-label="Page suivante">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
              </nav>
            {%- endif -%}
          {%- endif -%}
        {%- endpaginate -%}
      </div>

    </main>
  </div>
</div>

{%- comment -%}━━━━━━━━━━━━━━━━━━━ 4. BRANDS CAROUSEL ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
{%- if show_brands -%}
<div class="mcp__brands" aria-label="{{ section.settings.brands_title | default: 'Nos marques' }}">
  <div class="mcp__brands-inner">
    {%- if section.settings.brands_title != blank -%}
      <p class="mcp__brands-label">{{ section.settings.brands_title }}</p>
    {%- endif -%}
    <div class="mcp__brands-track" aria-hidden="true">
      {%- assign brand_loop_count = 2 -%}
      {%- for i in (1..brand_loop_count) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand' -%}
            <div class="mcp__brand-item" {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <img src="{{ block.settings.logo | image_url: width: 160 }}" alt="{{ block.settings.name | default: '' | escape }}" loading="lazy" width="80" height="30">
              {%- else -%}
                <span class="mcp__brand-name">{{ block.settings.name | default: 'Brand' }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks | where: 'type', 'brand' | size == 0 -%}
          {%- assign default_brands = 'Sony,DJI,Rode,Canon,Elgato,Shure,Blackmagic,Logitech' | split: ',' -%}
          {%- for brand in default_brands -%}
            <div class="mcp__brand-item"><span class="mcp__brand-name">{{ brand }}</span></div>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

{%- comment -%}━━━━━━━━━━━━━━━━━━━ 5. GUIDE / CONTENT ━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
{%- if show_guide -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'guide_block' -%}
      <div class="mcp__guide" {{ block.shopify_attributes }}>
        <div class="mcp__guide-inner">
          <div class="mcp__guide-header">
            {%- if block.settings.eyebrow != blank -%}
              <span class="mcp__guide-eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            <h2 class="mcp__guide-title">{{ block.settings.title | default: 'Guides & Conseils' }}</h2>
            {%- if block.settings.subtitle != blank -%}
              <p class="mcp__guide-sub">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>
          {%- if block.settings.content != blank -%}
            <div class="mcp__guide-content rte">{{ block.settings.content }}</div>
          {%- endif -%}
          {%- if block.settings.faq != blank -%}
            <div class="mcp__faq">
              {%- assign faq_items = block.settings.faq | newline_to_br | split: '<br />' -%}
              {%- for item in faq_items -%}
                {%- if item contains '::' -%}
                  {%- assign parts = item | split: '::' -%}
                  <details class="mcp__faq-item">
                    <summary class="mcp__faq-q">{{ parts[0] | strip }}</summary>
                    <div class="mcp__faq-a">{{ parts[1] | strip }}</div>
                  </details>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

</div>

<style>
/* ══════════════════════════════════════════════════════════
   MCP — Main Collection Premium — Motion19 OS 2.0
   Prefix: mcp
   ══════════════════════════════════════════════════════════ */

.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

.mcp {
  --mcp-ease:     cubic-bezier(0.4, 0, 0.2, 1);
  --mcp-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --mcp-ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  background: var(--mcp-bg, #fff);
  color: var(--mcp-text, #1a1a1a);
}

/* ── HERO ──────────────────────────────────────────────── */
.mcp__hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  min-height: var(--mcp-hero-h-mob, 500px);
}
@media (min-width: 768px) {
  .mcp__hero--small  { min-height: 45vh; }
  .mcp__hero--medium { min-height: 65vh; }
  .mcp__hero--large  { min-height: 80vh; }
  .mcp__hero--full   { min-height: 100svh; }
}

.mcp__hero-media { position: absolute; inset: 0; z-index: 0; }
.mcp__hero-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}
.mcp__hero-overlay { position: absolute; inset: 0; }
.mcp__hero-overlay--full { background: rgba(0,0,0,var(--ov-a,.55)); }
.mcp__hero-overlay--bottom {
  background: linear-gradient(to top, rgba(0,0,0,calc(var(--ov-a,.55)*1.6)) 0%, rgba(0,0,0,calc(var(--ov-a,.55)*0.9)) 35%, rgba(0,0,0,calc(var(--ov-a,.55)*0.3)) 100%);
}
.mcp__hero-overlay--left {
  background: linear-gradient(to right, rgba(0,0,0,calc(var(--ov-a,.55)*1.5)) 0%, rgba(0,0,0,calc(var(--ov-a,.55)*0.5)) 55%, transparent 100%);
}
.mcp__hero-overlay--center {
  background: radial-gradient(ellipse at center, rgba(0,0,0,calc(var(--ov-a,.55)*0.4)) 0%, rgba(0,0,0,calc(var(--ov-a,.55)*1.2)) 100%);
}

.mcp__hero-glow {
  position: absolute; z-index: 1; pointer-events: none;
  width: 700px; height: 700px; border-radius: 50%;
  background: radial-gradient(circle, rgba(7,135,234,0.15) 0%, transparent 70%);
  top: -150px; right: -150px; filter: blur(50px);
  animation: mcpGlowPulse 7s ease-in-out infinite alternate;
}
@keyframes mcpGlowPulse { from { opacity: 0.5; transform: scale(1); } to { opacity: 1; transform: scale(1.2); } }

.mcp__hero-content {
  position: relative; z-index: 2; width: 100%;
  padding: clamp(60px,10vw,140px) clamp(16px,5vw,80px) clamp(60px,8vw,120px);
}
.mcp__hero--align-center .mcp__hero-content { display: flex; flex-direction: column; align-items: center; text-align: center; }
.mcp__hero--align-right  .mcp__hero-content { display: flex; flex-direction: column; align-items: flex-end; text-align: right; }

.mcp__hero-inner {
  max-width: 680px;
  opacity: 0; transform: translateY(20px);
  will-change: opacity, transform;
}
.mcp__hero-inner.is-visible {
  opacity: 1; transform: translateY(0);
  transition: opacity 700ms var(--mcp-ease-out), transform 700ms var(--mcp-ease-out);
}
.mcp--speed-fast .mcp__hero-inner.is-visible  { transition-duration: 450ms; }
.mcp--speed-slow .mcp__hero-inner.is-visible  { transition-duration: 1100ms; }
.mcp__hero--align-center .mcp__hero-inner { max-width: 760px; }

.mcp__breadcrumb {
  display: inline-flex; align-items: center; gap: 6px; flex-wrap: wrap;
  margin-bottom: 18px;
}
.mcp__breadcrumb-link {
  font-size: 0.72rem; font-weight: 500; color: rgba(255,255,255,0.65);
  text-decoration: none; transition: color 150ms ease;
}
.mcp__breadcrumb-link:hover { color: #fff; }
.mcp__breadcrumb-sep { font-size: 0.7rem; color: rgba(255,255,255,0.35); }
.mcp__breadcrumb-current { font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.9); }

.mcp__hero-title {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: clamp(2.2rem, 6vw, 5rem);
  font-weight: 800; line-height: 1.0; letter-spacing: -0.04em;
  color: #fff; margin: 0 0 18px;
}

.mcp__hero-desc {
  font-size: clamp(0.9rem, 1.5vw, 1.05rem);
  font-weight: 400; line-height: 1.65;
  color: rgba(255,255,255,0.75); margin: 0 0 28px;
  max-width: 52ch;
}

.mcp__hero-stats {
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  margin-bottom: 32px;
}
.mcp__hero-stat { display: flex; flex-direction: column; gap: 2px; }
.mcp__hero-stat-num {
  font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1;
}
.mcp__hero-stat-label {
  font-size: 0.65rem; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(255,255,255,0.55);
}
.mcp__hero-stat-sep {
  width: 1px; height: 32px;
  background: rgba(255,255,255,0.2);
}

.mcp__hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; }
.mcp__hero--align-center .mcp__hero-ctas { justify-content: center; }

.mcp__hero-btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.8rem; font-weight: 600;
  letter-spacing: 0.07em; text-transform: uppercase;
  padding: 13px 28px; border-radius: var(--mcp-btn-radius, 3px);
  border: 1.5px solid transparent;
  text-decoration: none;
  transition: background 180ms ease, color 180ms ease, border-color 180ms ease, transform 180ms ease;
}
.mcp__hero-btn svg { flex-shrink: 0; transition: transform 180ms ease; }
.mcp__hero-btn:hover svg { transform: translateX(3px); }
.mcp__hero-btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,0.6); }
.mcp__hero-btn--outline-white:hover { background: #fff; color: #0a0a0a; }
.mcp__hero-btn--solid { background: rgba(245,245,247,0.95); color: #0a0a0a; }
.mcp__hero-btn--solid:hover { background: var(--mcp-accent, #0787ea); color: #fff; transform: scale(1.02); }
.mcp__hero-btn--primary { background: var(--mcp-accent, #0787ea); color: #fff; border-color: var(--mcp-accent, #0787ea); }
.mcp__hero-btn--primary:hover { filter: brightness(1.1); transform: scale(1.02); }
.mcp__hero-btn--dark { background: #0a0a0a; color: #f5f5f7; }
.mcp__hero-btn--dark:hover { background: #1a1a1a; transform: scale(1.02); }

.mcp__hero-scroll {
  position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 6px;
  opacity: 0.5; transition: opacity 200ms ease;
}
.mcp__hero-scroll:hover { opacity: 0.9; }
.mcp__hero-scroll-line {
  width: 1.5px; height: 32px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8));
  animation: mcpScrollBounce 2s ease-in-out infinite;
}
@keyframes mcpScrollBounce { 0%,100%{transform:scaleY(1);opacity:.5} 50%{transform:scaleY(1.4);opacity:1} }
.mcp__hero-scroll-label { font-size: 0.58rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.65); }

@media (max-width: 767px) {
  .mcp__hero-title { letter-spacing: -0.03em; }
  .mcp__hero-stats { gap: 14px; }
  .mcp__hero-stat-num { font-size: 1.3rem; }
  .mcp__hero-scroll { display: none; }
  .mcp__hero-btn { padding: 12px 22px; }
}

/* ── STICKY BAR ────────────────────────────────────────── */
.mcp__sticky {
  position: sticky; top: 0; z-index: 120;
  background: var(--mcp-sticky-bg, rgba(255,255,255,0.88));
  backdrop-filter: saturate(180%) blur(14px);
  -webkit-backdrop-filter: saturate(180%) blur(14px);
  border-bottom: 1px solid rgba(10,10,10,0.07);
  transition: box-shadow 250ms var(--mcp-ease);
}
.mcp__sticky.is-scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.06); }

.mcp__sticky-inner {
  max-width: var(--mcp-container, 1400px);
  margin: 0 auto;
  padding: 0 clamp(12px,3vw,40px);
  height: 56px;
  display: flex; align-items: center; gap: 12px;
}

.mcp__sticky-left  { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
.mcp__sticky-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; margin-left: auto; }
.mcp__sticky-center { flex: 1; min-width: 0; overflow: hidden; }

.mcp__filter-toggle {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
  background: none; border: 1px solid rgba(10,10,10,0.14); border-radius: var(--mcp-btn-radius, 3px);
  color: var(--mcp-text, #1a1a1a); padding: 7px 13px; cursor: pointer;
  transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
  white-space: nowrap;
}
.mcp__filter-toggle:hover { background: var(--mcp-text, #1a1a1a); color: #fff; border-color: var(--mcp-text, #1a1a1a); }
.mcp__filter-toggle.is-active { background: var(--mcp-text, #1a1a1a); color: #fff; border-color: var(--mcp-text, #1a1a1a); }
.mcp__filter-count {
  background: var(--mcp-accent, #0787ea); color: #fff;
  font-size: 0.62rem; font-weight: 700; min-width: 18px; height: 18px;
  border-radius: 100px; padding: 0 5px;
  display: inline-flex; align-items: center; justify-content: center;
}

.mcp__product-count { font-size: 0.75rem; color: #888; white-space: nowrap; }

.mcp__quick-nav { width: 100%; overflow: hidden; }
.mcp__quick-nav-scroll {
