    if (isDesktop) return;
    sidebar.hidden = true;
    sidebar.setAttribute('aria-hidden', 'true');
    if (filterBtn) filterBtn.setAttribute('aria-expanded', 'false');
    if (filterBtn) filterBtn.classList.remove('is-active');
    if (overlay) overlay.classList.remove('is-active');
    document.body.style.overflow = '';
    if (filterBtn) filterBtn.focus();
  }

  if (filterBtn) filterBtn.addEventListener('click', function () {
    var isDesktop = window.innerWidth >= 1024;
    if (isDesktop) {
      var nowHidden = sidebar && sidebar.hidden;
      if (nowHidden) {
        sidebar.hidden = false;
        filterBtn.classList.add('is-active');
      } else {
        sidebar.hidden = true;
        filterBtn.classList.remove('is-active');
      }
    } else {
      openSidebar();
    }
  });
  if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
  if (overlay)  overlay.addEventListener('click', closeSidebar);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSidebar();
  });

  /* ── Desktop: sidebar always visible ── */
  function initSidebarDesktop() {
    if (!sidebar) return;
    if (window.innerWidth >= 1024) {
      sidebar.hidden = false;
      sidebar.removeAttribute('aria-hidden');
      document.body.style.overflow = '';
    }
  }
  initSidebarDesktop();
  window.addEventListener('resize', initSidebarDesktop);

  /* ── Filter accordion ── */
  wrap.addEventListener('click', function (e) {
    var head = e.target.closest('.mcp__filter-group-head');
    if (!head) return;
    var expanded = head.getAttribute('aria-expanded') === 'true';
    var body = document.getElementById(head.getAttribute('aria-controls'));
    head.setAttribute('aria-expanded', String(!expanded));
    if (body) {
      if (expanded) {
        body.style.maxHeight = body.scrollHeight + 'px';
        requestAnimationFrame(function () { body.style.maxHeight = '0'; });
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        body.addEventListener('transitionend', function handler() {
          body.style.maxHeight = '';
          body.removeEventListener('transitionend', handler);
        });
      }
    }
  });

  /* ── Sort change ── */
  if (sortSel) {
    sortSel.addEventListener('change', function () {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', sortSel.value);
      window.location.href = url.toString();
    });
  }

  /* ── View toggle (grid/list) ── */
  var viewBtns = wrap.querySelectorAll('.mcp__view-btn');
  viewBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var view = btn.dataset.view;
      viewBtns.forEach(function (b) {
        b.classList.toggle('is-active', b === btn);
        b.setAttribute('aria-pressed', String(b === btn));
      });
      if (grid) {
        grid.classList.toggle('mcp__grid--list-view', view === 'list');
      }
    });
  });

  /* ── Card reveal on scroll ── */
  if ('IntersectionObserver' in window && grid) {
    var cardObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        e.target.classList.add('is-visible');
        cardObs.unobserve(e.target);
      });
    }, { threshold: 0.06 });
    Array.from(grid.querySelectorAll('.m19-card')).forEach(function (c) { cardObs.observe(c); });
  } else if (grid) {
    Array.from(grid.querySelectorAll('.m19-card')).forEach(function (c) { c.classList.add('is-visible'); });
  }

  /* ── Quick Add (icon button + text button) ── */
  function doAtc(btn, variantId) {
    if (btn.dataset.loading) return;
    btn.dataset.loading = '1';
    var label = btn.querySelector('.pg__atc-label') || btn;
    var origText = btn.tagName === 'BUTTON' && btn.classList.contains('m19-card__quick-add') ? btn.textContent : null;
    if (origText) btn.textContent = '…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btn.classList.add('is-added');
      if (origText) btn.textContent = '✓ Ajouté';
      if (typeof M19Cart !== 'undefined') M19Cart.updateBadge();
      setTimeout(function () {
        btn.classList.remove('is-added');
        if (origText) btn.textContent = origText;
        delete btn.dataset.loading;
      }, 2000);
    })
    .catch(function () {
      if (origText) btn.textContent = 'Erreur';
      setTimeout(function () {
        if (origText) btn.textContent = origText;
        delete btn.dataset.loading;
      }, 2000);
    });
  }

  if (grid) {
    grid.addEventListener('click', function (e) {
      var btn = e.target.closest('.mcp__atc-icon, .mcp__atc-text');
      if (!btn) return;
      e.preventDefault();
      doAtc(btn, btn.dataset.variantId);
    });
  }

  /* ── Price range UI ── */
  wrap.querySelectorAll('.mcp__price-range').forEach(function (pr) {
    var minInput = pr.querySelector('.mcp__price-range-input--min');
    var maxInput = pr.querySelector('.mcp__price-range-input--max');
    var fill     = pr.querySelector('.mcp__price-range-fill');
    var minVal   = pr.querySelector('[id*="price-min"]');
    var maxVal   = pr.querySelector('[id*="price-max"]');

    function updateRange() {
      var min = parseFloat(minInput.min), max = parseFloat(maxInput.max);
      var lo  = parseFloat(minInput.value), hi = parseFloat(maxInput.value);
      if (lo > hi) { var t = lo; lo = hi; hi = t; }
      var leftPct  = ((lo - min) / (max - min)) * 100;
      var rightPct = ((hi - min) / (max - min)) * 100;
      if (fill) { fill.style.left = leftPct + '%'; fill.style.width = (rightPct - leftPct) + '%'; }
      if (minVal) minVal.textContent = lo.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
      if (maxVal) maxVal.textContent = hi.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
    }
    if (minInput && maxInput) {
      minInput.addEventListener('input', updateRange);
      maxInput.addEventListener('input', updateRange);
      updateRange();
    }
  });

  /* ── Filter form auto submit on checkbox ── */
  var filterForm = document.getElementById('mcp-filter-form-' + sid);
  if (filterForm) {
    filterForm.addEventListener('change', function (e) {
      if (e.target.type === 'checkbox') {
        filterForm.submit();
      }
    });
  }

  /* ── Active filter count badge ── */
  var countBadge = document.getElementById('mcp-filter-count-' + sid);
  if (countBadge) {
    var activeCount = wrap.querySelectorAll('.mcp__active-pill').length;
    if (activeCount > 0) {
      countBadge.textContent = activeCount;
      countBadge.hidden = false;
    }
  }

  /* ── Load More ── */
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function () {
      var nextUrl = loadMoreBtn.dataset.nextUrl;
      if (!nextUrl) return;
      loadMoreBtn.classList.add('is-loading');
      loadMoreBtn.querySelector('.mcp__loadmore-label').textContent = 'Chargement…';

      fetch(nextUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var parser = new DOMParser();
        var doc = parser.parseFromString(html, 'text/html');
        var newGrid = doc.getElementById('mcp-product-grid-' + sid);
        if (newGrid) {
          var newCards = Array.from(newGrid.querySelectorAll('.m19-card'));
          newCards.forEach(function (card) {
            grid.insertBefore(card, loadMoreWrap);
          });
          if ('IntersectionObserver' in window) {
            newCards.forEach(function (c) { cardObs.observe(c); });
          } else {
            newCards.forEach(function (c) { c.classList.add('is-visible'); });
          }
        }
        var newLoadMore = doc.getElementById('mcp-loadmore-' + sid);
        if (newLoadMore && newLoadMore.dataset.nextUrl) {
          loadMoreBtn.dataset.nextUrl = newLoadMore.dataset.nextUrl;
          loadMoreBtn.classList.remove('is-loading');
          loadMoreBtn.querySelector('.mcp__loadmore-label').textContent = '{{ section.settings.loadmore_label | default: "Charger plus" | escape }}';
          var newInfo = newLoadMore.querySelector('.mcp__loadmore-info');
          var info = loadMoreBtn.querySelector('.mcp__loadmore-info');
          if (newInfo && info) info.textContent = newInfo.textContent;
        } else {
          if (loadMoreWrap) loadMoreWrap.remove();
        }
      })
      .catch(function () {
        loadMoreBtn.classList.remove('is-loading');
        loadMoreBtn.querySelector('.mcp__loadmore-label').textContent = '{{ section.settings.loadmore_label | default: "Charger plus" | escape }}';
      });
    });
  }

  /* ── Shopify section editor events ── */
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sid) {
      if (heroInner) requestAnimationFrame(function () { heroInner.classList.add('is-visible'); });
      initSidebarDesktop();
    }
  });

})();
</script>

