{{ 'card.css' | asset_url | stylesheet_tag }}
{%- comment -%} Creator Testimonials — Motion19 — OS 2.0 v4 (Swiper) {%- endcomment -%}

{%- liquid
  assign sid = section.id

  assign bg_color      = section.settings.bg_color          | default: 'var(--color-bg-soft)'
  assign card_bg       = section.settings.card_bg           | default: 'var(--color-bg)'
  assign text_color    = section.settings.text_color        | default: 'var(--color-bg-dark)'
  assign title_color   = section.settings.title_color       | default: 'var(--color-bg-dark)'
  assign eyebrow_col   = section.settings.eyebrow_color     | default: 'var(--color-primary)'
  assign subtitle_col  = section.settings.subtitle_color    | default: 'var(--color-text-light)'
  assign quote_color   = section.settings.quote_color       | default: '#555555'
  assign name_color    = section.settings.name_color        | default: 'var(--color-bg-dark)'
  assign role_color    = section.settings.role_color        | default: '#999999'
  assign mark_color    = section.settings.mark_color        | default: 'rgba(10,10,10,0.10)'
  assign divider_color = section.settings.divider_color     | default: 'rgba(10,10,10,0.07)'
  assign card_radius   = section.settings.card_radius       | default: 6
  assign card_border_c = section.settings.card_border_color | default: 'var(--color-border)'
  assign show_border   = section.settings.card_show_border
  assign show_shadow   = section.settings.card_show_shadow

  assign pt_m         = section.settings.padding_top_mobile     | default: 52
  assign pb_m         = section.settings.padding_bottom_mobile  | default: 40
  assign pt_d         = section.settings.padding_top_desktop    | default: 72
  assign pb_d         = section.settings.padding_bottom_desktop | default: 52
  assign mt           = section.settings.margin_top             | default: 0
  assign mb           = section.settings.margin_bottom          | default: 0
  assign gap_cards    = section.settings.cards_gap              | default: 14
  assign max_width    = section.settings.max_width              | default: 1400
  assign header_align = section.settings.header_align           | default: 'left'
  assign scroll_speed = section.settings.scroll_speed           | default: 8000

  assign card_border_w = '1px'
  unless show_border
    assign card_border_w = '0px'
  endunless

  assign card_shadow_val = '0 2px 16px rgba(0,0,0,0.06)'
  unless show_shadow
    assign card_shadow_val = 'none'
  endunless

  assign ct_has_content = false
  for block in section.blocks
    if block.settings.testimonial != blank
      assign ct_has_content = true
      break
    endif
  endfor
-%}

<section
  id="ct-{{ sid }}"
  class="ct"
  aria-labelledby="ct-title-{{ sid }}"
  style="
    --ct-bg:          {{ bg_color }};
    --ct-card-bg:     {{ card_bg }};
    --ct-text:        {{ text_color }};
    --ct-title:       {{ title_color }};
    --ct-eyebrow:     {{ eyebrow_col }};
    --ct-subtitle:    {{ subtitle_col }};
    --ct-quote:       {{ quote_color }};
    --ct-name:        {{ name_color }};
    --ct-role:        {{ role_color }};
    --ct-mark:        {{ mark_color }};
    --ct-divider:     {{ divider_color }};
    --ct-card-r:      {{ card_radius }}px;
    --ct-card-bdr-c:  {{ card_border_c }};
    --ct-card-bdr-w:  {{ card_border_w }};
    --ct-card-shadow: {{ card_shadow_val }};
    --ct-pt-m:        {{ pt_m }}px;
    --ct-pb-m:        {{ pb_m }}px;
    --ct-pt-d:        {{ pt_d }}px;
    --ct-pb-d:        {{ pb_d }}px;
    --ct-mt:          {{ mt }}px;
    --ct-mb:          {{ mb }}px;
    --ct-gap:         {{ gap_cards }}px;
    --ct-max-w:       {{ max_width }}px;
  "
>
  <div class="ct__inner">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="ct__header ct__header--{{ header_align }}">
      <div class="ct__header-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="ct__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="ct__title" id="ct-title-{{ sid }}">
          {{- section.settings.title | default: 'Ce que disent nos créateurs' -}}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="ct__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Swiper — continuous autoplay ── {%- endcomment -%}
    <div class="ct__viewport-wrap">
      <div class="swiper ct__swiper" id="ct-swiper-{{ sid }}">
        <ul class="swiper-wrapper ct__track" role="list" aria-label="Témoignages">

          {%- if ct_has_content -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.testimonial != blank -%}
                <li class="swiper-slide ct__item" {{ block.shopify_attributes }}>
                  <article class="ct__card m19-card is-visible">
                    <div class="ct__avatar-wrap">
                      {%- if block.settings.photo != blank -%}
                        <img
                          src="{{ block.settings.photo | image_url: width: 128, height: 128, crop: 'center' }}"
                          srcset="
                            {{ block.settings.photo | image_url: width: 80, height: 80, crop: 'center' }} 80w,
                            {{ block.settings.photo | image_url: width: 128, height: 128, crop: 'center' }} 128w,
                            {{ block.settings.photo | image_url: width: 160, height: 160, crop: 'center' }} 160w
                          "
                          sizes="64px"
                          alt="{{ block.settings.name | default: 'Créateur' | escape }}"
                          width="64" height="64"
                          loading="lazy" decoding="async"
                        >
                      {%- else -%}
                        <div class="ct__avatar-fallback" aria-hidden="true">
                          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        </div>
                      {%- endif -%}
                    </div>
                    <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                    <blockquote class="ct__quote">
                      <p class="ct__quote-text">{{ block.settings.testimonial }}</p>
                    </blockquote>
                    <hr class="ct__divider" aria-hidden="true">
                    <div class="ct__creator">
                      <span class="ct__creator-name">{{ block.settings.name }}</span>
                      <span class="ct__creator-role">{{ block.settings.role }}</span>
                    </div>
                  </article>
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Le micro Blue Yeti commandé chez Motion19 a totalement transformé la qualité audio de mes vidéos. Livraison en 24h, emballage impeccable et un SAV réactif. Je ne commande plus ailleurs.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Alex Dubois</span><span class="ct__creator-role">Créateur YouTube — 280K</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Interface Focusrite Scarlett 2i2 reçue en parfait état. Le son de mon podcast a pris une toute autre dimension depuis. Je recommande Motion19 à tous les créateurs sérieux.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Marie Laurent</span><span class="ct__creator-role">Podcasteuse</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">J'ai équipé toute ma cabine de streaming chez Motion19 : micro, bras articulé, carte son. Le rapport qualité/prix est imbattable et les conseils via le chat sont vraiment utiles.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Tom Petitjean</span><span class="ct__creator-role">Streamer Twitch — Partner</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Deux panneaux LED Elgato reçus en deux jours. La différence sur mes shootings produit est impressionnante. Emballage soigné, rien n'était abîmé. Service client vraiment au top.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Léa Martin</span><span class="ct__creator-role">Photographe & vidéaste</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Rode NT-USB Mini pour mes interviews terrain, qualité pro pour un budget maîtrisé. Le service client m'a aidé à choisir le bon modèle. C'est rare de trouver ce niveau de conseil en ligne.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Julien Roy</span><span class="ct__creator-role">Vidéaste freelance</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Mon ring light et mon trépied de chez Motion19 sont mes meilleurs investissements de l'année. Mes abonnés ont immédiatement remarqué la différence de qualité sur mes vidéos.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Camille Nguyen</span><span class="ct__creator-role">Créatrice TikTok — 1.2M</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Écran BenQ de monitoring reçu parfaitement calibré à la livraison. En moins de 48h à domicile. Prix imbattable comparé aux autres boutiques spécialisées que j'avais consultées.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Baptiste Morel</span><span class="ct__creator-role">Monteur & coloriste</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">La webcam Logitech Brio 4K a changé la perception de mes formations en ligne. Image nette, couleurs naturelles sans réglage. Commande simple et livraison rapide chez Motion19.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Sarah Leclerc</span><span class="ct__creator-role">Coach en ligne & formatrice</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Interface Audient iD4 commandée un dimanche soir, reçue le mardi matin. Son cristallin pour mes enregistrements guitare et voix. Motion19 est ma boutique de référence désormais.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Kevin Marchand</span><span class="ct__creator-role">Guitariste & créateur musical</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Zoom H5 et ses accessoires reçus rapidement. La qualité d'enregistrement en terrain est irréprochable pour mes reportages. Très bonne communication de Motion19 tout au long de la commande.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Inès Fortier</span><span class="ct__creator-role">Journaliste & podcasteuse</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Setup complet acheté en une seule commande : micro, bras articulé, carte son, caméra. Tout est arrivé bien protégé dans un seul colis. Motion19 comprend vraiment les besoins des créateurs.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Romain Duval</span><span class="ct__creator-role">Streamer & esportif</span></div>
              </article>
            </li>

            <li class="swiper-slide ct__item">
              <article class="ct__card m19-card is-visible">
                <div class="ct__avatar-wrap"><div class="ct__avatar-fallback" aria-hidden="true"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div></div>
                <div class="ct__quote-mark" aria-hidden="true">&ldquo;</div>
                <blockquote class="ct__quote"><p class="ct__quote-text">Le Godox SL60W est parfait pour mes vidéos en intérieur. Lumière douce, facilement réglable et très naturelle à l'image. Livraison express et emballage impeccable, je suis fan de Motion19.</p></blockquote>
                <hr class="ct__divider" aria-hidden="true">
                <div class="ct__creator"><span class="ct__creator-name">Chloé Bernard</span><span class="ct__creator-role">Influenceuse lifestyle — 450K</span></div>
              </article>
            </li>

          {%- endif -%}

        </ul>
      </div>
    </div>

  </div>
</section>

<style>
/* ═══════════════════════════════════════════════════
   Creator Testimonials — ct — Motion19 OS 2.0 v4 (Swiper)
   mobile  ≤640px      → 1 + 0.3 partiel
   tablette 641-1023px → 3 + 0.3 partiel
   moyen  1024-1280px  → 4 + 0.3 partiel
   grand  ≥1281px      → 5 + 0.3 partiel
   ═══════════════════════════════════════════════════ */

.ct {
  --ct-pad:      16px;
  --ct-ease:     cubic-bezier(0.4, 0, 0.2, 1);
  --ct-usable-w: min(100vw, var(--ct-max-w, 1400px));
  --ct-card-w:   calc((var(--ct-usable-w) - (2 * var(--ct-pad)) - (1 * var(--ct-gap, 14px))) / 1.3);

  background:    var(--ct-bg, var(--color-bg-soft));
  color:         var(--ct-text, var(--color-bg-dark));
  margin-top:    var(--ct-mt, 0);
  margin-bottom: var(--ct-mb, 0);
  overflow-x:    clip;
}

/* ── tablette : 641px → 1023px — 3 + 0.3 ── */
@media (min-width: 641px) {
  .ct {
    --ct-pad:    24px;
    --ct-card-w: calc((var(--ct-usable-w) - (2 * var(--ct-pad)) - (3 * var(--ct-gap, 14px))) / 3.3);
  }
}

/* ── moyen : 1024px → 1280px — 4 + 0.3 ── */
@media (min-width: 1024px) {
  .ct {
    --ct-pad:    32px;
    --ct-card-w: calc((var(--ct-usable-w) - (2 * var(--ct-pad)) - (4 * var(--ct-gap, 14px))) / 4.3);
  }
}

/* ── grand : ≥1281px — 5 + 0.3 ── */
@media (min-width: 1281px) {
  .ct {
    --ct-pad:    40px;
    --ct-card-w: calc((var(--ct-usable-w) - (2 * var(--ct-pad)) - (5 * var(--ct-gap, 14px))) / 5.3);
  }
}

/* ── Inner container ── */
.ct__inner {
  max-width: var(--ct-max-w, 1400px);
  margin: 0 auto;
  padding-top:    var(--ct-pt-m, 52px);
  padding-bottom: var(--ct-pb-m, 40px);
}
@media (min-width: 641px) {
  .ct__inner {
    padding-top:    var(--ct-pt-d, 72px);
    padding-bottom: var(--ct-pb-d, 52px);
  }
}

/* ── Header ── */
.ct__header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
  padding: 0 var(--ct-pad) 28px;
}
.ct__header--center { align-items: center; text-align: center; }
.ct__header--right  { align-items: flex-end; text-align: right; }

.ct__header-text { display: flex; flex-direction: column; gap: 6px; }

.ct__eyebrow {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ct-eyebrow, var(--color-primary));
}
.ct__title {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--ct-title, var(--color-bg-dark));
  margin: 0;
}
.ct__subtitle {
  font-size: 0.875rem;
  color: var(--ct-subtitle, var(--color-text-light));
  margin: 0;
  max-width: 52ch;
  line-height: 1.55;
}

/* ── Viewport wrap ── */
.ct__viewport-wrap {
  overflow: hidden;
  padding-top: 8px;
  margin-top: -8px;
  padding-bottom: 32px;
  margin-bottom: -32px;
  contain: layout style;
}

/* ── Swiper ── */
.ct__swiper {
  overflow: visible;
  padding: 20px var(--ct-pad) 28px;
}

.ct__swiper .ct__track {
  margin: 0;
  padding: 0;
  list-style: none;
  gap: var(--ct-gap, 14px);
  align-items: stretch;
}

/* ── Slide ── */
.ct__swiper .ct__item {
  width: var(--ct-card-w) !important;
  flex-shrink: 0;
  height: auto;
  display: flex;
  flex-direction: column;
  contain: layout;
}

/* ── Card ── */
.ct__card {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28px 22px 22px;
  background: var(--ct-card-bg, #fff);
  border-radius: var(--ct-card-r, 6px);
  border: var(--ct-card-bdr-w, 1px) solid var(--ct-card-bdr-c, var(--color-border));
  box-shadow: var(--ct-card-shadow, 0 2px 16px rgba(0,0,0,0.06));
  font-family: var(--font-body, 'Inter', sans-serif);
  overflow: visible;
  transition: transform 200ms var(--ct-ease), box-shadow 200ms var(--ct-ease);
  will-change: transform;
}

@media (prefers-reduced-motion: reduce) {
  .ct__card { transition: none; will-change: auto; }
}

/* ── Avatar ── */
.ct__avatar-wrap {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-bottom: 20px;
  border: 1.5px solid rgba(10,10,10,0.08);
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  contain: strict;
}
.ct__avatar-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  border-radius: 50%;
}
.ct__avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(10,10,10,0.3);
}

/* ── Quote mark ── */
.ct__quote-mark {
  font-size: 4rem;
  line-height: 0.7;
  color: var(--ct-mark, rgba(10,10,10,0.10));
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: 700;
  margin-bottom: 14px;
  align-self: center;
  user-select: none;
  aria-hidden: true;
}

/* ── Quote text ── */
.ct__quote {
  margin: 0;
  flex: 1;
  display: flex;
  align-items: flex-start;
  width: 100%;
}
.ct__quote-text {
  font-size: 0.875rem;
  line-height: 1.72;
  color: var(--ct-quote, #555555);
  font-style: italic;
  margin: 0;
  text-align: center;
  width: 100%;
  display: -webkit-box;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Divider ── */
.ct__divider {
  border: none;
  border-top: 1px solid var(--ct-divider, rgba(10,10,10,0.07));
  width: 100%;
  margin: 20px 0 16px;
  flex-shrink: 0;
}

/* ── Creator footer ── */
.ct__creator {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  width: 100%;
  gap: 8px;
  min-width: 0;
}
.ct__creator-name {
  font-size: 0.8rem;
  font-weight: 600;
  font-style: italic;
  color: var(--ct-name, var(--color-bg-dark));
  letter-spacing: -0.01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;
}
.ct__creator-role {
  font-size: 0.72rem;
  font-weight: 400;
  font-style: italic;
  color: var(--ct-role, #999999);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 2;
  min-width: 0;
  text-align: right;
}

/* ── Masquer la navigation Swiper native ── */
.ct__swiper .swiper-pagination,
.ct__swiper .swiper-button-next,
.ct__swiper .swiper-button-prev { display: none !important; }

{%- if section.settings.custom_css != blank -%}
{{ section.settings.custom_css }}
{%- endif -%}
</style>

<script>
(function () {
  'use strict';

  var sid         = '{{ sid }}';
  var scrollSpeed = {{ scroll_speed }};
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var swiper      = null;

  function resumeIfPaused() {
    if (swiper && swiper.autoplay && !swiper.autoplay.running) {
      swiper.autoplay.start();
    }
  }

  function init() {
    var swiperEl = document.getElementById('ct-swiper-' + sid);
    if (!swiperEl || typeof Swiper === 'undefined') return;

    if (swiper) { swiper.destroy(true, true); swiper = null; }

    var speed = reducedMotion ? 0 : scrollSpeed;

    swiper = new Swiper(swiperEl, {
      slidesPerView:    'auto',
      spaceBetween:     0,
      loop:             true,
      speed:            speed,
      grabCursor:       false,
      allowTouchMove:   !reducedMotion,
      observer:         true,
      observeParents:   true,
      resizeObserver:   true,
      watchSlidesProgress: true,
      freeMode: {
        enabled:  !reducedMotion,
        momentum: false
      },
      autoplay: reducedMotion ? false : {
        delay:                0,
        disableOnInteraction: false,
        pauseOnMouseEnter:    true
      }
    });

    /* Pause au hover desktop */
    swiperEl.addEventListener('mouseenter', function () {
      if (swiper && swiper.autoplay) swiper.autoplay.stop();
    });
    swiperEl.addEventListener('mouseleave', function () {
      resumeIfPaused();
    });

    /* Reprise après touch — passive */
    swiperEl.addEventListener('touchend', function () {
      setTimeout(resumeIfPaused, 800);
    }, { passive: true });

    /* Pause quand hors viewport */
    if ('IntersectionObserver' in window && !reducedMotion) {
      var visObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (!swiper || !swiper.autoplay) return;
          if (e.isIntersecting) {
            resumeIfPaused();
          } else {
            swiper.autoplay.stop();
          }
        });
      }, { threshold: 0.1 });
      visObs.observe(swiperEl.closest('.ct') || swiperEl);
    }

    /* Pause quand onglet inactif */
    if (!reducedMotion) {
      document.addEventListener('visibilitychange', function () {
        if (!swiper || !swiper.autoplay) return;
        if (document.hidden) {
          swiper.autoplay.stop();
        } else {
          resumeIfPaused();
        }
      });
    }
  }

  function safeInit() {
    if (typeof Swiper !== 'undefined') { init(); return; }
    var attempts = 0;
    var t = setInterval(function () {
      attempts++;
      if (typeof Swiper !== 'undefined') { clearInterval(t); init(); return; }
      if (attempts >= 100) clearInterval(t);
    }, 50);
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sid) safeInit();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', safeInit, { once: true });
  } else {
    safeInit();
  }
})();
</script>

