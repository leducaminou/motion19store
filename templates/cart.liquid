{% comment %}
  Refined Cart Template — Moment-Inspired, Precise Layout, Mobile-First
{% endcomment %}

<style>
  /* ─── Design Tokens ─── */
  :root {
    --primary-black: #121212;
    --primary-blue: #007aff;
    --text-main: #1d1d1f;
    --text-muted: #6e6e73;
    --bg-light: #f5f5f7;
    --bg-white: #ffffff;
    --border-color: #e5e5e7;
    --border-radius-card: 0.375rem;
    --font-stack: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }

  body {
    font-family: var(--font-stack);
    color: var(--text-main);
    background: var(--bg-white);
    margin: 0;
    padding: 0;
    -webkit-font-smoothing: antialiased;
  }

  * {
    box-sizing: border-box;
  }

  .cart-wrapper {
    max-width: 1320px;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .cart-container {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3rem;
    align-items: start;
  }

  /* ─── Header ─── */
  .cart-header {
    background: #f8f8f8;
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-card);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    grid-column: 1 / -1;
  }

  .cart-title {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    color: var(--text-muted);
  }

  .cart-count-badge {
    background: var(--primary-black);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Cart Items ─── */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-card);
    background: var(--bg-white);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1.5rem;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .cart-item:last-child {
    border: none;
  }

  .cart-item-image-link {
    width: 100px;
    height: 100px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }

  .cart-item-image-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cart-item-main {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-item-title {
    font-size: 1.05rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-main);
    line-height: 1.4;
    max-width: 90%;
  }

  .cart-item-variant {
    font-size: 0.78rem;
    background: #f0f0f0;
    padding: 0.2rem 0.5rem;
    border-radius: 10px;
    color: var(--text-muted);
    width: fit-content;
  }

  .qty-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .qty-box {
    width: 48px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .qty-plus {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    color: var(--text-muted);
    transition: all 0.2s;
  }

  .cart-remove-link {
    font-size: 0.85rem;
    color: var(--text-main);
    text-decoration: underline;
    margin-left: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .cart-item-status {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  .status-in-stock {
    font-weight: 500;
    color: #000;
  }
  .status-ready {
    color: var(--text-muted);
  }

  .cart-item-price {
    font-size: 1.1rem;
    font-weight: 500;
    text-align: right;
  }

  /* ─── Summary Sidebar ─── */
  .summary-box {
    background: #f8f8f8;
    border-radius: var(--border-radius-card);
    padding: 2rem;
    border: 1px solid var(--border-color);
    width: 100%;
  }

  .summary-title {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 2rem 0;
    color: var(--text-muted);
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .summary-info-block {
    background: #ededed;
    padding: 0.75rem 1rem;
    border-radius: var(--border-radius-card);
    font-size: 0.8rem;
    color: #444;
    margin: 1.5rem 0;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #ddd;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .total-value {
    font-size: 1.4rem;
    letter-spacing: 0;
  }

  .btn-checkout {
    display: block;
    width: 100%;
    padding: 1.25rem;
    background: #222;
    color: #fff;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    margin-top: 1.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  /* Trust Badges */
  .trust-badges {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.82rem;
    color: #444;
  }

  .trust-icon {
    width: 18px;
    color: var(--primary-blue);
    flex-shrink: 0;
  }

  .continue-shopping {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    text-decoration: none;
    color: var(--text-main);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    width: fit-content;
    padding: 0.5rem 0;
    transition: transform 0.2s ease;
  }

  .continue-shopping:hover {
    transform: translateX(-5px);
  }

  .continue-shopping svg {
    color: var(--primary-blue);
  }

  /* ─── Responsive ─── */
  @media (max-width: 991px) {
    .cart-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .cart-wrapper {
      margin: 1.5rem auto;
    }
    .cart-header {
      grid-column: 1;
    }
  }

  @media (max-width: 599px) {
    .cart-wrapper {
      padding: 0 1rem;
      margin: 1rem auto;
    }

    /* Image + (info + price) en 2 colonnes */
    .cart-item {
      grid-template-columns: 76px 1fr;
      grid-template-rows: auto auto;
      gap: 0.75rem 1rem;
      padding: 1rem;
    }

    .cart-item-image-link {
      width: 76px;
      height: 76px;
      grid-row: 1 / 3;
    }

    /* Prix passe sous le texte, dans la colonne droite */
    .cart-item-price {
      grid-column: 2;
      text-align: left;
      font-size: 1rem;
    }

    .cart-item-title {
      font-size: 0.95rem;
      max-width: 100%;
    }

    .qty-row {
      flex-wrap: wrap;
    }

    .summary-box {
      padding: 1.25rem;
    }

    .btn-checkout {
      padding: 1rem;
      font-size: 0.85rem;
    }
  }
</style>

<div class="cart-wrapper">
  {%- if cart.item_count > 0 -%}
    <div class="cart-container" id="cartContainer">
      <!-- Gauche : Liste des articles -->
      <div class="cart-left">
        <header class="cart-header">
          <h1 class="cart-title">PANIER</h1>
          <span class="cart-count-badge">{{ cart.item_count }}</span>
        </header>

        <div class="cart-items-list">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <a href="{{ item.url }}" class="cart-item-image-link">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" loading="lazy" width="200" height="200">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}
              </a>

              <div class="cart-item-main">
                <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <span class="cart-item-variant">{{ item.variant.title }}</span>
                {%- endunless -%}

                <div class="qty-row" style="margin-top: 1rem;">
                  <div class="qty-box">{{ item.quantity }}</div>
                  <button class="qty-plus" onclick="updateQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})">
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </button>
                  <button class="cart-remove-link" onclick="updateQty({{ forloop.index }}, 0)">Supprimer</button>
                </div>

                <div class="cart-item-status">
                  <span class="status-in-stock">En stock</span>
                  <span class="status-ready">Prêt à être expédié</span>
                </div>
              </div>

              <div class="cart-item-price">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <a href="/collections/all" class="continue-shopping">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Continuer mes achats
        </a>
      </div>

      <!-- Droite : Résumé -->
      <aside class="cart-summary">
        <div class="summary-box">
          <h2 class="summary-title">RÉSUMÉ DU PANIER</h2>

          <div class="summary-line">
            <span>SOUS-TOTAL</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="summary-line">
            <span>TAXES</span>
            <span>{{ cart.total_tax | money }}</span>
          </div>

          <div class="summary-line">
            <span>LIVRAISON</span>
            <span>Calculée</span>
          </div>

          <div class="summary-info-block">Les taxes et frais de port sont calculés à la caisse</div>

          <div class="summary-total">
            <span>TOTAL</span>
            <span class="total-value">{{ cart.total_price | money }}</span>
          </div>

          <a href="/checkout" class="btn-checkout">COMMANDER</a>

          <div class="trust-badges">
            <div class="trust-badge">
              <svg
                class="trust-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><polyline points="12 8 8 12 12 16"/><line x1="16" y1="12" x2="8" y2="12"/>
              </svg>
              <span>Retours sous 90 jours pour les membres</span>
            </div>
            <div class="trust-badge">
              <svg
                class="trust-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              <span>Garantie à vie sur les produits Motion</span>
            </div>
          </div>
        </div>
      </aside>
    </div>

  {%- else -%}
    <div style="text-align: center; padding: 6rem 0;">
      <h1 class="cart-title">VOTRE PANIER EST VIDE</h1>
      <a
        href="/collections/all"
        class="btn-checkout"
        style="width: auto; display: inline-block; padding: 1.25rem 3rem; margin-top: 2rem;"
        >COMMENCER MES ACHATS</a
      >
    </div>
  {%- endif -%}
</div>

<script>
  async function updateQty(line, qty) {
    const container = document.getElementById('cartContainer');
    if (container) container.style.opacity = '0.5';

    try {
      const params = new URLSearchParams();
      params.append('line', line.toString());
      params.append('quantity', qty.toString());

      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: params,
      });

      if (response.ok) {
        window.location.reload();
      } else {
        const errorData = await response.json();
        alert('Could not update cart: ' + (errorData.description || errorData.message || 'Error ' + response.status));
        if (container) container.style.opacity = '1';
      }
    } catch (error) {
      console.error('Cart update error:', error);
      if (container) container.style.opacity = '1';
    }
  }
</script>
